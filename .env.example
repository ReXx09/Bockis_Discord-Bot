# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=dein_discord_bot_token_hier
STATUS_CHANNEL_ID=channel_id_fuer_die_status_nachricht
DISCORD_NOTIFICATION_CHANNEL=channel_id_fuer_aenderungs_alerts
DISCORD_STATUS_RENDER_MODE=auto
DISCORD_STATUS_WEBHOOK_URL=
CHANNEL_STATUS_INDICATOR=true
GUILD_ID=
SERVICE_CATEGORY_NAME=📊 Service Status
MONITORED_SERVICES=
DISCORD_ENABLED_COMMANDS=status,uptime,refresh,help,coinflip,dice,eightball,cleanup,translate

# ── Discord Übersetzer (/translate) ──────────────────────────────────────────
DISCORD_TRANSLATE_ENABLED=false
DISCORD_TRANSLATE_DEFAULT_TARGET=de
DISCORD_TRANSLATE_DEFAULT_SOURCE=auto
DISCORD_TRANSLATE_API_URL=https://libretranslate.com/translate
DISCORD_TRANSLATE_API_KEY=
DISCORD_TRANSLATE_ALLOWED_GUILD_IDS=
DISCORD_TRANSLATE_MAX_TEXT_LENGTH=1800

# ── Uptime Kuma ────────────────────────────────────────────────────────────────
UPTIME_KUMA_URL=http://uptime.deinedomain.de
UPTIME_KUMA_API_KEY=uk1_deinapikey
STATUS_PAGE_SLUG=dienste

# ── Timing ────────────────────────────────────────────────────────────────────
# Update-Intervall in Millisekunden (Standard: 300000 = 5 Minuten)
UPDATE_INTERVAL=300000

# ── Webserver ─────────────────────────────────────────────────────────────────
WEB_PORT=3000
# Passwort für das Web-Dashboard (leer lassen = kein Passwortschutz)
DASHBOARD_PASSWORD=

# ── Cloudflare Tunnel / Link Preview ──────────────────────────────────────────
# Öffentliche URL der Statusseite für Discord-Linkvorschau (z. B. https://status.deinedomain.de)
CLOUDFLARE_PUBLIC_URL=

# ── KI-Chat (OpenAI / ChatGPT) ────────────────────────────────────────────────
# KI-Chat aktivieren: Nutzer können den Bot per @Mention oder DM ansprechen
OPENAI_ENABLED=false
# OpenAI-kompatible API Base URL (OpenAI, Groq, OpenRouter, ...)
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI API-Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
# Modell: gpt-4o-mini (günstig), gpt-4o (besser), gpt-3.5-turbo (legacy)
OPENAI_MODEL=gpt-4o-mini
# Persönlichkeitsname des Bots im Chat
OPENAI_PERSONA_NAME=Bockis
# System-Prompt (leer = Standard-Persönlichkeit basierend auf OPENAI_PERSONA_NAME)
OPENAI_SYSTEM_PROMPT=
# Optionale Kanal-IDs wo KI-Chat aktiv ist, getrennt mit , oder ; (leer = überall)
OPENAI_CHANNEL_IDS=
# Maximale Antwort-Länge in Tokens (50–2000)
OPENAI_MAX_TOKENS=600
# Bot antwortet auch auf Direktnachrichten
OPENAI_ALLOW_DMS=true
# Maximale Anfragen pro Nutzer pro Minute (Schutz vor Missbrauch)
OPENAI_RATE_LIMIT_PER_MINUTE=5

# ── Datenbank ─────────────────────────────────────────────────────────────────
DB_DIALECT=sqlite
DB_STORAGE=./data/status.db
