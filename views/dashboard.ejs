  async function loadSystemLocalization() {
    const statusEl = document.getElementById('cfgLocaleStatus');
    const btn = document.getElementById('btnLocaleReload');
    if (btn) btn.disabled = true;
    if (statusEl) { statusEl.textContent = 'LadeвА¶'; statusEl.className = 'muted'; }
    try {
      const d = await fetch('/api/system-localization').then(r => r.json());
      if (!d.ok) throw new Error(d.error || 'Laden fehlgeschlagen');
      const tz = document.getElementById('cfgTimezone');
      const dt = document.getElementById('cfgDateTimeLocal');
      const locale = document.getElementById('cfgSystemLocale');
      if (tz) {
        if (Array.isArray(d.timezoneOptions) && d.timezoneOptions.length) {
          const existingValues = new Set(Array.from(tz.options).map(o => o.value));
          d.timezoneOptions.forEach((opt) => {
            if (!opt?.value || existingValues.has(opt.value)) return;
            const o = document.createElement('option');
            o.value = opt.value;
            o.textContent = opt.label || opt.value;
            tz.appendChild(o);
          });
        }
        if (d.timezone && !Array.from(tz.options).some(o => o.value === d.timezone)) {
          const o = document.createElement('option');
          o.value = d.timezone;
          o.textContent = `${d.timezone} (aktuell)`;
          tz.appendChild(o);
        }
        tz.value = d.timezone || '';
      }
      if (dt) dt.value = d.dateTimeLocal || '';
      if (locale) {
        if (Array.isArray(d.localeOptions) && d.localeOptions.length) {
          const existingValues = new Set(Array.from(locale.options).map(o => o.value));
          d.localeOptions.forEach((opt) => {
            if (!opt?.value || existingValues.has(opt.value)) return;
            const o = document.createElement('option');
            o.value = opt.value;
            o.textContent = opt.label || opt.value;
            locale.appendChild(o);
          });
        }
        locale.value = d.systemLocale || '';
      }
      if (statusEl) {
        statusEl.textContent = `Aktuell: ${d.localDate || '-'} ${d.localTime || '-'} | TZ: ${d.timezone || '-'} | Sprache: ${d.systemLocale || '-'}`;
        statusEl.className = 'muted';
      }
    } catch (e) {
      if (statusEl) { statusEl.textContent = 'Fehler: ' + e.message; statusEl.className = 'err'; }
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  async function saveSystemLocalization() {
    const statusEl = document.getElementById('cfgLocaleStatus');
    const btn = document.getElementById('btnLocaleSave');
    const body = {
      timezone: document.getElementById('cfgTimezone')?.value.trim() || '',
      datetimeLocal: document.getElementById('cfgDateTimeLocal')?.value || '',
      systemLocale: document.getElementById('cfgSystemLocale')?.value.trim() || ''
    };
    if (!body.timezone && !body.datetimeLocal && !body.systemLocale) {
      if (statusEl) { statusEl.textContent = 'Keine Werte gesetzt'; statusEl.className = 'warn'; }
      return;
    }

    if (btn) btn.disabled = true;
    if (statusEl) { statusEl.textContent = '√Ьbernehme SystemeinstellungenвА¶'; statusEl.className = 'muted'; }
    try {
      const d = await fetch('/api/system-localization', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      }).then(r => r.json());

      if (!d.ok) {
        const msg = [d.error, d.hint, d.details].filter(Boolean).join(' | ');
        throw new Error(msg || 'Speichern fehlgeschlagen');
      }
      if (statusEl) { statusEl.textContent = 'вЬУ √Ьbernommen: ' + (d.applied || []).join(', '); statusEl.className = 'ok'; }
      toast('вЬУ Raspi-Einstellungen √Љbernommen', 'ok');
      loadSystemLocalization();
    } catch (e) {
      if (statusEl) { statusEl.textContent = 'Fehler: ' + e.message; statusEl.className = 'err'; }
      toast('Fehler: ' + e.message, 'err');
    } finally {
      if (btn) btn.disabled = false;
    }
  }

