            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px">
              <input type="checkbox" id="cfgAutoReactionEnabled" style="width:16px;height:16px;cursor:pointer;accent-color:var(--green)">
              <span>Für neue Guild-Nachrichten automatisch Emojis setzen</span>
