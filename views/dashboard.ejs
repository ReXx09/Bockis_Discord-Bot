          <button class="cfg-nav-btn active" data-cfg-pane-btn="bot" onclick="setActiveSettingsPane('bot')">🤖 Bot & IDs</button>
          <button class="cfg-nav-btn" data-cfg-pane-btn="commands" onclick="setActiveSettingsPane('commands')">⌨️ Bot-Kommandos</button>
          <button class="cfg-nav-btn" data-cfg-pane-btn="channels" onclick="setActiveSettingsPane('channels')">🧩 Dienst-Kanäle</button>
          <button class="cfg-nav-btn" data-cfg-pane-btn="renderer" onclick="setActiveSettingsPane('renderer')">📡 Discord Renderer</button>
          <button class="cfg-nav-btn" data-cfg-pane-btn="security" onclick="setActiveSettingsPane('security')">🗂 Sicherheit & API</button>
          <button class="cfg-nav-btn" data-cfg-pane-btn="raspi" onclick="setActiveSettingsPane('raspi')">🍓 Raspi & Web</button>
        </div>
      </div>

      <div class="cfg-panels">
      <div class="cfg-pane-card" data-cfg-pane="bot">
