  function arAddRule() {
    const newId = `regel-${Date.now()}`;
    _arRules.push({ id: newId, trigger: '', mode: 'contains', reply: '', caseSensitive: false });
    arRenderTable();
    // Zur neuen Zeile scrollen
    const tbody = document.getElementById('arTableBody');
    const lastRow = tbody.querySelector(`tr[data-ar-idx="${_arRules.length - 1}"]`);
    if (lastRow) lastRow.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    // ID-Feld der neuen Zeile fokussieren
    const idInput = tbody.querySelector(`tr[data-ar-idx="${_arRules.length - 1}"] input[data-ar-field="id"]`);
    if (idInput) { idInput.value = ''; idInput.focus(); arFieldChanged(_arRules.length - 1, 'id', ''); }
  }

  function arDeleteRule(idx) {
    _arRules.splice(idx, 1);
    arRenderTable();
  }

  function arSyncTemplateCheckboxesFromRules(rules = []) {
    const ids = new Set((Array.isArray(rules) ? rules : []).map(r => String(r?.id || '').trim()));
    const mapping = [
      ['cfgTemplateGoodEvening', 'good-evening'],
      ['cfgTemplateGoodDay', 'good-day'],
      ['cfgTemplateGreeting', 'greeting'],
      ['cfgTemplateWeekend', 'weekend'],
      ['cfgTemplateWeekdays', 'weekdays'],
    ];
    mapping.forEach(([checkboxId, ruleId]) => {
      const el = document.getElementById(checkboxId);
      if (el) el.checked = ids.has(ruleId);
    });
  }

  async function arLoadRules() {
    const st = document.getElementById('arStatus');
    st.textContent = 'вП≥ LadenвА¶'; st.className = 'muted';
    try {
      const d = await fetch('/api/auto-replies').then(r => r.json());
      if (!d.ok) { st.textContent = 'вЬЧ ' + d.error; st.className = 'err'; return; }
      _arRules = d.rules;
      arRenderTable();
      arSyncTemplateCheckboxesFromRules(_arRules);
      st.textContent = `вЬУ ${_arRules.length} Regel${_arRules.length !== 1 ? 'n' : ''} geladen`;
      st.className = 'ok';
    } catch (e) {
      st.textContent = 'вЬЧ Fehler: ' + e.message; st.className = 'err';
    }
  }

  async function arSaveRules() {
    const st = document.getElementById('arStatus');
    const btn = document.getElementById('btnArSave');
    btn.disabled = true;
    st.textContent = 'вП≥ SpeichernвА¶'; st.className = 'muted';
    try {
      const d = await fetch('/api/auto-replies', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ rules: _arRules })
      }).then(r => r.json());
      if (!d.ok) { st.textContent = 'вЬЧ ' + d.error; st.className = 'err'; }
      else { st.textContent = `вЬУ ${d.count} Regel${d.count !== 1 ? 'n' : ''} gespeichert`; st.className = 'ok'; }
    } catch (e) {
      st.textContent = 'вЬЧ Fehler: ' + e.message; st.className = 'err';
    } finally {
      btn.disabled = false;
    }
  }

  async function saveAutoReplyTemplates() {
    const btn = document.getElementById('btnSaveAutoReplyTemplates');
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'вП≥ SpeichernвА¶';
    
    const templates = {
      goodEvening: document.getElementById('cfgTemplateGoodEvening').checked,
      goodDay: document.getElementById('cfgTemplateGoodDay').checked,
      greeting: document.getElementById('cfgTemplateGreeting').checked,
      weekend: document.getElementById('cfgTemplateWeekend').checked,
      weekdays: document.getElementById('cfgTemplateWeekdays').checked
    };
    
    try {
      const response = await fetch('/api/auto-reply-templates', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ templates })
      });
      const result = await response.json();
      if (result.ok) {
        toast('вЬУ Templates gespeichert! Auto-Replies aktualisiert.', 'ok');
        // Regeln neu laden um die Updates zu sehen
        setTimeout(() => arLoadRules(), 500);
      } else {
        toast('вЬЧ Fehler: ' + result.error, 'err');
      }
    } catch (e) {
      toast('вЬЧ Fehler: ' + e.message, 'err');
    } finally {
      btn.disabled = false;
      btn.textContent = originalText;
    }
  }

