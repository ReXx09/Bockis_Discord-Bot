  // ── Init ─────────────────────────────────────────────
  fetchAll();
  resetCd();
  checkUpdate();
  checkDeps();
  setActivePane(localStorage.getItem(STORAGE_KEY_ACTIVE_PANE) || 'overview');

  // ── Update Check ─────────────────────────────────────
  let _updateData = null;

  async function checkUpdate(showToast = false) {
    try {
      const d = await fetch('/api/update-check').then(r => r.json());
      const state = document.getElementById('updateState');

      if (!d.ok) {
        if (state) state.textContent = 'Fehler beim Prüfen';
        if (showToast) toast('Update-Prüfung fehlgeschlagen', 'err');
        return;
      }

      if (!d.hasGit) {
        if (state) state.textContent = 'Kein Git-Repository erkannt';
        if (showToast) toast('Kein Git-Repository erkannt', 'warn');
        return;
      }

      if (d.fetchFailed) {
        if (state) state.textContent = 'Git Fetch fehlgeschlagen';
        if (showToast) toast('Git Fetch fehlgeschlagen', 'warn');
        return;
      }

      _updateData = d;

      const banner = document.getElementById('updateBanner');
      const sub    = document.getElementById('ubSub');

      if (d.updateAvailable) {
        if (state) state.textContent = `${d.behind} Commit${d.behind > 1 ? 's' : ''} verfügbar`;
        sub.textContent = `${d.behind} neuer Commit${d.behind > 1 ? 's' : ''} verfügbar · lokal: ${d.local} · remote: ${d.remote}`;
        banner.classList.remove('hidden');
        renderCommits(d.commits);
        if (showToast) toast(`Update verfügbar: ${d.behind} Commit${d.behind > 1 ? 's' : ''}`, 'warn');
      } else {
        if (state) state.textContent = 'Aktuell, kein Update verfügbar';
        // Kein Update — trotzdem Versioninfo im Bot-Card ergänzen
        const bi = document.getElementById('botInfo');
        if (bi) bi.innerHTML += row('Git-Commit', d.local + ' ✓ aktuell');
        renderCommits([]);
        if (showToast) toast('Kein Update verfügbar', 'ok');
      }
    } catch { /* update check ist nicht kritisch */ }
  }

  function renderCommits(commits) {
    const cl = document.getElementById('commitList');
    if (!commits.length) { cl.innerHTML = '<span class="muted">Keine Details verfügbar.</span>'; return; }
    cl.innerHTML = commits.map(c =>
      `<div class="commit">
        <span class="commit-hash">${c.hash}</span>
        <span class="commit-msg">${c.subject.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</span>
        <span class="commit-when">${c.when}</span>
      </div>`
    ).join('');
  }

  function toggleUpdateSection() {
    const card = document.getElementById('updateCard');
    if (card) card.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ── Abhängigkeiten prüfen ────────────────────────────

  async function checkDeps(showToast = false) {
    const btn   = document.getElementById('btnDepsCheck');
    const state = document.getElementById('depsState');
    const list  = document.getElementById('depsList');

    btn.disabled = true;
    btn.textContent = '⏳ Prüfe…';
    if (state) state.textContent = 'Prüfe npm-Pakete…';

    try {
      const d = await fetch('/api/deps-check').then(r => r.json());

      if (!d.ok) {
        if (state) state.textContent = 'Fehler: ' + (d.error || 'Unbekannt');
        if (showToast) toast('Fehler beim Abhängigkeitscheck', 'err');
        return;
      }

      const rows = d.packages.map(p => {
        const badge = !p.outdated
          ? `<span class="dep-badge dep-ok-badge">✓ aktuell</span>`
          : p.majorBump
            ? `<span class="dep-badge dep-crit-badge">↑ Major ${escapeHtml(p.latest)}</span>`
            : `<span class="dep-badge dep-warn-badge">↑ Minor ${escapeHtml(p.latest)}</span>`;
        return `<tr>
          <td><span class="dep-name">${escapeHtml(p.name)}</span>${p.type === 'devDependency' ? '<span class="dep-dev">dev</span>' : ''}</td>
          <td class="dep-ver">${escapeHtml(p.required)}</td>
          <td class="dep-ver">${escapeHtml(p.current ?? '–')}</td>
          <td class="dep-ver">${escapeHtml(p.wanted  ?? '–')}</td>
          <td class="dep-ver">${escapeHtml(p.latest  ?? '–')}</td>
          <td>${badge}</td>
        </tr>`;
      }).join('');

      list.innerHTML = `
        <table class="deps-table">
          <thead><tr>
            <th>Paket</th><th>Erwartet</th><th>Installiert</th><th>Kompatibel</th><th>Neuest</th><th>Status</th>
          </tr></thead>
          <tbody>${rows}</tbody>
        </table>`;

      const txt = d.outdatedCount > 0
        ? `${d.outdatedCount} von ${d.total} Paket(en) veraltet`
        : `Alle ${d.total} Pakete aktuell`;
      if (state) state.textContent = txt;
      if (showToast) toast(txt, d.outdatedCount > 0 ? 'err' : 'ok');
    } catch (e) {
      if (state) state.textContent = 'Verbindungsfehler';
      if (showToast) toast('Fehler: ' + e.message, 'err');
    } finally {
      btn.disabled = false;
      btn.textContent = '🔎 Abhängigkeiten prüfen';
    }
  }

  async function runUpdate(modeOverride = null, sourceBtnId = 'btnUpdateRun') {
    const btn = document.getElementById(sourceBtnId) || document.getElementById('btnUpdateRun');
    const bannerBtn = document.getElementById('btnUpdateRun');
    const paneBtn = document.getElementById('btnUpdateRunPane');
    const modeSelect = document.getElementById('updateMode');
    const selectedMode = modeOverride || (modeSelect ? modeSelect.value : 'auto');

    btn.disabled = true;
    btn.textContent = '⏳ Update läuft…';
    if (bannerBtn && bannerBtn !== btn) bannerBtn.disabled = true;
    if (paneBtn && paneBtn !== btn) paneBtn.disabled = true;

    const log  = document.getElementById('updateLog');
    const state = document.getElementById('updateState');
    if (state) state.textContent = `Update läuft (${selectedMode})…`;
    log.innerHTML = '';
    log.classList.add('visible');
    log.scrollTop = 0;

    const addLine = (text, cls = '') => {
      const el = document.createElement('div');
      el.className = 'ul-line ' + cls;
      // ANSI-Escape-Codes entfernen
      el.textContent = text.replace(/\x1b\[[0-9;]*m/g, '');
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
    };

    try {
      const res  = await fetch('/api/update-run', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode: selectedMode })
      });

      const reader = res.body.getReader();
      const dec    = new TextDecoder();
      let buf = '';

      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        const parts = buf.split('\n\n');
        buf = parts.pop();
        for (const part of parts) {
          if (!part.startsWith('data:')) continue;
          const line = part.slice(5).trim();
          if (line.startsWith('__EXIT__:')) {
            const code = line.split(':')[1];
            if (code === '0') {
              addLine('✓ Update erfolgreich abgeschlossen!', 'ul-ok');
              toast('✓ Bot erfolgreich aktualisiert!', 'ok');
              document.getElementById('updateBanner').classList.add('hidden');
              if (state) state.textContent = 'Update erfolgreich abgeschlossen';
            } else {
              addLine(`✗ Update fehlgeschlagen (Exit-Code ${code})`, 'ul-err');
              toast('Update fehlgeschlagen', 'err');
              if (state) state.textContent = `Update fehlgeschlagen (Code ${code})`;
            }
          } else {
            let cls = 'ul-line';
            if (/error|fehler|fail/i.test(line))   cls = 'ul-err';
            else if (/warn|⚠/i.test(line))         cls = 'ul-warn';
            else if (/✓|success|erfolgreich/i.test(line)) cls = 'ul-ok';
            addLine(line, cls);
          }
        }
      }
    } catch (e) {
      addLine('Verbindungsfehler: ' + e.message, 'ul-err');
      toast('Fehler: ' + e.message, 'err');
      if (state) state.textContent = 'Verbindungsfehler beim Update';
    } finally {
      btn.disabled = false;
      if (sourceBtnId === 'btnUpdateRunPane') {
        btn.textContent = '▶ Update starten';
        if (bannerBtn) {
          bannerBtn.disabled = false;
          bannerBtn.textContent = '▶ Update jetzt starten';
        }
      } else {
        btn.textContent = '▶ Update jetzt starten';
        if (paneBtn) {
          paneBtn.disabled = false;
          paneBtn.textContent = '▶ Update starten';
        }
      }
      checkUpdate(false);
    }
  }

  function setFieldValue(id, value) {
    const el = document.getElementById(id);
    if (!el) return;
    const normalized = value ?? '';
    el.value = normalized;
    el.dataset.initialValue = normalized;
  }

  function maybeSetChanged(body, key, id, { allowEmpty = false } = {}) {
    const el = document.getElementById(id);
    if (!el) return;
    const value = el.value.trim();
    const initial = (el.dataset.initialValue || '').trim();
    if (value === initial) return;
    if (!allowEmpty && !value) return;
    body[key] = value;
  }

  // ── Config laden ─────────────────────────────────────
  async function loadConfig() {
    try {
      const d = await fetch('/api/config').then(r => r.json());
      if (!d.ok) { document.getElementById('cfgStatus').textContent = d.error; return; }

      // Secret-Felder bleiben leer, Platzhalter zeigt maskierten Ist-Wert.
      setFieldValue('cfgToken', '');
      setFieldValue('cfgApiKey', '');
      setFieldValue('cfgWebhookUrl', '');
      setFieldValue('cfgDashPassword', '');

      document.getElementById('cfgToken').dataset.initialValue = d.DISCORD_TOKEN ? '__MASKED__' : '';
      document.getElementById('cfgApiKey').dataset.initialValue = d.UPTIME_KUMA_API_KEY ? '__MASKED__' : '';
      document.getElementById('cfgWebhookUrl').dataset.initialValue = d.DISCORD_STATUS_WEBHOOK_URL ? '__MASKED__' : '';
      document.getElementById('cfgDashPassword').dataset.initialValue = d.DASHBOARD_PASSWORD ? '__MASKED__' : '';

      setFieldValue('cfgStatusCh', d.STATUS_CHANNEL_ID || '');
      setFieldValue('cfgNotifCh', d.DISCORD_NOTIFICATION_CHANNEL || '');
      setFieldValue('cfgKumaUrl', d.UPTIME_KUMA_URL || '');
      setFieldValue('cfgRenderMode', d.DISCORD_STATUS_RENDER_MODE || 'auto');
      setFieldValue('cfgStatusTitle', d.DISCORD_STATUS_MESSAGE_TITLE || '');
      setFieldValue('cfgStatusButtonLabel', d.DISCORD_STATUS_BUTTON_LABEL || 'Statusseite öffnen');
      setFieldValue('cfgSlug', d.STATUS_PAGE_SLUG || 'dienste');
      setFieldValue('cfgCloudflareUrl', d.CLOUDFLARE_PUBLIC_URL || '');
      setFieldValue('cfgGuildId', d.GUILD_ID || '');
      setFieldValue('cfgServiceCategory', d.SERVICE_CATEGORY_NAME || '');
      setFieldValue('cfgMonitoredServices', d.MONITORED_SERVICES || '');
      setFieldValue('cfgUpdateInterval', d.UPDATE_INTERVAL || '300000');
      setFieldValue('cfgWebPort', d.WEB_PORT || '3000');
      setFieldValue('cfgDbStorage', d.DB_STORAGE || './data/status.db');

      document.getElementById('cfgStatus').textContent = '';
      document.getElementById('cfgToken').placeholder = d.DISCORD_TOKEN
        ? `Aktuell: ${d.DISCORD_TOKEN} — leer lassen = unverändert`
        : 'Neuen Token eingeben';
      document.getElementById('cfgApiKey').placeholder = d.UPTIME_KUMA_API_KEY
        ? `Aktuell: ${d.UPTIME_KUMA_API_KEY} — leer lassen = unverändert`
        : 'Neuen API Key eingeben';
      document.getElementById('cfgWebhookUrl').placeholder = d.DISCORD_STATUS_WEBHOOK_URL
        ? `Aktuell: ${d.DISCORD_STATUS_WEBHOOK_URL} — leer lassen = unverändert`
        : 'Webhook URL (optional)';
      document.getElementById('cfgDashPassword').placeholder = d.DASHBOARD_PASSWORD
        ? `Aktuell: ${d.DASHBOARD_PASSWORD} — leer lassen = unverändert`
        : 'Neues Passwort eingeben (optional)';

      const indicatorEl = document.getElementById('cfgChannelIndicator');
      indicatorEl.checked = (d.CHANNEL_STATUS_INDICATOR || 'true') !== 'false';
      indicatorEl.dataset.initialValue = indicatorEl.checked ? 'true' : 'false';
    } catch (e) {
      document.getElementById('cfgStatus').textContent = 'Ladefehler: ' + e.message;
      document.getElementById('cfgStatus').className = 'err';
    }
  }

  // ── Config speichern mit Polling nach Restart ──────
  async function saveConfig() {
    const btn = document.getElementById('btnCfgSave');
    const st  = document.getElementById('cfgStatus');
    btn.disabled = true;
    btn.textContent = '⏳ Speichern…';
    st.textContent = '';
    st.className = '';

    const body = {};
    maybeSetChanged(body, 'DISCORD_TOKEN', 'cfgToken');
    maybeSetChanged(body, 'STATUS_CHANNEL_ID', 'cfgStatusCh');
    maybeSetChanged(body, 'DISCORD_NOTIFICATION_CHANNEL', 'cfgNotifCh');
    maybeSetChanged(body, 'UPTIME_KUMA_URL', 'cfgKumaUrl');
    maybeSetChanged(body, 'DISCORD_STATUS_RENDER_MODE', 'cfgRenderMode');
    maybeSetChanged(body, 'DISCORD_STATUS_MESSAGE_TITLE', 'cfgStatusTitle', { allowEmpty: true });
    maybeSetChanged(body, 'DISCORD_STATUS_BUTTON_LABEL', 'cfgStatusButtonLabel', { allowEmpty: true });
    maybeSetChanged(body, 'STATUS_PAGE_SLUG', 'cfgSlug');
    maybeSetChanged(body, 'CLOUDFLARE_PUBLIC_URL', 'cfgCloudflareUrl', { allowEmpty: true });
    maybeSetChanged(body, 'UPTIME_KUMA_API_KEY', 'cfgApiKey', { allowEmpty: true });
    maybeSetChanged(body, 'DISCORD_STATUS_WEBHOOK_URL', 'cfgWebhookUrl', { allowEmpty: true });
    maybeSetChanged(body, 'GUILD_ID', 'cfgGuildId');
    maybeSetChanged(body, 'SERVICE_CATEGORY_NAME', 'cfgServiceCategory');
    maybeSetChanged(body, 'MONITORED_SERVICES', 'cfgMonitoredServices', { allowEmpty: true });
    maybeSetChanged(body, 'UPDATE_INTERVAL', 'cfgUpdateInterval');
    maybeSetChanged(body, 'WEB_PORT', 'cfgWebPort');
    maybeSetChanged(body, 'DASHBOARD_PASSWORD', 'cfgDashPassword', { allowEmpty: true });
    maybeSetChanged(body, 'DB_STORAGE', 'cfgDbStorage');

    const indicatorEl = document.getElementById('cfgChannelIndicator');
    const currentIndicator = indicatorEl.checked ? 'true' : 'false';
    const initialIndicator = indicatorEl.dataset.initialValue || 'true';
    if (currentIndicator !== initialIndicator) {
      body.CHANNEL_STATUS_INDICATOR = currentIndicator;
    }

    if (Object.keys(body).length === 0) {
      st.textContent = 'Keine Änderungen erkannt';
      st.className = 'warn';
      btn.disabled = false;
      btn.textContent = '💾 Speichern & Neu starten';
      return;
    }

    try {
      const res = await fetch('/api/config', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(body),
      }).then(r => r.json());

      if (res.ok) {
        st.textContent = `✓ Gespeichert: ${res.updated.join(', ')}${res.restarted ? ' · Bot startet neu…' : ''}`;
        st.className = 'ok';
        toast('✓ Konfiguration gespeichert', 'ok');
        
        // Bot-Polling nach Restart vornehmen
        if (res.restarted) {
          st.textContent += ' ⏳ Warte auf Bot-Neustart…';
          btn.textContent = '⏳ Bot startet neu…';
          btn.disabled = true;
          
          // Polling: Versuche alle 500ms die config zu laden bis Bot antwortet
          let retries = 0;
          const maxRetries = 30; // max 15 Sekunden
          let pollBotReady = null;
          
          pollBotReady = setInterval(async () => {
            retries++;
            try {
              const testRes = await fetch('/api/config', { timeout: 2000 });
              if (testRes.ok) {
                clearInterval(pollBotReady);
                pollBotReady = null;
                await new Promise(r => setTimeout(r, 500)); // Kurze Pause für Bot-Stabilisierung
                loadConfig();
                fetchAll();
                await fetch('/api/refresh', { method: 'POST' }); // Sofortiger Discord-Update
                st.textContent = `✓ Bot neu gestartet. Status aktualisiert.`;
                st.className = 'ok';
                btn.textContent = '💾 Speichern & Neu starten';
                btn.disabled = false;
              }
            } catch (e) {
              if (retries >= maxRetries) {
                clearInterval(pollBotReady);
                pollBotReady = null;
                st.textContent = `⚠ Bot braucht länger als erwartet. Seite in 5s neu laden…`;
                st.className = 'warn';
                btn.disabled = false;
                btn.textContent = '💾 Speichern & Neu starten';
                setTimeout(() => location.reload(), 5000);
              }
            }
          }, 500);
        } else {
          loadConfig();
        }
      } else {
        st.textContent = '✗ ' + (res.error || 'Unbekannter Fehler');
        st.className = 'err';
        toast('Fehler: ' + res.error, 'err');
        btn.disabled = false;
        btn.textContent = '💾 Speichern & Neu starten';
      }
    } catch (e) {
      st.textContent = 'Verbindungsfehler: ' + e.message;
      st.className = 'err';
      toast('Verbindungsfehler', 'err');
      btn.disabled = false;
      btn.textContent = '💾 Speichern & Neu starten';
    }
  }

