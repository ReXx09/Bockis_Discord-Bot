<!-- ── TOAST ──────────────────────────────────────────── -->
<div id="toast"></div>

<script>
  const STORAGE_KEY_ACTIVE_PANE = 'dashboard-active-pane';

  function setActivePane(pane) {
    const paneLabels = {
      overview: 'Service Monitor · Live-Ansicht',
      settings: 'Einstellungen · Konfiguration & Steuerung',
      updates: 'Updates · Versionen & Deploy',
      diagnostics: 'Diagnose · Logs & Link-Preview-Checks'
    };

    document.querySelectorAll('[data-pane]').forEach(el => {
      el.classList.toggle('pane-hidden', el.dataset.pane !== pane);
    });

    document.querySelectorAll('[data-pane-btn]').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.paneBtn === pane);
    });

    const headerSub = document.getElementById('headerSub');
    if (headerSub) headerSub.textContent = paneLabels[pane] || paneLabels.overview;

    localStorage.setItem(STORAGE_KEY_ACTIVE_PANE, pane);

    if (pane === 'updates') {
      checkUpdate(false);
      checkDeps(false);
    }

    if (pane === 'diagnostics') {
      runLinkPreviewDiagnostics();
    }
  }

  function escapeHtml(v) {
    return String(v ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function diagLine(text, level = 'i') {
    return `<div class="ll ${level}">${escapeHtml(text)}</div>`;
  }

  function renderLinkPreviewDiagnostics(d) {
    const checkedAt = document.getElementById('diagCheckedAt');
    const summary = document.getElementById('diagSummary');
    const viewer = document.getElementById('diagViewer');
    const hints = document.getElementById('diagHints');

    if (!d.ok) {
      checkedAt.textContent = 'Letzter Lauf: Fehler';
      summary.innerHTML = `<div class="ll e">Diagnose fehlgeschlagen: ${escapeHtml(d.error || 'Unbekannter Fehler')}</div>`;
      viewer.innerHTML = diagLine('Keine Daten verfügbar', 'w');
      hints.innerHTML = '';
      return;
    }

    const localTs = d.checkedAt ? new Date(d.checkedAt).toLocaleString('de-DE') : '–';
    checkedAt.textContent = `Letzter Lauf: ${localTs}`;

    const discord = d.probes?.discord || {};
    const browser = d.probes?.browser || {};
    const diag = d.diagnosis || {};
    const modeUsesLinkPreview = diag.modeUsesLinkPreview !== false;
    const ynBadge = (ok, yes = 'OK', no = 'FEHLT') => ok
      ? `<span class="badge b-green">${yes}</span>`
      : `<span class="badge b-red">${no}</span>`;

    const richPreviewBadge = diag.richPreviewLikely != null
      ? ynBadge(diag.richPreviewLikely, 'JA', 'NEIN')
      : (discord.richPreview ? '<span class="badge b-green">JA</span>' : '<span class="badge b-red">NEIN</span>');

    const naBadge = '<span class="badge">N/A</span>';
    const discordHttpCell = discord.ok
      ? discord.status
      : (modeUsesLinkPreview
        ? `Fehler (${escapeHtml(discord.error || 'n/a')})`
        : `Optional (${escapeHtml(discord.error || 'n/a')})`);
    const contentTypeCell = modeUsesLinkPreview ? escapeHtml(discord.contentType || '–') : 'N/A (Modus-unabhängig)';

    summary.innerHTML =
      row('Ziel-URL', escapeHtml(d.targetUrl || '–')) +
      row('Render-Modus', escapeHtml(d.currentRenderMode || '–')) +
      row('Discord HTTP', discordHttpCell) +
      row('Browser HTTP', browser.ok ? browser.status : `Fehler (${escapeHtml(browser.error || 'n/a')})`) +
      row('Discord Rich Preview', modeUsesLinkPreview ? richPreviewBadge : naBadge) +
      row('Discord Content-Type', contentTypeCell) +
      row('Check: og:title', modeUsesLinkPreview ? ynBadge(!!diag.hasOgTitle) : naBadge) +
      row('Check: Beschreibung', modeUsesLinkPreview ? ynBadge(!!diag.hasDescription, 'OK', 'FEHLT (og:description/meta)') : naBadge) +
      row('Check: Bild', modeUsesLinkPreview ? ynBadge(!!diag.hasImage, 'OK', 'FEHLT (og:image/twitter:image)') : naBadge);

    const lines = [];
    lines.push(`URL: ${d.targetUrl || '–'}`);
    if (discord.ok) {
      lines.push(`Discord final URL: ${discord.finalUrl || '-'}`);
      lines.push(`Discord cache-control: ${discord.headers?.cacheControl || '-'}`);
      lines.push(`Discord cf-cache-status: ${discord.headers?.cfCacheStatus || '-'}`);
      lines.push(`Discord server: ${discord.headers?.server || '-'}`);
      lines.push(`OG title: ${discord.meta?.ogTitle || '-'}`);
      lines.push(`OG description: ${discord.meta?.ogDescription || '-'}`);
      lines.push(`OG image: ${discord.meta?.ogImage || '-'}`);
      lines.push(`Twitter card: ${discord.meta?.twitterCard || '-'}`);
      lines.push(`Twitter image: ${discord.meta?.twitterImage || '-'}`);
      if (discord.challengeDetected) lines.push('Cloudflare/Challenge Hinweise im HTML erkannt');
    } else {
      lines.push(`Discord Probe Fehler: ${discord.error || 'unbekannt'}`);
    }

    viewer.innerHTML = lines.map(l => {
      if (/fehler|challenge|nein/i.test(l)) return diagLine(l, 'e');
      if (/cache|server|twitter|og /i.test(l)) return diagLine(l, 'w');
      return diagLine(l, 'i');
    }).join('');

    let hintHtml = '';
    if ((d.hints || []).length) {
      hintHtml = d.hints.map(h => diagLine(h, /nein|fehler|unzureichend|blockiert/i.test(h) ? 'e' : 'w')).join('');
    } else {
      hintHtml = diagLine('Keine offensichtlichen Probleme gefunden.', 'i');
    }
    
    // Solutions anzeigen (Lösungsvorschläge)
    if ((d.solutions || []).length > 0) {
      hintHtml += diagLine('', 'i'); // Leerzeile
      hintHtml += d.solutions.map(s => diagLine(s, /lösung|option|embed/i.test(s) ? 'w' : 'i')).join('');
    }
    
    hints.innerHTML = hintHtml;
  }

  async function runLinkPreviewDiagnostics() {
    const btn = document.getElementById('btnDiagRun');
    if (!btn) return;
    btn.disabled = true;
    btn.textContent = '⏳ Diagnose läuft…';
    try {
      const d = await fetch('/api/diagnostics/link-preview').then(r => r.json());
      renderLinkPreviewDiagnostics(d);
    } catch (e) {
      renderLinkPreviewDiagnostics({ ok: false, error: e.message });
    } finally {
      btn.disabled = false;
      btn.textContent = 'Diagnose jetzt ausführen';
    }
  }

  // ── Countdown ────────────────────────────────────────
  const STORAGE_KEY_REFRESH_INTERVAL = 'dashboard-refresh-interval';
  let cd = 30, cdTimer = null;

  function getRefreshInterval() {
    return parseInt(localStorage.getItem(STORAGE_KEY_REFRESH_INTERVAL) || '30', 10);
  }

  function setRefreshInterval(val) {
    localStorage.setItem(STORAGE_KEY_REFRESH_INTERVAL, parseInt(val, 10));
    resetCd();
  }

  function resetCd() {
    clearInterval(cdTimer);
    cd = getRefreshInterval();
    const timerEl = document.getElementById('timer');
    if (cd === 0) {
      if (timerEl) timerEl.textContent = 'Auto-Refresh: Aus';
      return;
    }
    if (timerEl) timerEl.textContent = `Auto-Refresh in ${cd}s`;
    cdTimer = setInterval(() => {
      cd--;
      if (timerEl) timerEl.textContent = `Auto-Refresh in ${cd}s`;
      if (cd <= 0) {
        const activePane = localStorage.getItem(STORAGE_KEY_ACTIVE_PANE) || 'overview';
        if (activePane === 'overview') {
          fetchAll();
        }
        resetCd();
      }
    }, 1000);
  }

  // ── Toast ────────────────────────────────────────────
  function toast(msg, type = 'ok') {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.className = 'show ' + type;
    clearTimeout(el._t);
    el._t = setTimeout(() => el.className = '', 3500);
  }

  // ── Helpers ──────────────────────────────────────────
  function fmtUptime(sec) {
    const d = Math.floor(sec / 86400);
    const h = Math.floor((sec % 86400) / 3600);
    const m = Math.floor((sec % 3600) / 60);
    const s = Math.floor(sec % 60);
    if (d > 0) return `${d}d ${h}h ${m}m`;
    if (h > 0) return `${h}h ${m}m ${s}s`;
    return `${m}m ${s}s`;
  }

  function row(label, value) {
    return `<div class="row"><span class="row-label">${label}</span><span class="row-value">${value}</span></div>`;
  }

  function tempBadge(tempC) {
    if (tempC == null || Number.isNaN(tempC)) return '<span class="badge b-gray">N/V</span>';
    if (tempC >= 75) return `<span class="badge b-red">${tempC.toFixed(1)} °C</span>`;
    if (tempC >= 65) return `<span class="badge b-yellow">${tempC.toFixed(1)} °C</span>`;
    return `<span class="badge b-green">${tempC.toFixed(1)} °C</span>`;
  }

  // ── Render: Bot Info ─────────────────────────────────
  function renderBot(d) {
    const dot   = d.discordReady ? '<span class="dot dot-g"></span>' : '<span class="dot dot-r"></span>';
    const badge = d.discordReady ? '<span class="badge b-green">ONLINE</span>' : '<span class="badge b-red">OFFLINE</span>';
    const pingColor = d.ping < 0 ? 'var(--muted)' : d.ping < 100 ? 'var(--green)' : d.ping < 250 ? 'var(--yellow)' : 'var(--red)';
    const pingStr   = d.ping >= 0 ? `<span style="color:${pingColor}">${d.ping} ms</span>` : '–';

    document.getElementById('botInfo').innerHTML =
      row('Discord', dot + badge) +
      row('Bot-Tag', d.tag) +
      row('WS-Ping', pingStr) +
      row('Laufzeit', fmtUptime(d.uptime));
  }

  // ── Render: System ───────────────────────────────────
  function renderSys(bot, raspi = null) {
    const systemRam = raspi
      ? `${raspi.memUsedMb} / ${raspi.memTotalMb} MB (${raspi.memUsedPercent}%)`
      : '–';
    const load = raspi
      ? `${raspi.load1} / ${raspi.load5} / ${raspi.load15}`
      : '–';
    const platform = raspi?.platform || navigator.platform || '–';

    const systemRam = raspi
      ? `${raspi.memUsedMb} / ${raspi.memTotalMb} MB (${raspi.memUsedPercent}%)`
      : '–';
    const load = raspi
      ? `${raspi.load1} / ${raspi.load5} / ${raspi.load15}`
      : '–';
    const platform = raspi?.platform || navigator.platform || '–';

    document.getElementById('sysInfo').innerHTML =
      row('CPU-Temperatur', tempBadge(raspi?.cpuTempC ?? null)) +
      row('RAM (Raspberry)', systemRam) +
      row('Load (1/5/15)', load) +
      row('Node.js', bot.nodeVersion) +
      row('RAM (Prozess)', bot.memUsedMb + ' MB') +
      row('Heap (genutzt)', bot.memHeapMb + ' MB') +
      row('Plattform', platform);
  }

  // ── Render: Hardware-Metriken ─────────────────────────
  function _metricBarClass(pct) {
    if (pct >= 90) return 'crit';
    if (pct >= 70) return 'warn';
    return 'ok';
  }
  function _setMetricTile(ids, value, pct, sub, na = false) {
    const valEl = document.getElementById(ids.val);
    const barEl = document.getElementById(ids.bar);
    const subEl = document.getElementById(ids.sub);
    if (valEl) valEl.textContent = na ? 'N/V' : value;
    if (barEl && !na) {
      const p = Math.min(100, Math.max(0, pct));
      barEl.style.width = p + '%';
      barEl.className = 'metric-bar ' + _metricBarClass(p);
    }
    if (subEl) subEl.textContent = sub || '';
  }
  function fmtKBps(kbps) {
    if (kbps == null) return 'N/V';
    if (kbps >= 1024) return (kbps / 1024).toFixed(1) + ' MB/s';
    return kbps.toFixed(1) + ' KB/s';
  }
  function renderHwMetrics(r) {
    if (!r || !r.ok) {
      ['mtCpuPctVal','mtRamVal','mtCpuTempVal','mtGpuTempVal','mtNetDown','mtNetUp','mtDiskVal']
        .forEach(id => { const el = document.getElementById(id); if (el) el.textContent = 'N/V'; });
      return;
    }

    // CPU %
    if (r.cpuPercent != null) {
      _setMetricTile({ val:'mtCpuPctVal', bar:'mtCpuPctBar', sub:'mtCpuPctSub' },
        r.cpuPercent.toFixed(1) + '%', r.cpuPercent, `Load: ${r.load1} / ${r.load5} / ${r.load15}`);
    } else {
      _setMetricTile({ val:'mtCpuPctVal', bar:'mtCpuPctBar', sub:'mtCpuPctSub' },
        '', 0, `Load: ${r.load1} / ${r.load5} / ${r.load15}`, true);
    }

    // RAM
    _setMetricTile({ val:'mtRamVal', bar:'mtRamBar', sub:'mtRamSub' },
      r.memUsedPercent.toFixed(0) + '%', r.memUsedPercent,
      `${r.memUsedMb} / ${r.memTotalMb} MB`);

    // CPU Temperatur
    if (r.cpuTempC != null) {
      const pct = Math.min(100, (r.cpuTempC / 100) * 100);
      _setMetricTile({ val:'mtCpuTempVal', bar:'mtCpuTempBar', sub:'mtCpuTempSub' },
        r.cpuTempC.toFixed(1) + ' °C', pct, r.cpuTempC >= 75 ? '⚠ Heiß' : r.cpuTempC >= 65 ? '▲ Warm' : '✓ Normal');
    } else {
      _setMetricTile({ val:'mtCpuTempVal', bar:'mtCpuTempBar', sub:'mtCpuTempSub' }, '', 0, '', true);
    }

    // GPU Temperatur
    if (r.gpuTempC != null) {
      const pct = Math.min(100, (r.gpuTempC / 100) * 100);
      const src = r.gpuTempSource === 'nvidia' ? 'Nvidia' : r.gpuTempSource === 'vcgencmd' ? 'RPi VideoCore' : r.gpuTempSource;
      _setMetricTile({ val:'mtGpuTempVal', bar:'mtGpuTempBar', sub:'mtGpuTempSub' },
        r.gpuTempC.toFixed(1) + ' °C', pct, src);
    } else {
      const el = document.getElementById('mtGpuTempVal');
      if (el) el.textContent = 'N/V';
      const sub = document.getElementById('mtGpuTempSub');
      if (sub) sub.textContent = 'Kein GPU erkannt';
    }

    // Netzwerk
    const downEl = document.getElementById('mtNetDown');
    const upEl   = document.getElementById('mtNetUp');
    const downSub = document.getElementById('mtNetDownSub');
    const upSub   = document.getElementById('mtNetUpSub');
    if (downEl) downEl.textContent = r.netRxKBps != null ? fmtKBps(r.netRxKBps) : 'N/V';
    if (upEl)   upEl.textContent   = r.netTxKBps != null ? fmtKBps(r.netTxKBps) : 'N/V';
    if (downSub) downSub.textContent = '↓ Download';
    if (upSub)   upSub.textContent   = '↑ Upload';

    // Disk
    if (r.diskUsedPercent != null) {
      _setMetricTile({ val:'mtDiskVal', bar:'mtDiskBar', sub:'mtDiskSub' },
        r.diskUsedPercent.toFixed(0) + '%', r.diskUsedPercent,
        `${r.diskUsedGb} / ${r.diskTotalGb} GB (${r.diskAvailGb} GB frei)`);
    } else {
      _setMetricTile({ val:'mtDiskVal', bar:'mtDiskBar', sub:'mtDiskSub' }, '', 0, '', true);
    }
  }

  // ── Render: Monitors ─────────────────────────────────
  function monClass(m) {
    if (!m.active)    return 'inactive';
    if (m.status === 1) return 'online';
    if (m.status === 0) return 'offline';
    if (m.status === 2) return 'pending';
    return 'inactive';
  }
  function monBadge(m) {
    if (!m.active)    return '<span class="badge b-gray">DEAKTIVIERT</span>';
    if (m.status === 1) return '<span class="badge b-green">ONLINE</span>';
    if (m.status === 0) return '<span class="badge b-red">OFFLINE</span>';
    if (m.status === 2) return '<span class="badge b-yellow">PENDING</span>';
    return '<span class="badge b-gray">UNBEKANNT</span>';
  }
  function fillCls(u) {
    const v = parseFloat(u);
    return v >= 95 ? 'uf-g' : v >= 80 ? 'uf-y' : 'uf-r';
  }

  function renderMonitors(monitors) {
    const grid  = document.getElementById('monGrid');
    const count = document.getElementById('monCount');

    if (!monitors.length) {
      grid.innerHTML = '<p class="muted">Keine Daten von Uptime Kuma empfangen.</p>';
      count.textContent = '0';
      return;
    }

    const online  = monitors.filter(m => m.status === 1 && m.active).length;
    const offline = monitors.filter(m => m.status === 0 && m.active).length;
    count.textContent = `${online} / ${monitors.length} online` + (offline ? ` · ${offline} offline` : '');

    grid.innerHTML = monitors.map(m => {
      const lastCheck = m.time ? new Date(m.time).toLocaleTimeString('de-DE') : '–';
      const ping      = m.ping ? m.ping + ' ms' : '–';
      return `
        <div class="mc ${monClass(m)}">
          <div class="mc-name" title="${m.name}">${m.name}</div>
          <div class="mc-group">${m.group}</div>
          ${monBadge(m)}
          <div class="uptime-bar">
            <div class="uptime-fill ${fillCls(m.uptime)}" style="width:${m.uptime}%"></div>
          </div>
          <div class="mc-meta">
            <span>${m.uptime}% Uptime</span>
            <span>${ping}</span>
          </div>
          <div class="muted" style="margin-top:6px">⏱ ${lastCheck}</div>
        </div>`;
    }).join('');
  }

  // ── Render: Logs ─────────────────────────────────────
  function renderLogs(d) {
    document.getElementById('logFile').textContent = d.file || '–';
    const viewer = document.getElementById('logViewer');

    if (!d.lines.length) {
      viewer.innerHTML = '<span class="muted">Keine Log-Einträge gefunden.</span>';
      return;
    }

    viewer.innerHTML = d.lines.map(line => {
      let cls = 'll';
      if (/ERROR/i.test(line)) cls += ' e';
      else if (/WARN/i.test(line))  cls += ' w';
      else if (/INFO/i.test(line))  cls += ' i';
      const safe = line.replace(/</g, '&lt;').replace(/>/g, '&gt;');
      return `<div class="${cls}">${safe}</div>`;
    }).join('');
  }

  function renderLogTimeContext(d) {
    const el = document.getElementById('logTimeContext');
    if (!el) return;
    if (!d || !d.ok) {
      el.textContent = 'Zeit: nicht verfügbar';
      el.style.color = 'var(--muted)';
      return;
    }

    const sysTz = d.systemTimezone || 'n/a';
    const procTz = d.processTimezone || 'n/a';
    el.textContent = `Zeit: System ${d.systemTime || '-'} (${sysTz}) | Bot ${d.processTime || '-'} (${procTz})`;

    if (d.timezoneMismatch) {
      el.style.color = 'var(--yellow)';
    } else {
      el.style.color = 'var(--muted)';
    }
  }

  async function fetchJsonSafe(url, timeoutMs = 4500) {
    try {
      if (typeof AbortSignal !== 'undefined' && typeof AbortSignal.timeout === 'function') {
        const r = await fetch(url, { signal: AbortSignal.timeout(timeoutMs) });
        return await r.json();
      }

      const controller = new AbortController();
      const timer = setTimeout(() => controller.abort(), timeoutMs);
      try {
        const r = await fetch(url, { signal: controller.signal });
        return await r.json();
      } finally {
        clearTimeout(timer);
      }
    } catch {
      return { ok: false };
    }
  }

  let _fetchAllInFlight = false;

  // ── Fetch All ────────────────────────────────────────
  async function fetchAll() {
    if (_fetchAllInFlight) return;
    _fetchAllInFlight = true;
    try {
      const [bot, status, logs, raspi, timeCtx] = await Promise.all([
        fetchJsonSafe('/api/bot-info'),
        fetchJsonSafe('/api/status'),
        fetchJsonSafe('/api/logs', 6000),
        fetchJsonSafe('/api/raspi-status'),
        fetchJsonSafe('/api/time-context')
      ]);
      if (bot.ok)    { renderBot(bot); renderSys(bot, raspi?.ok ? raspi : null); }
      renderHwMetrics(raspi?.ok ? raspi : null);
      if (status.ok) renderMonitors(status.monitors);
      if (logs.ok)   renderLogs(logs);
      renderLogTimeContext(timeCtx);
    } catch (e) {
      toast('Verbindungsfehler – ' + e.message, 'err');
    } finally {
      _fetchAllInFlight = false;
    }
    // Tunnel-Status separat (non-blocking, cloudflared optional)
    try {
      const t = await fetchJsonSafe('/api/tunnel-status', 3500);
      renderTunnel(t);
    } catch { /* cloudflared nicht zwingend installiert */ }
    // Container-/Service-Erkennung (non-blocking)
    try {
      const c = await fetchJsonSafe('/api/container-detection', 3500);
      renderContainers(c);
    } catch { /* optional */ }
    // Service-Status laden
    fetchServiceStatus();
  }

  // ── Service Control ────────────────────────────────
  const SVC_LABELS = {
    'active':   ['b-green',  'AKTIV'],
    'inactive': ['b-gray',   'GESTOPPT'],
    'failed':   ['b-red',    'FEHLER'],
    'unknown':  ['b-yellow', 'UNBEKANNT']
  };

  async function fetchServiceStatus() {
    try {
      const d = await fetchJsonSafe('/api/service-status', 3500);
      if (!d.ok) return;
      for (const [svc, state] of Object.entries(d.services)) {
        const badge = document.getElementById('svcBadge-' + svc);
        if (!badge) continue;
        const [cls, label] = SVC_LABELS[state] || ['b-gray', state];
        badge.className = 'badge ' + cls;
        badge.textContent = label;
      }
    } catch { /* service-status ist optional */ }
  }

  async function svcAction(service, action) {
    const btns = document.querySelectorAll(`#svc-${service} .btn-svc`);
    btns.forEach(b => b.disabled = true);
    toast(`⏳ ${action} ${service}…`);
    try {
      const r = await fetch('/api/service-control', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ service, action })
      }).then(r => r.json());
      if (r.ok) {
        toast(`✓ ${service}: ${action} ausgeführt`);
      } else {
        toast(`Fehler: ${r.error}`, 'err');
      }
    } catch (e) {
      toast('Netzwerkfehler: ' + e.message, 'err');
    } finally {
      setTimeout(() => {
        btns.forEach(b => b.disabled = false);
        fetchServiceStatus();
      }, 2500);
    }  }

  // ── Tunnel Status ────────────────────────────────────
  function renderTunnel(d) {
    const el = document.getElementById('tunnelInfo');
    const card = document.getElementById('tunnelCard');
    if (!d.installed) {
      el.innerHTML = row('Status', '<span class="badge" style="background:var(--surface2);color:var(--muted)">nicht installiert</span>') +
                     row('Hinweis', '<span class="muted">cloudflared nicht gefunden – im Raspi-Menü unter "Netzwerk &amp; Cloudflare" einrichten</span>');
      card.style.borderTop = '3px solid var(--border)';
      return;
    }
    const stBadge = d.active
      ? '<span class="badge b-green">AKTIV</span>'
      : '<span class="badge b-red">GESTOPPT</span>';
    card.style.borderTop = d.active ? '3px solid var(--green)' : '3px solid var(--red)';
    let html = row('Service', stBadge) + row('Version', d.version || '–');
    if (d.tunnels && d.tunnels.length) {
      html += row('Tunnel', d.tunnels.map(t =>
        `<span class="commit-hash">${t.id.slice(0,8)}</span> ${t.name.replace(/</g,'&lt;').replace(/>/g,'&gt;')}`
      ).join('<br>'));
    } else if (d.zeroTrust) {
      html += row('Tunnel', '<span class="badge b-green">Zero Trust (Token-Methode)</span>');
      if (d.publicUrl) {
        html += row('Public URL', `<a href="${d.publicUrl.replace(/</g,'&lt;')}" target="_blank" style="color:var(--blue)">${d.publicUrl.replace(/</g,'&lt;')}</a>`);
      }
    } else {
      html += row('Tunnel', '<span class="muted">kein Tunnel konfiguriert</span>');
    }
    el.innerHTML = html;
  }

  // ── Container-/Service-Erkennung ─────────────────────
  function renderContainers(d) {
    const el = document.getElementById('containersInfo');
    const card = document.getElementById('containersCard');
    if (!el) return;
    if (!d || !d.ok) {
      el.innerHTML = row('Fehler', '<span class="muted">Erkennung nicht verfügbar</span>');
      return;
    }

    const safe = v => String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

    const fmtInternal = (svc, fallback = '–') => {
      if (!svc?.found) return '<span class="badge b-gray">NICHT GEFUNDEN</span>';
      const via = svc.via === 'docker' ? '🐳 Docker' : svc.via === 'systemd' ? '⚙️ systemd' : fallback;
      let html = `<span class="muted">${safe(via)}</span>`;
      if (svc.name) html += `<div class="muted" style="font-size:12px;margin-top:4px">Name: <span class="commit-hash">${safe(svc.name)}</span></div>`;
      if (svc.ports) html += `<div class="muted" style="font-size:12px">Ports: ${safe(svc.ports)}</div>`;
      if (svc.status) html += `<div class="muted" style="font-size:12px">Status: ${safe(svc.status)}</div>`;
      return html;
    };

    const fmtExternal = (svc) => {
      if (!svc?.url) return '<span class="muted">nicht konfiguriert</span>';
      const urlSafe = safe(svc.url);
      let html = svc.reachable
        ? `<span class="muted">Erreichbar</span>`
        : `<span class="muted">Nicht erreichbar</span>`;
      html += `<div style="margin-top:4px"><a href="${urlSafe}" target="_blank" rel="noopener noreferrer" style="color:var(--blue);font-size:12px">${urlSafe}</a></div>`;
      if (svc.languageCount) html += `<div class="muted" style="font-size:12px">${safe(svc.languageCount)} Sprachen erkannt</div>`;
      return html;
    };

    const getServiceStatus = (svc, kind = 'service') => {
      if (kind === 'docker') {
        return d.docker.available
          ? '<span class="badge b-green">VERFÜGBAR</span>'
          : '<span class="badge b-gray">NICHT INSTALLIERT</span>';
      }
      if (svc?.reachable) {
        return svc?.found
          ? '<span class="badge b-green">VERFÜGBAR · HTTP OK</span>'
          : '<span class="badge b-green">HTTP OK</span>';
      }
      if (svc?.found) return '<span class="badge b-yellow">NUR INTERN</span>';
      return '<span class="badge b-red">NICHT ERREICHBAR</span>';
    };

    const rows = [
      {
        status: getServiceStatus(null, 'docker'),
        service: 'Docker Engine',
        internal: d.docker.available
          ? `<span class="muted">Installiert</span><div class="muted" style="font-size:12px;margin-top:4px">Version: ${safe(d.docker.version || 'vorhanden')}</div>`
          : '<span class="muted">Nicht installiert</span>',
        external: '<span class="muted">–</span>',
        details: '<span class="muted">Basis für lokale Container-Erkennung</span>'
      },
      {
        status: getServiceStatus(d.uptimeKuma),
        service: 'Uptime Kuma',
        internal: fmtInternal(d.uptimeKuma),
        external: fmtExternal(d.uptimeKuma),
        details: '<span class="muted">Lokal per Docker oder systemd, extern per UPTIME_KUMA_URL</span>'
      },
      {
        status: getServiceStatus(d.libretranslate),
        service: 'LibreTranslate',
        internal: fmtInternal(d.libretranslate),
        external: fmtExternal(d.libretranslate),
        details: '<span class="muted">Lokal per Docker-Erkennung, extern per DISCORD_TRANSLATE_API_URL</span>'
      }
    ].map(item => `
      <tr>
        <td>${item.status}</td>
        <td><span class="dep-name">${item.service}</span></td>
        <td>${item.internal}</td>
        <td>${item.external}</td>
        <td>${item.details}</td>
      </tr>`).join('');

    // Karten-Rahmenfarbe: grün wenn beide erreichbar, gelb wenn einer fehlt
    const allOk = d.uptimeKuma.reachable && d.libretranslate.reachable;
    const anyOk = d.uptimeKuma.reachable || d.libretranslate.reachable;
    if (card) card.style.borderTop = allOk ? '3px solid var(--green)' : anyOk ? '3px solid var(--yellow)' : '';

    el.innerHTML = `
      <div class="muted" style="margin-bottom:10px;font-size:12px">
        Intern = lokale Erkennung auf diesem Host. Extern = Erreichbarkeit über die konfigurierte URL.
      </div>
      <table class="deps-table">
        <thead><tr>
          <th>Status</th><th>Service</th><th>Intern</th><th>Extern</th><th>Hinweis</th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>`;
  }

  // ── Manual Refresh ───────────────────────────────────
  async function manualRefresh() {
    const btn = document.getElementById('btnRefresh');
    btn.disabled = true;
    btn.textContent = '⏳ Wird aktualisiert…';
    try {
      const res = await fetch('/api/refresh', { method: 'POST' });
      const d   = await res.json();
      if (d.ok) toast('✓ Discord Status-Nachricht aktualisiert');
      else      toast('Fehler: ' + d.error, 'err');
      await fetchAll();
      resetCd();
    } catch (e) {
      toast('Netzwerkfehler: ' + e.message, 'err');
    } finally {
      btn.disabled = false;
      btn.textContent = '↺ Discord Refresh';
    }
  }

  // ── Init ─────────────────────────────────────────────
  fetchAll();
  // Interval-Dropdown mit gespeichertem Wert vorbelegen
  const _savedInterval = localStorage.getItem(STORAGE_KEY_REFRESH_INTERVAL) || '30';
  const _intervalSel = document.getElementById('refreshIntervalSelect');
  if (_intervalSel) _intervalSel.value = _savedInterval;
  resetCd();
  checkUpdate();
  checkDeps();
  setActivePane(localStorage.getItem(STORAGE_KEY_ACTIVE_PANE) || 'overview');

  // ── Update Check ─────────────────────────────────────
  let _updateData = null;
  let _depsBannerData = null;

  function refreshUpdateBanner() {
    const banner = document.getElementById('updateBanner');
    const titleEl = document.getElementById('ubTitle');
    const subEl = document.getElementById('ubSub');
    const gitBtn = document.getElementById('btnUpdateRun');
    const npmBtn = document.getElementById('btnBannerNpm');
    if (!banner || !titleEl || !subEl || !gitBtn || !npmBtn) return;

    const hasGitUpdate = Boolean(_updateData?.updateAvailable);
    const behind = Number(_updateData?.behind || 0);
    const local = _updateData?.local || '–';
    const remote = _updateData?.remote || '–';

    const npmOutdated = Number(_depsBannerData?.outdatedCount || 0);
    const npmTotal = Number(_depsBannerData?.total || 0);
    const hasNpmUpdates = npmOutdated > 0;

    const sysRequiredMissing = Number(_depsBannerData?.systemRequiredMissingCount || 0);
    const hasRequiredSysMissing = sysRequiredMissing > 0;

    if (!hasGitUpdate && !hasNpmUpdates && !hasRequiredSysMissing) {
      banner.classList.add('hidden');
      gitBtn.classList.add('hidden');
      npmBtn.classList.add('hidden');
      return;
    }

    banner.classList.remove('hidden');
    gitBtn.classList.toggle('hidden', !hasGitUpdate);
    npmBtn.classList.toggle('hidden', !hasNpmUpdates);

    if (hasGitUpdate && hasNpmUpdates) {
      titleEl.textContent = 'Updates verfügbar';
    } else if (hasGitUpdate) {
      titleEl.textContent = 'Git-Update verfügbar';
    } else if (hasNpmUpdates) {
      titleEl.textContent = 'npm-Updates verfügbar';
    } else {
      titleEl.textContent = 'Pflicht-Abhängigkeiten fehlen';
    }

    const details = [];
    if (hasGitUpdate) details.push(`${behind} Commit${behind > 1 ? 's' : ''} verfügbar · lokal: ${local} · remote: ${remote}`);
    if (hasNpmUpdates) details.push(`${npmOutdated} von ${npmTotal} npm-Paket(en) veraltet`);
    if (hasRequiredSysMissing) details.push(`${sysRequiredMissing} Pflicht-System-Abhängigkeit(en) fehlen`);
    subEl.textContent = details.join(' · ');
  }

  async function checkUpdate(showToast = false) {
    try {
      const d = await fetch('/api/update-check').then(r => r.json());
      const state = document.getElementById('updateState');

      if (!d.ok) {
        _updateData = null;
        refreshUpdateBanner();
        if (state) state.textContent = 'Fehler: ' + (d.error || 'Update-Prüfung fehlgeschlagen');
        if (showToast) toast('Update-Prüfung fehlgeschlagen: ' + (d.error || 'Unbekannt'), 'err');
        return;
      }

      if (!d.hasGit) {
        _updateData = null;
        refreshUpdateBanner();
        if (state) state.textContent = 'Kein Git-Repository erkannt';
        if (showToast) toast('Kein Git-Repository erkannt', 'warn');
        return;
      }

      if (d.fetchFailed) {
        _updateData = null;
        refreshUpdateBanner();
        if (state) state.textContent = 'Git Fetch fehlgeschlagen';
        if (showToast) toast('Git Fetch fehlgeschlagen', 'warn');
        return;
      }

      _updateData = d;
      refreshUpdateBanner();

      if (d.updateAvailable) {
        if (state) state.textContent = `${d.behind} Commit${d.behind > 1 ? 's' : ''} verfügbar`;
        renderCommits(d.commits);
        if (showToast) toast(`Update verfügbar: ${d.behind} Commit${d.behind > 1 ? 's' : ''}`, 'warn');
      } else {
        if (state) state.textContent = 'Aktuell, kein Update verfügbar';
        // Kein Update — trotzdem Versioninfo im Bot-Card ergänzen
        const bi = document.getElementById('botInfo');
        if (bi) bi.innerHTML += row('Git-Commit', d.local + ' ✓ aktuell');
        renderCommits([]);
        if (showToast) toast('Kein Update verfügbar', 'ok');
      }
    } catch (e) {
      _updateData = null;
      refreshUpdateBanner();
      const state = document.getElementById('updateState');
      if (state) state.textContent = 'Verbindungsfehler beim Prüfen';
      if (showToast) toast('Netzwerkfehler: ' + e.message, 'err');
    }
  }

  function renderCommits(commits) {
    const cl = document.getElementById('commitList');
    if (!commits.length) { cl.innerHTML = '<span class="muted">Keine Details verfügbar.</span>'; return; }
    cl.innerHTML = commits.map(c =>
      `<div class="commit">
        <span class="commit-hash">${c.hash}</span>
        <span class="commit-msg">${c.subject.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</span>
        <span class="commit-when">${c.when}</span>
      </div>`
    ).join('');
  }

  function toggleUpdateSection() {
    const card = document.getElementById('updateCard');
    if (card) card.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ── Abhängigkeiten prüfen ────────────────────────────

  // Zwischenspeicher für fehlende+installierbare Deps (für "Alle installieren")
  let _pendingSysInstalls = [];

  async function checkDeps(showToast = false) {
    const btn      = document.getElementById('btnDepsCheck');
    const sysBtn   = document.getElementById('btnSysDepsCheck');
    const state    = document.getElementById('depsState');
    const sysState = document.getElementById('sysDepState');
    const list     = document.getElementById('depsList');
    const sysList  = document.getElementById('sysDepsList');
    const btnInstAll = document.getElementById('btnInstallAllMissing');

    [btn, sysBtn].forEach(b => { if (b) { b.disabled = true; b.textContent = '⏳ Prüfe…'; } });
    if (state)    state.textContent    = 'Prüfe npm-Pakete…';
    if (sysState) sysState.textContent = 'Prüfe System-Abhängigkeiten…';

    try {
      const d = await fetch('/api/deps-check').then(r => r.json());

      if (!d.ok) {
        _depsBannerData = null;
        refreshUpdateBanner();
        if (state)    state.textContent    = 'Fehler: ' + (d.error || 'Unbekannt');
        if (sysState) sysState.textContent = 'Fehler: ' + (d.error || 'Unbekannt');
        if (showToast) toast('Fehler beim Abhängigkeitscheck', 'err');
        return;
      }

      // ── npm Tabelle ─────────────────────────────────────────────────────────
      const rows = d.packages.map(p => {
        const badge = !p.outdated
          ? `<span class="dep-badge dep-ok-badge">✓ aktuell</span>`
          : p.majorBump
            ? `<span class="dep-badge dep-crit-badge">↑ Major ${escapeHtml(p.latest)}</span>`
            : `<span class="dep-badge dep-warn-badge">↑ Minor ${escapeHtml(p.latest)}</span>`;
        return `<tr>
          <td><span class="dep-name">${escapeHtml(p.name)}</span>${p.type === 'devDependency' ? '<span class="dep-dev">dev</span>' : ''}</td>
          <td class="dep-ver">${escapeHtml(p.required)}</td>
          <td class="dep-ver">${escapeHtml(p.current ?? '–')}</td>
          <td class="dep-ver">${escapeHtml(p.wanted  ?? '–')}</td>
          <td class="dep-ver">${escapeHtml(p.latest  ?? '–')}</td>
          <td>${badge}</td>
        </tr>`;
      }).join('');

      list.innerHTML = `
        <table class="deps-table">
          <thead><tr>
            <th>Paket</th><th>Erwartet</th><th>Installiert</th><th>Kompatibel</th><th>Neuest</th><th>Status</th>
          </tr></thead>
          <tbody>${rows || '<tr><td colspan="6" class="muted">Keine npm-Pakete gefunden.</td></tr>'}</tbody>
        </table>`;

      const npmTxt = d.outdatedCount > 0
        ? `${d.outdatedCount} von ${d.total} Paket(en) veraltet`
        : `Alles aktuell (${d.total} Pakete)`;
      if (state) state.textContent = npmTxt;

      // ── System-Tabelle ──────────────────────────────────────────────────────
      _pendingSysInstalls = [];

      const systemRows = (d.systemDeps || []).map(dep => {
        const badge = dep.installed
          ? `<span class="dep-badge dep-ok-badge">✓ installiert</span>`
          : dep.required
            ? `<span class="dep-badge dep-crit-badge">✗ fehlt (Pflicht)</span>`
            : `<span class="dep-badge dep-warn-badge">○ optional</span>`;

        let installCell;
        if (dep.installed) {
          installCell = '<span class="muted">–</span>';
        } else if (dep.installable) {
          _pendingSysInstalls.push(dep.key);
          installCell = `<button class="btn btn-green" style="padding:2px 10px;font-size:12px"
            onclick="installSysDep('${escapeHtml(dep.key)}', this)">⬇ Installieren</button>`;
        } else {
          installCell = `<code style="font-size:11px">${escapeHtml(dep.installCommand || 'manuell')}</code>`;
        }

        return `<tr id="sysdep-row-${escapeHtml(dep.key)}">
          <td><span class="dep-name">${escapeHtml(dep.name)}</span></td>
          <td>${dep.required ? '<span style="color:var(--accent-err)">Pflicht</span>' : '<span class="muted">Optional</span>'}</td>
          <td class="dep-ver">${escapeHtml(dep.version || '–')}</td>
          <td>${escapeHtml(dep.requiredBy || '–')}</td>
          <td>${installCell}</td>
          <td>${badge}</td>
        </tr>`;
      }).join('');

      const aptHint = (d.systemDeps?.length > 0 && !d.aptAvailable)
        ? '<div class="muted" style="margin-top:8px;font-size:12px">Hinweis: apt-get nicht verfügbar — Direkt-Installation nicht möglich.</div>'
        : '';

      sysList.innerHTML = `
        <table class="deps-table">
          <thead><tr>
            <th>Tool</th><th>Typ</th><th>Version</th><th>Verwendet für</th><th>Installieren</th><th>Status</th>
          </tr></thead>
          <tbody>${systemRows || '<tr><td colspan="6" class="muted">Keine System-Abhängigkeiten definiert.</td></tr>'}</tbody>
        </table>${aptHint}`;

      // "Alle installieren" Button nur zeigen wenn mindestens eine Dep installierbar ist
      if (btnInstAll) btnInstAll.style.display = _pendingSysInstalls.length > 0 ? '' : 'none';

      const sysMissing         = d.systemMissingCount || 0;
      const sysRequiredMissing = d.systemRequiredMissingCount || 0;
      const sysTxt = sysMissing > 0
        ? `${sysMissing} fehlend${sysRequiredMissing > 0 ? `, ${sysRequiredMissing} Pflicht` : ''}`
        : 'Alle vorhanden';
      if (sysState) sysState.textContent = sysTxt;

      _depsBannerData = {
        outdatedCount: d.outdatedCount || 0,
        total: d.total || 0,
        systemMissingCount: d.systemMissingCount || 0,
        systemRequiredMissingCount: d.systemRequiredMissingCount || 0,
      };
      refreshUpdateBanner();

      if (showToast) {
        const allOk = d.outdatedCount === 0 && sysRequiredMissing === 0;
        toast(`npm: ${npmTxt} · System: ${sysTxt}`, allOk ? 'ok' : 'err');
      }
    } catch (e) {
      _depsBannerData = null;
      refreshUpdateBanner();
      if (state)    state.textContent    = 'Verbindungsfehler';
      if (sysState) sysState.textContent = 'Verbindungsfehler';
      if (showToast) toast('Fehler: ' + e.message, 'err');
    } finally {
      if (btn)    { btn.disabled    = false; btn.textContent    = '🔎 npm prüfen'; }
      if (sysBtn) { sysBtn.disabled = false; sysBtn.textContent = '🔎 System prüfen'; }
    }
  }

  // ── System-Abhängigkeit direkt installieren ─────────────────────────────────

  async function installSysDep(key, triggerBtn = null) {
    const logEl   = document.getElementById('sysInstallLog');
    const sysState = document.getElementById('sysDepState');
    const btnInstAll = document.getElementById('btnInstallAllMissing');

    if (triggerBtn) { triggerBtn.disabled = true; triggerBtn.textContent = '⏳…'; }
    if (btnInstAll) btnInstAll.disabled = true;
    if (sysState)   sysState.textContent = `Installiere ${key}…`;

    logEl.style.display = 'block';
    logEl.className = 'update-log visible';
    logEl.innerHTML = '';

    const addLine = (text, cls = '') => {
      const el = document.createElement('div');
      el.className = 'ul-line ' + cls;
      el.textContent = text.replace(/\x1b\[[0-9;]*m/g, '');
      logEl.appendChild(el);
      logEl.scrollTop = logEl.scrollHeight;
    };

    try {
      const res = await fetch('/api/sys-dep-install', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: res.statusText }));
        addLine('Fehler: ' + (err.error || res.statusText), 'ul-err');
        if (sysState) sysState.textContent = 'Installation fehlgeschlagen';
        toast('Installation fehlgeschlagen: ' + (err.error || ''), 'err');
        return;
      }

      const reader = res.body.getReader();
      const dec    = new TextDecoder();
      let buf = '';

      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        const parts = buf.split('\n\n');
        buf = parts.pop();
        for (const part of parts) {
          if (!part.startsWith('data:')) continue;
          const line = part.slice(5).trim();
          if (line.startsWith('__EXIT__:')) {
            const code = line.split(':')[1];
            if (code === '0') {
              addLine(`✓ ${key} erfolgreich installiert!`, 'ul-ok');
              toast(`✓ ${key} installiert`, 'ok');
            } else {
              addLine(`✗ Installation fehlgeschlagen (Exit-Code ${code})`, 'ul-err');
              toast(`Installation fehlgeschlagen (Code ${code})`, 'err');
            }
          } else {
            let cls = 'ul-line';
            if (/error|fehler|fail/i.test(line))          cls = 'ul-err';
            else if (/warn|⚠/i.test(line))                cls = 'ul-warn';
            else if (/✓|success|erfolgreich/i.test(line)) cls = 'ul-ok';
            addLine(line, cls);
          }
        }
      }
    } catch (e) {
      addLine('Verbindungsfehler: ' + e.message, 'ul-err');
      toast('Fehler: ' + e.message, 'err');
    } finally {
      if (triggerBtn) { triggerBtn.disabled = false; triggerBtn.textContent = '⬇ Installieren'; }
      if (btnInstAll) btnInstAll.disabled = false;
      // Status nach Installation neu laden
      checkDeps(false);
    }
  }

  async function installAllMissingSysDeps() {
    for (const key of [..._pendingSysInstalls]) {
      await installSysDep(key, null);
    }
  }

  function getUpdateButtonLabel(task, isBanner = false) {
    if (task === 'git') return isBanner ? '▶ Git Pull starten' : '▶ Git Pull';
    if (task === 'npm') return '📦 npm';
    return '🛠 Vollupdate';
  }

  async function runUpdate(modeOverride = null, taskOverride = 'git', sourceBtnId = 'btnUpdateRun') {
    const btn = document.getElementById(sourceBtnId) || document.getElementById('btnUpdateRun');
    const bannerBtn = document.getElementById('btnUpdateRun');
    const paneBtns = [
      document.getElementById('btnUpdateGitPane'),
      document.getElementById('btnUpdateNpmPane'),
      document.getElementById('btnUpdateFullPane'),
    ].filter(Boolean);
    const modeSelect = document.getElementById('updateMode');
    const selectedMode = modeOverride || (modeSelect ? modeSelect.value : 'auto');
    const selectedTask = taskOverride || 'git';

    btn.disabled = true;
    btn.textContent = '⏳ Update läuft…';
    if (bannerBtn && bannerBtn !== btn) bannerBtn.disabled = true;
    paneBtns.forEach(paneBtn => { if (paneBtn !== btn) paneBtn.disabled = true; });

    const log  = document.getElementById('updateLog');
    const state = document.getElementById('updateState');
    if (state) state.textContent = `Update läuft (${selectedMode}, ${selectedTask})…`;
    log.innerHTML = '';
    log.classList.add('visible');
    log.scrollTop = 0;

    const addLine = (text, cls = '') => {
      const el = document.createElement('div');
      el.className = 'ul-line ' + cls;
      // ANSI-Escape-Codes entfernen
      el.textContent = text.replace(/\x1b\[[0-9;]*m/g, '');
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
    };

    // Wird true, sobald der Stream "Service wird neugestartet" meldet.
    // Dann ist ein Verbindungsabbruch erwartet und kein Fehler.
    let willRestart = false;
    let handledByRestart = false;

    try {
      const res  = await fetch('/api/update-run', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode: selectedMode, task: selectedTask })
      });

      const reader = res.body.getReader();
      const dec    = new TextDecoder();
      let buf = '';

      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        const parts = buf.split('\n\n');
        buf = parts.pop();
        for (const part of parts) {
          if (!part.startsWith('data:')) continue;
          const line = part.slice(5).trim();
          if (line.startsWith('__EXIT__:')) {
            const code = line.split(':')[1];
            if (code === '0') {
              addLine('✓ Update erfolgreich abgeschlossen!', 'ul-ok');
              toast('✓ Bot erfolgreich aktualisiert!', 'ok');
              document.getElementById('updateBanner').classList.add('hidden');
              if (state) state.textContent = 'Update erfolgreich abgeschlossen';
            } else {
              addLine(`✗ Update fehlgeschlagen (Exit-Code ${code})`, 'ul-err');
              toast('Update fehlgeschlagen', 'err');
              if (state) state.textContent = `Update fehlgeschlagen (Code ${code})`;
            }
          } else {
            // Neustart erkennen bevor der Service (und damit die Verbindung) stirbt
            const cleanLine = line.replace(/\x1b\[[0-9;]*m/g, '');
            if (/starte.*service.*neu|restarting.*service/i.test(cleanLine)) {
              willRestart = true;
            }
            let cls = 'ul-line';
            if (/error|fehler|fail/i.test(line))   cls = 'ul-err';
            else if (/warn|⚠/i.test(line))         cls = 'ul-warn';
            else if (/✓|success|erfolgreich/i.test(line)) cls = 'ul-ok';
            addLine(line, cls);
          }
        }
      }
    } catch (e) {
      if (willRestart) {
        // Erwarteter Verbindungsabbruch durch Service-Neustart — kein Fehler
        handledByRestart = true;
        addLine('→ Service neugestartet — warte auf Wiederherstellung…', 'ul-warn');
        if (state) state.textContent = 'Service neugestartet — warte…';
        // Im Hintergrund pollen bis der Server wieder antwortet
        _waitForServerReconnect(state);
      } else {
        addLine('Verbindungsfehler: ' + e.message, 'ul-err');
        toast('Fehler: ' + e.message, 'err');
        if (state) state.textContent = 'Verbindungsfehler beim Update';
      }
    } finally {
      btn.disabled = false;
      btn.textContent = getUpdateButtonLabel(selectedTask, sourceBtnId === 'btnUpdateRun');
      if (bannerBtn) {
        bannerBtn.disabled = false;
        bannerBtn.textContent = getUpdateButtonLabel('git', true);
      }
      paneBtns.forEach(paneBtn => {
        paneBtn.disabled = false;
        if (paneBtn.id === 'btnUpdateGitPane') paneBtn.textContent = getUpdateButtonLabel('git');
        if (paneBtn.id === 'btnUpdateNpmPane') paneBtn.textContent = getUpdateButtonLabel('npm');
        if (paneBtn.id === 'btnUpdateFullPane') paneBtn.textContent = getUpdateButtonLabel('full');
      });
      // Update-Check nur ausführen wenn kein Neustart läuft (der Reconnect-Poller macht es dann)
      if (!handledByRestart) checkUpdate(false);
    }
  }

  async function _waitForServerReconnect(stateEl, maxWaitMs = 90000, intervalMs = 2500) {
    const start = Date.now();
    while (Date.now() - start < maxWaitMs) {
      await new Promise(r => setTimeout(r, intervalMs));
      try {
        const r = await fetch('/api/config', { signal: AbortSignal.timeout(3000) });
        if (r.ok) {
          if (stateEl) stateEl.textContent = 'Update & Neustart erfolgreich ✓';
          const logEl = document.getElementById('updateLog');
          if (logEl) {
            const el = document.createElement('div');
            el.className = 'ul-line ul-ok';
            el.textContent = '✓ Service läuft wieder — Verbindung wiederhergestellt!';
            logEl.appendChild(el);
            logEl.scrollTop = logEl.scrollHeight;
          }
          toast('✓ Update & Neustart erfolgreich!', 'ok');
          document.getElementById('updateBanner')?.classList.add('hidden');
          checkUpdate(false);
          return;
        }
      } catch { /* Server antwortet noch nicht */ }
    }
    // Timeout nach maxWaitMs
    if (stateEl) stateEl.textContent = 'Service antwortet nicht — bitte manuell prüfen';
    toast('Service antwortet nach 90s nicht', 'err');
  }

  function _shouldPreserveConfigField(el, force = false) {
    if (!el || force) return false;
    if (el === document.activeElement) return true;
    return el.dataset.dirty === '1';
  }

  function _setDirtyState(el, isDirty) {
    if (!el) return;
    el.dataset.dirty = isDirty ? '1' : '0';
    el.classList.toggle('cfg-dirty', !!isDirty);
    const field = el.closest('.cfg-field');
    if (field) field.classList.toggle('cfg-field-dirty', !!isDirty);
  }

  function refreshConfigDirtyIndicator() {
    const dirtyEl = document.getElementById('cfgDirtyState');
    if (!dirtyEl) return;
    const fields = document.querySelectorAll('#cfgCard .cfg-input, #cfgCard input[type="checkbox"], #cfgCard select, #cfgCard textarea');
    const count = Array.from(fields).filter((el) => el.dataset.dirty === '1').length;
    if (count > 0) {
      dirtyEl.textContent = `● ${count} ungespeicherte Änderung${count === 1 ? '' : 'en'}`;
      dirtyEl.classList.add('show');
    } else {
      dirtyEl.classList.remove('show');
      dirtyEl.textContent = '● Ungespeicherte Änderungen';
    }
  }

  function setFieldValue(id, value, { force = false } = {}) {
    const el = document.getElementById(id);
    if (!el) return;
    if (_shouldPreserveConfigField(el, force)) return;
    const normalized = value ?? '';
    el.value = normalized;
    el.dataset.initialValue = normalized;
    _setDirtyState(el, false);
    refreshConfigDirtyIndicator();
  }

  function setCheckboxValue(id, checked, { force = false } = {}) {
    const el = document.getElementById(id);
    if (!el) return;
    if (_shouldPreserveConfigField(el, force)) return;
    const normalized = !!checked;
    el.checked = normalized;
    el.dataset.initialValue = normalized ? 'true' : 'false';
    _setDirtyState(el, false);
    refreshConfigDirtyIndicator();
  }

  function initConfigDirtyTracking() {
    const fields = document.querySelectorAll('#cfgCard .cfg-input, #cfgCard input[type="checkbox"], #cfgCard select, #cfgCard textarea');
    fields.forEach((el) => {
      if (el.dataset.dirtyBound === '1') return;
      el.dataset.dirtyBound = '1';
      const markDirty = () => {
        _setDirtyState(el, true);
        refreshConfigDirtyIndicator();
      };
      el.addEventListener('input', markDirty);
      el.addEventListener('change', markDirty);
    });
    refreshConfigDirtyIndicator();
  }

  function clearConfigDirtyTracking() {
    const fields = document.querySelectorAll('#cfgCard .cfg-input, #cfgCard input[type="checkbox"], #cfgCard select, #cfgCard textarea');
    fields.forEach((el) => { _setDirtyState(el, false); });
    refreshConfigDirtyIndicator();
  }

  function _computeChannelNamePreview(serviceName, status, mode) {
    const dot = status === 1 ? '🟢' : status === 0 ? '🔴' : '🟡';
    const raw = String(serviceName || '').trim() || 'Service Name';

    const toMono = (value) => {
      return Array.from(value).map((ch) => {
        const code = ch.codePointAt(0);
        if (code >= 65 && code <= 90) return String.fromCodePoint(0x1D670 + (code - 65));
        if (code >= 97 && code <= 122) return String.fromCodePoint(0x1D68A + (code - 97));
        if (code >= 48 && code <= 57) return String.fromCodePoint(0x1D7F6 + (code - 48));
        return ch;
      }).join('');
    };

    if (mode === 'mono') {
      const mono = raw
        .replace(/[\u0000-\u001F\u007F]/g, '')
        .replace(/[\n\r\t]+/g, ' ')
        .replace(/\s+/g, '-')
        .replace(/#+/g, '-')
        .replace(/:+/g, '-')
        .replace(/@+/g, '-')
        .replace(/\/+|\\+/g, '-')
        .replace(/^-+|-+$/g, '')
        .slice(0, 90);
      return `${dot}-${toMono(mono || 'service')}`;
    }

    if (mode === 'pretty') {
      const pretty = raw
        .replace(/[\u0000-\u001F\u007F]/g, '')
        .replace(/[\n\r\t]+/g, ' ')
        .replace(/\s+/g, '-')
        .replace(/#+/g, '-')
        .replace(/:+/g, '-')
        .replace(/@+/g, '-')
        .replace(/\/+|\\+/g, '-')
        .replace(/^-+|-+$/g, '')
        .slice(0, 90);
      return `${dot}-${pretty || 'service'}`;
    }

    const slug = raw
      .toLowerCase()
      .replace(/[äöüß]/g, c => ({ ä: 'ae', ö: 'oe', ü: 'ue', ß: 'ss' })[c] ?? c)
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 94);
    return `${dot}-${slug || 'service'}`;
  }

  function _toStyledAsciiChar(ch, style) {
    const code = ch.codePointAt(0);

    // A-Z
    if (code >= 65 && code <= 90) {
      const offset = code - 65;
      if (style === 'mono') return String.fromCodePoint(0x1D670 + offset);
      if (style === 'sansbold') return String.fromCodePoint(0x1D5D4 + offset);
      if (style === 'serifbold') return String.fromCodePoint(0x1D400 + offset);
      if (style === 'serifitalic') return String.fromCodePoint(0x1D434 + offset);
      if (style === 'serifbolditalic') return String.fromCodePoint(0x1D468 + offset);
      if (style === 'sans') return String.fromCodePoint(0x1D5A0 + offset);
      if (style === 'sansitalic') return String.fromCodePoint(0x1D608 + offset);
    }

    // a-z
    if (code >= 97 && code <= 122) {
      const offset = code - 97;
      if (style === 'mono') return String.fromCodePoint(0x1D68A + offset);
      if (style === 'sansbold') return String.fromCodePoint(0x1D5EE + offset);
      if (style === 'serifbold') return String.fromCodePoint(0x1D41A + offset);
      if (style === 'serifitalic') return String.fromCodePoint(0x1D44E + offset);
      if (style === 'serifbolditalic') return String.fromCodePoint(0x1D482 + offset);
      if (style === 'sans') return String.fromCodePoint(0x1D5BA + offset);
      if (style === 'sansitalic') return String.fromCodePoint(0x1D622 + offset);
    }

    // 0-9
    if (code >= 48 && code <= 57) {
      const offset = code - 48;
      if (style === 'mono') return String.fromCodePoint(0x1D7F6 + offset);
      if (style === 'sansbold') return String.fromCodePoint(0x1D7EC + offset);
      if (style === 'serifbold') return String.fromCodePoint(0x1D7CE + offset);
      if (style === 'sans') return String.fromCodePoint(0x1D7E2 + offset);
    }

    return ch;
  }

  function convertUnicodeStyledText() {
    const inputEl = document.getElementById('cfgUnicodeInput');
    const styleEl = document.getElementById('cfgUnicodeStyle');
    const outputEl = document.getElementById('cfgUnicodeOutput');
    if (!inputEl || !styleEl || !outputEl) return;

    const input = String(inputEl.value || '');
    const style = styleEl.value || 'mono';
    const transformed = Array.from(input).map(ch => _toStyledAsciiChar(ch, style)).join('');
    outputEl.value = transformed;
  }

  function _insertUnicodeValue(selected, emptyMsg) {
    const inputEl = document.getElementById('cfgUnicodeInput');
    if (!inputEl) return false;

    const value = String(selected || '');
    if (!value) {
      toast(emptyMsg, 'warn');
      return false;
    }

    const start = inputEl.selectionStart ?? inputEl.value.length;
    const end = inputEl.selectionEnd ?? inputEl.value.length;
    const before = inputEl.value.slice(0, start);
    const after = inputEl.value.slice(end);
    inputEl.value = before + value + after;
    const cursorPos = start + value.length;
    inputEl.setSelectionRange(cursorPos, cursorPos);
    inputEl.focus();
    convertUnicodeStyledText();
    return true;
  }

  function appendUnicodeSpecialChar() {
    const specialEl = document.getElementById('cfgUnicodeSpecial');
    if (!specialEl) return;
    const inserted = _insertUnicodeValue(specialEl.value, 'Bitte ein Sonderzeichen auswählen');
    if (!inserted) return;
    specialEl.value = '';
  }

  function appendUnicodeSmiley() {
    const emojiEl = document.getElementById('cfgUnicodeEmoji');
    if (!emojiEl) return;
    const inserted = _insertUnicodeValue(emojiEl.value, 'Bitte einen Smiley auswählen');
    if (!inserted) return;
    emojiEl.value = '';
  }

  function clearUnicodeConverter() {
    const inputEl = document.getElementById('cfgUnicodeInput');
    const outputEl = document.getElementById('cfgUnicodeOutput');
    const specialEl = document.getElementById('cfgUnicodeSpecial');
    const emojiEl = document.getElementById('cfgUnicodeEmoji');
    if (inputEl) inputEl.value = '';
    if (outputEl) outputEl.value = '';
    if (specialEl) specialEl.value = '';
    if (emojiEl) emojiEl.value = '';
    if (inputEl) inputEl.focus();
    convertUnicodeStyledText();
  }

  async function copyUnicodeStyledText() {
    const outputEl = document.getElementById('cfgUnicodeOutput');
    if (!outputEl) return;

    if (!outputEl.value.trim()) {
      toast('Kein Text zum Kopieren', 'warn');
      return;
    }

    try {
      if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
        await navigator.clipboard.writeText(outputEl.value);
      } else {
        const tmp = document.createElement('textarea');
        tmp.value = outputEl.value;
        tmp.setAttribute('readonly', '');
        tmp.style.position = 'fixed';
        tmp.style.opacity = '0';
        tmp.style.pointerEvents = 'none';
        document.body.appendChild(tmp);
        tmp.focus();
        tmp.select();

        const ok = document.execCommand('copy');
        document.body.removeChild(tmp);
        if (!ok) throw new Error('Clipboard API nicht verfügbar');
      }
      toast('Unicode-Text kopiert', 'ok');
    } catch (e) {
      toast('Kopieren fehlgeschlagen: ' + e.message, 'err');
    }
  }

  function updateChannelNamePreview() {
    const previewEl = document.getElementById('cfgChannelNamePreview');
    const monitoredEl = document.getElementById('cfgMonitoredServices');
    const modeEl = document.getElementById('cfgServiceChannelNameMode');
    if (!previewEl || !monitoredEl || !modeEl) return;

    const firstService = String(monitoredEl.value || '')
      .split(',')
      .map(s => s.trim())
      .find(Boolean) || 'Next-Cloud 🚀';

    const mode = modeEl.value || 'strict_slug';
    const upName = _computeChannelNamePreview(firstService, 1, mode);
    const downName = _computeChannelNamePreview(firstService, 0, mode);

    previewEl.innerHTML = `Vorschau: <code>${upName}</code> (up) · <code>${downName}</code> (down)`;
  }

  function maybeSetChanged(body, key, id, { allowEmpty = false } = {}) {
    const el = document.getElementById(id);
    if (!el) return;
    const value = el.value.trim();
    const initial = (el.dataset.initialValue || '').trim();
    if (value === initial) return;
    if (!allowEmpty && !value) return;
    body[key] = value;
  }

  function appendAutoReactionEmoji() {
    const presetEl = document.getElementById('cfgAutoReactionPreset');
    const inputEl = document.getElementById('cfgAutoReactionEmojis');
    const value = String(presetEl?.value || '').trim();
    if (!value || !inputEl) return;

    const existing = String(inputEl.value || '')
      .split(/[;,]/)
      .map(s => s.trim())
      .filter(Boolean);
    if (!existing.includes(value)) existing.push(value);
    inputEl.value = existing.slice(0, 5).join(';');
    presetEl.value = '';
  }

  function appendPresencePreset() {
    const presetEl = document.getElementById('cfgPresencePreset');
    const inputEl = document.getElementById('cfgPresenceText');
    const value = String(presetEl?.value || '').trim();
    if (!value || !inputEl) return;

    const existing = String(inputEl.value || '')
      .split(';')
      .map(s => s.trim())
      .filter(Boolean);

    if (!existing.includes(value)) existing.push(value);
    inputEl.value = existing.slice(0, 15).join(';');
    presetEl.value = '';
  }

  function _parseEnabledCommands(value) {
    const allowed = ['status', 'uptime', 'refresh', 'help', 'coinflip', 'dice', 'eightball', 'cleanup', 'translate'];
    const entries = String(value || '')
      .split(',')
      .map(s => s.trim().toLowerCase())
      .filter(Boolean);
    const unique = Array.from(new Set(entries)).filter(cmd => allowed.includes(cmd));
    return unique.length ? unique : ['status', 'uptime', 'refresh', 'help', 'coinflip', 'dice', 'eightball', 'translate'];
  }

  // ── Discord-Kanal-Browser für Mapping-Übernahme ──────────────────────────
  let _existingCategoryData = [];
  let _existingUncategorized = [];

  function _renderExistingChannelSelect() {
    const categoryEl = document.getElementById('cfgExistingCategorySelect');
    const channelEl = document.getElementById('cfgExistingChannelSelect');
    if (!categoryEl || !channelEl) return;

    const selectedCategoryId = categoryEl.value || '__uncategorized__';
    let channels = [];

    if (selectedCategoryId === '__uncategorized__') {
      channels = _existingUncategorized;
    } else {
      channels = (_existingCategoryData.find(c => c.id === selectedCategoryId)?.channels) || [];
    }

    channelEl.innerHTML = '<option value="">Kanal auswählen…</option>';
    channels.forEach((ch) => {
      const opt = document.createElement('option');
      opt.value = ch.id;
      opt.textContent = `# ${ch.name}`;
      channelEl.appendChild(opt);
    });
  }

  async function loadExistingGuildChannels() {
    const btn = document.getElementById('btnLoadExistingChannels');
    const state = document.getElementById('cfgExistingChannelState');
    const categoryEl = document.getElementById('cfgExistingCategorySelect');

    const serviceGuild = (document.getElementById('cfgServiceGuildId')?.value || '').trim();
    const defaultGuild = (document.getElementById('cfgGuildId')?.value || '').trim();
    const guildId = serviceGuild || defaultGuild;

    if (!guildId) {
      if (state) state.textContent = 'Bitte zuerst SERVICE_GUILD_ID oder GUILD_ID setzen.';
      toast('Guild-ID fehlt', 'warn');
      return;
    }

    if (btn) { btn.disabled = true; btn.textContent = '⏳ Lade…'; }
    if (state) state.textContent = 'Lade Kategorien und Kanäle aus Discord…';

    try {
      const d = await fetch(`/api/discord-channel-browser?guildId=${encodeURIComponent(guildId)}`).then(r => r.json());
      if (!d.ok) {
        if (state) state.textContent = 'Fehler: ' + (d.error || 'Unbekannt');
        toast('Discord-Kanäle laden fehlgeschlagen', 'err');
        return;
      }

      _existingCategoryData = d.categories || [];
      _existingUncategorized = d.uncategorized || [];

      categoryEl.innerHTML = '<option value="">Kategorie auswählen…</option>';
      _existingCategoryData.forEach((cat) => {
        const opt = document.createElement('option');
        opt.value = cat.id;
        opt.textContent = `${cat.name} (${cat.channels?.length || 0})`;
        categoryEl.appendChild(opt);
      });
      if (_existingUncategorized.length) {
        const opt = document.createElement('option');
        opt.value = '__uncategorized__';
        opt.textContent = `Ohne Kategorie (${_existingUncategorized.length})`;
        categoryEl.appendChild(opt);
      }

      categoryEl.onchange = _renderExistingChannelSelect;
      _renderExistingChannelSelect();

      if (state) state.textContent = `Geladen: ${d.guild?.name || guildId} · ${_existingCategoryData.length} Kategorien`;
      toast('Kategorien/Kanäle geladen', 'ok');
    } catch (e) {
      if (state) state.textContent = 'Verbindungsfehler: ' + e.message;
      toast('Verbindungsfehler beim Laden', 'err');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = '🔎 Aus Discord laden'; }
    }
  }

  function addSelectedChannelToMap() {
    const monitorEl = document.getElementById('cfgExistingMonitorName');
    const channelEl = document.getElementById('cfgExistingChannelSelect');
    const mapEl = document.getElementById('cfgServiceChannelMap');
    const state = document.getElementById('cfgExistingChannelState');

    const monitorName = String(monitorEl?.value || '').trim();
    const channelId = String(channelEl?.value || '').trim();
    if (!monitorName) {
      toast('Monitorname fehlt', 'warn');
      return;
    }
    if (!channelId) {
      toast('Kanal fehlt', 'warn');
      return;
    }

    const current = String(mapEl?.value || '').trim();
    const entries = current ? current.split(';').map(s => s.trim()).filter(Boolean) : [];
    const normalizedMonitor = monitorName.toLowerCase();

    const filtered = entries.filter((entry) => {
      const idx = entry.lastIndexOf('=');
      if (idx <= 0) return true;
      const left = entry.slice(0, idx).trim().toLowerCase();
      return left !== normalizedMonitor;
    });

    filtered.push(`${monitorName}=${channelId}`);
    mapEl.value = filtered.join(';');

    if (state) state.textContent = `Mapping aktualisiert: ${monitorName} → ${channelId}`;
    toast('Kanal ins Mapping übernommen', 'ok');
  }

  function applyEnabledCommandsToCheckboxes(value) {
    const enabled = new Set(_parseEnabledCommands(value));
    const boxes = document.querySelectorAll('[data-cmd]');
    boxes.forEach((box) => {
      box.checked = enabled.has(box.dataset.cmd);
    });
  }

  function syncEnabledCommandsFromCheckboxes(changedBox = null) {
    const boxes = Array.from(document.querySelectorAll('[data-cmd]'));
    if (!boxes.length) return;

    let selected = boxes.filter(b => b.checked);
    if (!selected.length) {
      if (changedBox) changedBox.checked = true;
      selected = boxes.filter(b => b.checked);
      toast('Mindestens ein Bot-Kommando muss aktiv bleiben', 'warn');
    }

    const value = selected.map(b => b.dataset.cmd).join(',');
    const hidden = document.getElementById('cfgEnabledCommands');
    if (hidden) hidden.value = value;
  }

