    const initialTranslateEnabled = translateEnabledEl.dataset.initialValue || 'false';
    if (currentTranslateEnabled !== initialTranslateEnabled) {
      body.DISCORD_TRANSLATE_ENABLED = currentTranslateEnabled;
    }

    const msgCleanupEnabledEl = document.getElementById('cfgMsgCleanupEnabled');
    const currentMsgCleanupEnabled = msgCleanupEnabledEl.checked ? 'true' : 'false';
    const initialMsgCleanupEnabled = msgCleanupEnabledEl.dataset.initialValue || 'false';
    if (currentMsgCleanupEnabled !== initialMsgCleanupEnabled) {
      body.MESSAGE_CLEANUP_ENABLED = currentMsgCleanupEnabled;
    }

    const msgCleanupOnlyBotEl = document.getElementById('cfgMsgCleanupOnlyBot');
    const currentMsgCleanupOnlyBot = msgCleanupOnlyBotEl.checked ? 'true' : 'false';
    const initialMsgCleanupOnlyBot = msgCleanupOnlyBotEl.dataset.initialValue || 'true';
    if (currentMsgCleanupOnlyBot !== initialMsgCleanupOnlyBot) {
      body.MESSAGE_CLEANUP_ONLY_BOT_MESSAGES = currentMsgCleanupOnlyBot;
    }

    const autoCreateEl = document.getElementById('cfgServiceAutoCreate');
    const currentAutoCreate = autoCreateEl.checked ? 'true' : 'false';
    const initialAutoCreate = autoCreateEl.dataset.initialValue || 'true';
    if (currentAutoCreate !== initialAutoCreate) {
      body.SERVICE_CHANNEL_AUTO_CREATE = currentAutoCreate;
    }

    const autoQuietEl = document.getElementById('cfgServiceAutoQuiet');
    const currentAutoQuiet = autoQuietEl.checked ? 'true' : 'false';
    const initialAutoQuiet = autoQuietEl.dataset.initialValue || 'true';
    if (currentAutoQuiet !== initialAutoQuiet) {
      body.SERVICE_CHANNEL_AUTO_QUIET = currentAutoQuiet;
    }

    const serviceDebugEl = document.getElementById('cfgServiceChannelDebug');
    const currentServiceDebug = serviceDebugEl.checked ? 'true' : 'false';
    const initialServiceDebug = serviceDebugEl.dataset.initialValue || 'false';
    if (currentServiceDebug !== initialServiceDebug) {
      body.SERVICE_CHANNEL_DEBUG = currentServiceDebug;
    }

    if (Object.keys(body).length === 0) {
      st.textContent = 'Keine √Дnderungen erkannt';
      st.className = 'warn';
      btn.disabled = false;
      btn.textContent = 'рЯТЊ Speichern & Neu starten';
      return;
    }

    try {
      const res = await fetch('/api/config', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(body),
      }).then(r => r.json());

      if (res.ok) {
        st.textContent = `вЬУ Gespeichert: ${res.updated.join(', ')}${res.restarted ? ' ¬Ј Bot startet neuвА¶' : ''}`;
        st.className = 'ok';
        toast('вЬУ Konfiguration gespeichert', 'ok');
        
        // Bot-Polling nach Restart vornehmen
        if (res.restarted) {
          st.textContent += ' вП≥ Warte auf Bot-NeustartвА¶';
          btn.textContent = 'вП≥ Bot startet neuвА¶';
          btn.disabled = true;
          
          // Polling: Versuche alle 500ms die config zu laden bis Bot antwortet
          let retries = 0;
          const maxRetries = 30; // max 15 Sekunden
          let pollBotReady = null;
          
          pollBotReady = setInterval(async () => {
            retries++;
            try {
              const testRes = await fetch('/api/config', { timeout: 2000 });
              if (testRes.ok) {
                clearInterval(pollBotReady);
                pollBotReady = null;
                await new Promise(r => setTimeout(r, 500)); // Kurze Pause f√Љr Bot-Stabilisierung
                clearConfigDirtyTracking();
                loadConfig({ force: true });
                fetchAll();
                await fetch('/api/refresh', { method: 'POST' }); // Sofortiger Discord-Update
                st.textContent = `вЬУ Bot neu gestartet. Status aktualisiert.`;
                st.className = 'ok';
                btn.textContent = 'рЯТЊ Speichern & Neu starten';
                btn.disabled = false;
              }
            } catch (e) {
              if (retries >= maxRetries) {
                clearInterval(pollBotReady);
                pollBotReady = null;
                st.textContent = `вЪ† Bot braucht l√§nger als erwartet. Seite in 5s neu ladenвА¶`;
                st.className = 'warn';
                btn.disabled = false;
                btn.textContent = 'рЯТЊ Speichern & Neu starten';
                setTimeout(() => location.reload(), 5000);
              }
            }
          }, 500);
        } else {
          clearConfigDirtyTracking();
          loadConfig({ force: true });
        }
      } else {
        st.textContent = 'вЬЧ ' + (res.error || 'Unbekannter Fehler');
        st.className = 'err';
        toast('Fehler: ' + res.error, 'err');
        btn.disabled = false;
        btn.textContent = 'рЯТЊ Speichern & Neu starten';
      }
    } catch (e) {
      st.textContent = 'Verbindungsfehler: ' + e.message;
      st.className = 'err';
      toast('Verbindungsfehler', 'err');
      btn.disabled = false;
      btn.textContent = 'рЯТЊ Speichern & Neu starten';
    }
  }

  // вФАвФА Test-Rendering: Sofortiger Discord-Update вФАвФАвФАвФАвФАвФАвФАвФА
  async function testRendering() {
    const btn = document.getElementById('btnTestRender');
    const st = document.getElementById('cfgStatus');
    btn.disabled = true;
    btn.textContent = 'вП≥вА¶';
    
    try {
      const res = await fetch('/api/refresh', { method: 'POST' }).then(r => r.json());
      if (res.ok) {
        st.textContent = 'вЬУ Rendering-Update zu Discord gesendet.';
        st.className = 'ok';
        toast('вЬУ Discord Status aktualisiert', 'ok');
      } else {
        st.textContent = 'вЬЧ Rendering-Update fehlgeschlagen: ' + (res.error || 'unknown');
        st.className = 'err';
      }
    } catch (e) {
      st.textContent = 'вЬЧ Fehler: ' + e.message;
      st.className = 'err';
    } finally {
      btn.disabled = false;
      btn.textContent = 'рЯІ™ Jetzt testen';
    }
  }

  // Config beim Start laden
  initConfigDirtyTracking();
  loadConfig();
  loadSystemLocalization();
  setActiveSettingsPane('bot');

  // Live-Vorschau f√Љr den Dienst-Kanalnamen
  document.getElementById('cfgMonitoredServices')?.addEventListener('input', updateChannelNamePreview);
  document.getElementById('cfgServiceChannelNameMode')?.addEventListener('change', updateChannelNamePreview);
  document.querySelectorAll('[data-cmd]').forEach((box) => {
    box.addEventListener('change', () => syncEnabledCommandsFromCheckboxes(box));
  });

  // вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
  // DRAGGABLE + COLLAPSIBLE CARDS SYSTEM
  // вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА

  const STORAGE_KEY_COLLAPSE = 'dashboard-collapsed';
  const STORAGE_KEY_ORDER    = 'dashboard-card-order';
  const STORAGE_KEY_SPAN     = 'dashboard-card-span';

  let dropPlaceholder = null;
  let dragSrc = null;
  let lastDragOverCard = null;
  let lastPlacerBefore = null;
  let dragOverThrottleId = null;

  function normalizeCardSpan(span) {
    const raw = String(span || '').trim();
    const allowed = new Set(['3', '4', '6', '8', '9', '12', '15', '16', '18', '20', '21', '24']);
    return allowed.has(raw) ? raw : '24';
  }

  function normalizeLegacyCardSpan(span) {
    const raw = String(span || '').trim();
    const migrated = {
      '3': '6',
      '4': '8',
      '6': '12',
      '8': '16',
      '9': '18',
      '12': '24'
    };
    return normalizeCardSpan(migrated[raw] || raw);
  }

  function getAvailableCardSpans(card) {
    const isSettingsCard = card.id === 'cfgCard';
    const allSpans = [
      { label: '1/8', span: '3' },
      { label: '1/6', span: '4' },
      { label: '1/4', span: '6' },
      { label: '1/3', span: '8' },
      { label: '3/8', span: '9' },
      { label: '1/2', span: '12' },
      { label: '5/8', span: '15' },
      { label: '2/3', span: '16' },
      { label: '3/4', span: '18' },
      { label: '5/6', span: '20' },
      { label: '7/8', span: '21' },
      { label: '1/1', span: '24' },
    ];
    return isSettingsCard ? allSpans.filter(({ span }) => Number(span) >= 12) : allSpans;
  }

  function getStableCardId(card, idx) {
    if (card.id) return `card:${card.id}`;
    const title = card.querySelector('.card-title')?.textContent?.trim().toLowerCase() || 'unknown';
    const slug = title.replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'unknown';
    return `card:${slug}:${idx}`;
  }

  function initCardSystem() {
    const grid = document.getElementById('dashboardGrid');
    if (!grid) return;

    if (!grid.dataset.dragBound) {
      grid.dataset.dragBound = '1';
      grid.addEventListener('dragover', (e) => {
        e.preventDefault();
        if (!dragSrc || !dropPlaceholder) return;
        if (e.target === grid) {
          dropPlaceholder.dataset.span = dragSrc.dataset.span || '24';
          grid.appendChild(dropPlaceholder);
        }
      });
      grid.addEventListener('drop', (e) => {
        e.preventDefault();
        if (!dragSrc || !dropPlaceholder) return;
        if (dropPlaceholder.parentNode === grid) {
          grid.insertBefore(dragSrc, dropPlaceholder);
          saveCardOrder();
        }
      });
    }

    Array.from(grid.querySelectorAll(':scope > .card')).forEach((card, idx) => {
      if (!card.dataset.cardId) {
        card.dataset.cardId = getStableCardId(card, idx);
      }
      if (!card.dataset.initialized) {
        card.dataset.initialized = '1';
        setupDrag(card);
        addCardControls(card);
      }
    });

    restoreCollapseStates();
    restoreSpanStates();
    restoreCardOrder();
  }

  function setupDrag(card) {
    card.draggable = true;

    card.addEventListener('dragstart', (e) => {
      dragSrc = card;
      lastDragOverCard = null;
      lastPlacerBefore = null;
      ensureDropPlaceholder(card);
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', card.dataset.cardId);
      document.getElementById('dashboardGrid')?.classList.add('dragging');
      setTimeout(() => card.classList.add('dragging'), 0);
    });

    card.addEventListener('dragend', () => {
      card.classList.remove('dragging');
      document.getElementById('dashboardGrid')?.classList.remove('dragging');
      document.querySelectorAll('.card.drag-over').forEach(c => c.classList.remove('drag-over'));
      if (dragOverThrottleId) clearTimeout(dragOverThrottleId);
      removeDropPlaceholder();
      dragSrc = null;
      lastDragOverCard = null;
      lastPlacerBefore = null;
    });

    card.addEventListener('dragover', (e) => {
      e.preventDefault();
      if (!dragSrc || dragSrc === card) return;
      card.classList.add('drag-over');

      // Throttle die Positionsberechnung: max einmal pro 50ms
      if (dragOverThrottleId) clearTimeout(dragOverThrottleId);
      dragOverThrottleId = setTimeout(() => {
        if (!dragSrc || !dropPlaceholder) return;

        const rect = card.getBoundingClientRect();
        const placeBefore = e.clientY < rect.top + rect.height / 2;
        const grid = document.getElementById('dashboardGrid');
        if (!grid || !dropPlaceholder) return;

        // Nur DOM-√Дnderung wenn sich Position wirklich ge√§ndert hat
        if (lastDragOverCard !== card || lastPlacerBefore !== placeBefore) {
          dropPlaceholder.dataset.span = dragSrc.dataset.span || '24';
          if (placeBefore) {
            if (card !== dropPlaceholder.nextElementSibling) {
              grid.insertBefore(dropPlaceholder, card);
            }
          } else {
            if (card.nextSibling !== dropPlaceholder) {
              grid.insertBefore(dropPlaceholder, card.nextSibling);
            }
          }
          lastDragOverCard = card;
          lastPlacerBefore = placeBefore;
        }
        dragOverThrottleId = null;
      }, 50);
    });

    card.addEventListener('dragleave', (e) => {
      if (!card.contains(e.relatedTarget)) card.classList.remove('drag-over');
    });

    card.addEventListener('drop', (e) => {
      e.preventDefault();
      card.classList.remove('drag-over');
      if (!dragSrc || dragSrc === card) return;
      const grid = document.getElementById('dashboardGrid');
      if (grid && dropPlaceholder && dropPlaceholder.parentNode === grid) {
        grid.insertBefore(dragSrc, dropPlaceholder);
      }
      saveCardOrder();
    });
  }

  function ensureDropPlaceholder(card) {
    if (!dropPlaceholder) {
      dropPlaceholder = document.createElement('div');
      dropPlaceholder.className = 'drop-placeholder';
      dropPlaceholder.setAttribute('aria-hidden', 'true');
    }
    dropPlaceholder.dataset.span = card.dataset.span || '24';
    const grid = document.getElementById('dashboardGrid');
    if (grid && dropPlaceholder.parentNode !== grid) {
      grid.appendChild(dropPlaceholder);
    }
  }

  function removeDropPlaceholder() {
    if (dropPlaceholder && dropPlaceholder.parentNode) {
      dropPlaceholder.parentNode.removeChild(dropPlaceholder);
    }
  }

  function addCardControls(card) {
    const title = card.querySelector('.card-title');
    const titleClone = title ? title.cloneNode(true) : null;
    title?.remove();

    const header = document.createElement('div');
    header.className = 'card-header';

    const left = document.createElement('div');
    left.className = 'card-header-left';
    if (titleClone) left.appendChild(titleClone);
    header.appendChild(left);

    const availableSpans = getAvailableCardSpans(card);
    const currentSpan = normalizeLegacyCardSpan(card.dataset.span || '24');
    const fallbackSpan = availableSpans.some(({ span }) => span === currentSpan)
      ? currentSpan
      : availableSpans[0].span;
    card.dataset.span = fallbackSpan;

    const sizeSelect = document.createElement('select');
    sizeSelect.className = 'card-size-select';
    sizeSelect.title = 'Kachelbreite';
    availableSpans.forEach(({ label, span }) => {
      const option = document.createElement('option');
      option.value = span;
      option.textContent = label;
      sizeSelect.appendChild(option);
    });
    sizeSelect.value = fallbackSpan;
    sizeSelect.addEventListener('click', (e) => e.stopPropagation());
    sizeSelect.addEventListener('change', (e) => {
      e.stopPropagation();
      const span = sizeSelect.value;
      card.dataset.span = span;
      const s = JSON.parse(localStorage.getItem(STORAGE_KEY_SPAN) || '{}');
      s[card.dataset.cardId] = span;
      localStorage.setItem(STORAGE_KEY_SPAN, JSON.stringify(s));
    });

    const collapseBtn = document.createElement('button');
    collapseBtn.className = 'btn-collapse';
    collapseBtn.innerHTML = 'вИТ';
    collapseBtn.title = 'Ein-/Ausklappen';
    collapseBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const content = card.querySelector('.card-content');
      if (!content) return;
      const collapsed = content.classList.toggle('collapsed');
      collapseBtn.innerHTML = collapsed ? '+' : 'вИТ';
      const s = JSON.parse(localStorage.getItem(STORAGE_KEY_COLLAPSE) || '{}');
      s[card.dataset.cardId] = collapsed;
      localStorage.setItem(STORAGE_KEY_COLLAPSE, JSON.stringify(s));
    });

    const controls = document.createElement('div');
    controls.className = 'card-controls';
    controls.appendChild(sizeSelect);
    controls.appendChild(collapseBtn);
    header.appendChild(controls);
    card.insertBefore(header, card.firstChild);

    const content = document.createElement('div');
    content.className = 'card-content';
    while (card.children.length > 1) content.appendChild(card.children[1]);
    card.appendChild(content);
  }

  function restoreCollapseStates() {
    const s = JSON.parse(localStorage.getItem(STORAGE_KEY_COLLAPSE) || '{}');
    document.querySelectorAll('#dashboardGrid > .card').forEach(card => {
      if (s[card.dataset.cardId]) {
        card.querySelector('.card-content')?.classList.add('collapsed');
        const btn = card.querySelector('.btn-collapse');
        if (btn) btn.innerHTML = '+';
      }
    });
  }

  function restoreSpanStates() {
    const s = JSON.parse(localStorage.getItem(STORAGE_KEY_SPAN) || '{}');
    document.querySelectorAll('#dashboardGrid > .card').forEach(card => {
      const span = normalizeCardSpan(s[card.dataset.cardId]);
      if (!span) return;
      const availableSpans = getAvailableCardSpans(card);
      const safeSpan = availableSpans.some(({ span: candidate }) => candidate === span)
        ? span
        : availableSpans[0].span;
      card.dataset.span = safeSpan;
      s[card.dataset.cardId] = safeSpan;
      const select = card.querySelector('.card-size-select');
      if (select) select.value = safeSpan;
    });
    localStorage.setItem(STORAGE_KEY_SPAN, JSON.stringify(s));
  }

  function restoreCardOrder() {
    const grid = document.getElementById('dashboardGrid');
    const saved = JSON.parse(localStorage.getItem(STORAGE_KEY_ORDER) || 'null');
    if (!saved?.length) return;
    saved.forEach(cid => {
      const el = grid.querySelector(`[data-card-id="${cid}"]`);
      if (el?.parentNode === grid) grid.appendChild(el);
    });
  }

  function saveCardOrder() {
    const grid = document.getElementById('dashboardGrid');
    const order = Array.from(grid.querySelectorAll(':scope > .card')).map(c => c.dataset.cardId);
    localStorage.setItem(STORAGE_KEY_ORDER, JSON.stringify(order));
  }

  // вФАвФА Collapsible Sections Toggle вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
  function toggleConfigSection(header) {
    const section = header.closest('.cfg-section');
    if (!section) return;
    section.classList.toggle('open');
    // Optionally, persist the state to localStorage
    const sectionTitle = header.querySelector('.cfg-section-header-title span:last-child')?.textContent || 'unknown';
    const state = section.classList.contains('open') ? 'open' : 'closed';
    localStorage.setItem(`cfg-section-${sectionTitle}`, state);
  }

  // Restore section states on page load
  function restoreSectionStates() {
    document.querySelectorAll('.cfg-section').forEach(section => {
      const title = section.querySelector('.cfg-section-header-title span:last-child')?.textContent || 'unknown';
      const state = localStorage.getItem(`cfg-section-${title}`);
      if (state === 'closed') {
        section.classList.remove('open');
      } else if (state === 'open') {
        section.classList.add('open');
      }
      // Default: Token & IDs and Pr√§senz & Status are open, others are closed
      if (!state) {
        if (title === 'рЯФС Token & IDs' || title === 'рЯШО Pr√§senz & Status') {
          section.classList.add('open');
        }
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      restoreSectionStates();
      initCardSystem();
    });
  } else {
    restoreSectionStates();
    initCardSystem();
  }

  const _origFetchAll = window.fetchAll;
  window.fetchAll = function() { _origFetchAll?.call(this); setTimeout(initCardSystem, 150); };
</script>
</body>
</html>
