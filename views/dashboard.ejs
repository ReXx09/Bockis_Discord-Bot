  let _arEmojiTargetIdx = null;
  let _arEmojiActiveCat = 0;

  function arOpenEmojiPicker(idx, btnEl) {
    const picker = document.getElementById('arEmojiPicker');
    if (picker.style.display !== 'none' && _arEmojiTargetIdx === idx) {
      arCloseEmojiPicker(); return;
    }
    _arEmojiTargetIdx = idx;
    _arEmojiActiveCat = 0;
    arRenderEmojiPicker();
    picker.style.display = 'flex';

    // Picker unter/√Љber dem Button positionieren
    const rect = btnEl.getBoundingClientRect();
    const pickerH = 340;
    const spaceBelow = window.innerHeight - rect.bottom;
    let top = spaceBelow >= pickerH ? rect.bottom + 4 : rect.top - pickerH - 4;
    let left = Math.min(rect.left, window.innerWidth - 330);
    picker.style.top = top + 'px';
    picker.style.left = Math.max(4, left) + 'px';
  }

  function arCloseEmojiPicker() {
    const picker = document.getElementById('arEmojiPicker');
    if (picker) picker.style.display = 'none';
    _arEmojiTargetIdx = null;
  }

  function arRenderEmojiPicker() {
    const catBtns = document.getElementById('arEmojiCatBtns');
    const grid    = document.getElementById('arEmojiGrid');
    catBtns.innerHTML = _arEmojiCategories.map((cat, i) => {
      const firstEmoji = cat.emojis[0];
      const active = i === _arEmojiActiveCat ? 'background:var(--green);color:#fff;' : 'background:var(--surface2);';
      return `<button type="button" title="${cat.label}" onclick="arSelectEmojiCat(${i})" style="${active}border:1px solid var(--border);border-radius:6px;padding:3px 7px;font-size:16px;cursor:pointer;line-height:1">${firstEmoji}</button>`;
    }).join('');

    const emojis = _arEmojiCategories[_arEmojiActiveCat].emojis;
    grid.innerHTML = emojis.map(e =>
      `<button type="button" onclick="arPickEmoji('${e}')" style="background:#111a2a;border:1px solid #22344f;font-size:20px;cursor:pointer;padding:4px;border-radius:4px;line-height:1" title="${e}" onmouseover="this.style.background='#1b2a40'" onmouseout="this.style.background='#111a2a'">${e}</button>`
    ).join('');
  }

  function arSelectEmojiCat(i) {
    _arEmojiActiveCat = i;
    arRenderEmojiPicker();
  }

  function arPickEmoji(emoji) {
    if (_arEmojiTargetIdx === null) return;
    const input = document.getElementById(`arReplyInput_${_arEmojiTargetIdx}`);
    if (!input) return;
    const start = input.selectionStart ?? input.value.length;
    const end   = input.selectionEnd   ?? input.value.length;
    const newVal = input.value.slice(0, start) + emoji + input.value.slice(end);
    input.value = newVal;
    arFieldChanged(_arEmojiTargetIdx, 'reply', newVal);
    // Cursor hinter Emoji setzen
    const pos = start + emoji.length;
    input.focus();
    input.setSelectionRange(pos, pos);
  }

  // Klick au√Яerhalb schlie√Яt den Picker
  document.addEventListener('click', (e) => {
    const picker = document.getElementById('arEmojiPicker');
    if (!picker || picker.style.display === 'none') return;
    if (!picker.contains(e.target) && !e.target.closest('[onclick*="arOpenEmojiPicker"]')) {
      arCloseEmojiPicker();
    }
  }, true);
