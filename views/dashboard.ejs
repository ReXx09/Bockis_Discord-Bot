  };

  function _defaultModelForBaseUrl(url) {
    return (_MODEL_SUGGESTIONS[url] || _MODEL_SUGGESTIONS['https://api.openai.com/v1']).models[0];
  }

  function updateModelSuggestions(baseUrl) {
    const cfg = _MODEL_SUGGESTIONS[baseUrl] || { models: [], hint: 'Modell-ID passend zum gew√§hlten Provider eintragen.', placeholder: '' };
    const dl = document.getElementById('cfgOpenaiModelList');
    dl.innerHTML = cfg.models.map(m => `<option value="${m}"></option>`).join('');
    const hint = document.getElementById('cfgOpenaiModelHint');
    if (hint) hint.innerHTML = cfg.hint;
    const inp = document.getElementById('cfgOpenaiModel');
    if (inp) inp.placeholder = cfg.placeholder;
  }

  // Provider-Dropdown: Modellvorschl√§ge und Placeholder aktualisieren
  document.getElementById('cfgOpenaiBaseUrl').addEventListener('change', function () {
