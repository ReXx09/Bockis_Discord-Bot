      <div class="cfg-module">
        <div class="cfg-module-title">🍓 Raspi / Web</div>
        <div class="cfg-field">
          <label class="cfg-label" for="cfgServiceCategory">Service Kategorie-Name</label>
          <input class="cfg-input" id="cfgServiceCategory" type="text" autocomplete="off"
                 placeholder="z. B. 📊 Service Status">
