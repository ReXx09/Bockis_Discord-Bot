  async function runRepair(action, sourceBtnId, group = 'updates') {
    const ui = REPAIR_UI_GROUPS[group] || REPAIR_UI_GROUPS.updates;
    const allBtns = ui.buttons.map(id => document.getElementById(id)).filter(Boolean);
    const btn     = document.getElementById(sourceBtnId);
    const logEl   = document.getElementById(ui.logId);
    if (!logEl) {
      toast('Reparatur-Log nicht gefunden', 'err');
      return;
    }

    allBtns.forEach(b => { b.disabled = true; });
    if (btn) { btn.textContent = 'вП≥вА¶'; }
    logEl.style.display = 'block';
    logEl.className     = 'update-log visible';
    logEl.innerHTML     = '';

    const addLine = (text, cls = '') => {
      const el = document.createElement('div');
      el.className = 'ul-line ' + cls;
      el.textContent = text.replace(/\x1b\[[0-9;]*m/g, '');
      logEl.appendChild(el);
      logEl.scrollTop = logEl.scrollHeight;
    };

    try {
      const res = await fetch('/api/repair', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: res.statusText }));
        addLine('Fehler: ' + (err.error || res.statusText), 'ul-err');
        toast('Reparatur fehlgeschlagen: ' + (err.error || ''), 'err');
        return;
      }

      const reader = res.body.getReader();
      const dec    = new TextDecoder();
      let buf = '';
      let willRestart = false;

      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        const parts = buf.split('\n\n');
        buf = parts.pop();
        for (const part of parts) {
          if (!part.startsWith('data:')) continue;
          const line = part.slice(5).trim();
          if (line.startsWith('__EXIT__:')) {
            const code = line.split(':')[1];
            if (code === '0') {
              addLine('вЬУ ' + (REPAIR_LABELS[action] || action) + ' erfolgreich!', 'ul-ok');
              toast('вЬУ Reparatur abgeschlossen', 'ok');
            } else {
              addLine('вЬЧ Reparatur fehlgeschlagen (Exit-Code ' + code + ')', 'ul-err');
              toast('Reparatur fehlgeschlagen (Code ' + code + ')', 'err');
            }
          } else {
            const clean = line.replace(/\x1b\[[0-9;]*m/g, '');
            if (/starte.*service.*neu|restarting/i.test(clean)) willRestart = true;
            let cls = 'ul-line';
            if (/error|fehler|fail|вЬЧ/i.test(line))        cls = 'ul-err';
            else if (/warn|вЪ†/i.test(line))                cls = 'ul-warn';
            else if (/вЬУ|success|erfolgreich/i.test(line)) cls = 'ul-ok';
            else if (/^===/.test(line))                    cls = 'ul-ok';
            addLine(line, cls);
          }
        }
      }
    } catch (e) {
      if (e.name === 'TypeError' && allBtns.some(b => b.id.endsWith('Restart') && b.disabled)) {
        addLine('вЖТ Verbindung getrennt вАФ Service wurde neugestartet', 'ul-warn');
        toast('Service neugestartet', 'ok');
      } else {
        addLine('Verbindungsfehler: ' + e.message, 'ul-err');
        toast('Fehler: ' + e.message, 'err');
      }
    } finally {
      allBtns.forEach(b => {
        b.disabled = false;
        const actionKey = ui.keyMap[b.id];
        b.textContent = REPAIR_LABELS[actionKey] || b.textContent;
      });
      if (btn) btn.textContent = REPAIR_LABELS[action] || action;
    }
  }

  function getUpdateButtonLabel(task, isBanner = false) {
    if (task === 'git') return isBanner ? 'вЦґ Git Pull starten' : 'вЦґ Git Pull';
    if (task === 'npm') return 'рЯУ¶ npm';
    return 'рЯЫ† Vollupdate';
  }

  async function runUpdate(modeOverride = null, taskOverride = 'git', sourceBtnId = 'btnUpdateRun') {
    const btn = document.getElementById(sourceBtnId) || document.getElementById('btnUpdateRun');
    const bannerBtn = document.getElementById('btnUpdateRun');
    const paneBtns = [
      document.getElementById('btnUpdateGitPane'),
      document.getElementById('btnUpdateNpmPane'),
      document.getElementById('btnUpdateFullPane'),
      document.getElementById('btnDepsUpdate'),
    ].filter(Boolean);
    const modeSelect = document.getElementById('updateMode');
    const selectedMode = modeOverride || (modeSelect ? modeSelect.value : 'auto');
    const selectedTask = taskOverride || 'git';

    btn.disabled = true;
    btn.textContent = 'вП≥ Update l√§uftвА¶';
    if (bannerBtn && bannerBtn !== btn) bannerBtn.disabled = true;
    paneBtns.forEach(paneBtn => { if (paneBtn !== btn) paneBtn.disabled = true; });

    const log  = document.getElementById('updateLog');
    const state = document.getElementById('updateState');
    if (state) state.textContent = `Update l√§uft (${selectedMode}, ${selectedTask})вА¶`;
    log.innerHTML = '';
    log.classList.add('visible');
    log.scrollTop = 0;

    const addLine = (text, cls = '') => {
      const el = document.createElement('div');
      el.className = 'ul-line ' + cls;
      // ANSI-Escape-Codes entfernen
      el.textContent = text.replace(/\x1b\[[0-9;]*m/g, '');
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
    };

    // Wird true, sobald der Stream "Service wird neugestartet" meldet.
    // Dann ist ein Verbindungsabbruch erwartet und kein Fehler.
    let willRestart = false;
    let handledByRestart = false;

    try {
      const res  = await fetch('/api/update-run', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode: selectedMode, task: selectedTask })
      });

      const reader = res.body.getReader();
      const dec    = new TextDecoder();
      let buf = '';

      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        const parts = buf.split('\n\n');
        buf = parts.pop();
        for (const part of parts) {
          if (!part.startsWith('data:')) continue;
          const line = part.slice(5).trim();
          if (line.startsWith('__EXIT__:')) {
            const code = line.split(':')[1];
            if (code === '0') {
              addLine('вЬУ Update erfolgreich abgeschlossen!', 'ul-ok');
              toast('вЬУ Bot erfolgreich aktualisiert!', 'ok');
              document.getElementById('updateBanner').classList.add('hidden');
              if (state) state.textContent = 'Update erfolgreich abgeschlossen';
            } else {
              addLine(`вЬЧ Update fehlgeschlagen (Exit-Code ${code})`, 'ul-err');
              toast('Update fehlgeschlagen', 'err');
              if (state) state.textContent = `Update fehlgeschlagen (Code ${code})`;
            }
          } else {
            // Neustart erkennen bevor der Service (und damit die Verbindung) stirbt
            const cleanLine = line.replace(/\x1b\[[0-9;]*m/g, '');
            if (/starte.*service.*neu|restarting.*service/i.test(cleanLine)) {
              willRestart = true;
            }
            let cls = 'ul-line';
            if (/error|fehler|fail/i.test(line))   cls = 'ul-err';
            else if (/warn|вЪ†/i.test(line))         cls = 'ul-warn';
            else if (/вЬУ|success|erfolgreich/i.test(line)) cls = 'ul-ok';
            addLine(line, cls);
          }
        }
      }
    } catch (e) {
      if (willRestart) {
        // Erwarteter Verbindungsabbruch durch Service-Neustart вАФ kein Fehler
        handledByRestart = true;
        addLine('вЖТ Service neugestartet вАФ warte auf WiederherstellungвА¶', 'ul-warn');
        if (state) state.textContent = 'Service neugestartet вАФ warteвА¶';
        // Im Hintergrund pollen bis der Server wieder antwortet
        _waitForServerReconnect(state);
      } else {
        addLine('Verbindungsfehler: ' + e.message, 'ul-err');
        toast('Fehler: ' + e.message, 'err');
        if (state) state.textContent = 'Verbindungsfehler beim Update';
      }
    } finally {
      btn.disabled = false;
      btn.textContent = getUpdateButtonLabel(selectedTask, sourceBtnId === 'btnUpdateRun');
      if (bannerBtn) {
        bannerBtn.disabled = false;
        bannerBtn.textContent = getUpdateButtonLabel('git', true);
      }
      paneBtns.forEach(paneBtn => {
        paneBtn.disabled = false;
        if (paneBtn.id === 'btnUpdateGitPane') paneBtn.textContent = getUpdateButtonLabel('git');
        if (paneBtn.id === 'btnUpdateNpmPane') paneBtn.textContent = getUpdateButtonLabel('npm');
        if (paneBtn.id === 'btnUpdateFullPane') paneBtn.textContent = getUpdateButtonLabel('full');
        if (paneBtn.id === 'btnDepsUpdate') paneBtn.textContent = 'рЯУ¶ npm updaten';
      });
      // Update-Check nur ausf√Љhren wenn kein Neustart l√§uft (der Reconnect-Poller macht es dann)
      if (!handledByRestart) checkUpdate(false);
    }
  }

  async function _waitForServerReconnect(stateEl, maxWaitMs = 90000, intervalMs = 2500) {
    const start = Date.now();
    while (Date.now() - start < maxWaitMs) {
      await new Promise(r => setTimeout(r, intervalMs));
      try {
        const r = await fetch('/api/config', { signal: AbortSignal.timeout(3000) });
        if (r.ok) {
          if (stateEl) stateEl.textContent = 'Update & Neustart erfolgreich вЬУ';
          const logEl = document.getElementById('updateLog');
          if (logEl) {
            const el = document.createElement('div');
            el.className = 'ul-line ul-ok';
            el.textContent = 'вЬУ Service l√§uft wieder вАФ Verbindung wiederhergestellt!';
            logEl.appendChild(el);
            logEl.scrollTop = logEl.scrollHeight;
          }
          toast('вЬУ Update & Neustart erfolgreich!', 'ok');
          document.getElementById('updateBanner')?.classList.add('hidden');
          checkUpdate(false);
          return;
        }
      } catch { /* Server antwortet noch nicht */ }
    }
    // Timeout nach maxWaitMs
    if (stateEl) stateEl.textContent = 'Service antwortet nicht вАФ bitte manuell pr√Љfen';
    toast('Service antwortet nach 90s nicht', 'err');
  }

  function _shouldPreserveConfigField(el, force = false) {
    if (!el || force) return false;
    if (el === document.activeElement) return true;
    return el.dataset.dirty === '1';
  }

  function _setDirtyState(el, isDirty) {
    if (!el) return;
    el.dataset.dirty = isDirty ? '1' : '0';
    el.classList.toggle('cfg-dirty', !!isDirty);
    const field = el.closest('.cfg-field');
    if (field) field.classList.toggle('cfg-field-dirty', !!isDirty);
  }

  function refreshConfigDirtyIndicator() {
    const dirtyEl = document.getElementById('cfgDirtyState');
    if (!dirtyEl) return;
    const fields = document.querySelectorAll('#cfgCard .cfg-input, #cfgCard input[type="checkbox"], #cfgCard select, #cfgCard textarea');
    const count = Array.from(fields).filter((el) => el.dataset.dirty === '1').length;
    if (count > 0) {
      dirtyEl.textContent = `вЧП ${count} ungespeicherte √Дnderung${count === 1 ? '' : 'en'}`;
      dirtyEl.classList.add('show');
    } else {
      dirtyEl.classList.remove('show');
      dirtyEl.textContent = 'вЧП Ungespeicherte √Дnderungen';
    }
  }

  function setFieldValue(id, value, { force = false } = {}) {
    const el = document.getElementById(id);
    if (!el) return;
    if (_shouldPreserveConfigField(el, force)) return;
    const normalized = value ?? '';
    el.value = normalized;
    el.dataset.initialValue = normalized;
    _setDirtyState(el, false);
    refreshConfigDirtyIndicator();
  }

  function setCheckboxValue(id, checked, { force = false } = {}) {
    const el = document.getElementById(id);
    if (!el) return;
    if (_shouldPreserveConfigField(el, force)) return;
    const normalized = !!checked;
    el.checked = normalized;
    el.dataset.initialValue = normalized ? 'true' : 'false';
    _setDirtyState(el, false);
    refreshConfigDirtyIndicator();
  }

  function initConfigDirtyTracking() {
    const fields = document.querySelectorAll('#cfgCard .cfg-input, #cfgCard input[type="checkbox"], #cfgCard select, #cfgCard textarea');
    fields.forEach((el) => {
      if (el.dataset.dirtyBound === '1') return;
      el.dataset.dirtyBound = '1';
      const markDirty = () => {
        _setDirtyState(el, true);
        refreshConfigDirtyIndicator();
      };
      el.addEventListener('input', markDirty);
      el.addEventListener('change', markDirty);
    });
    refreshConfigDirtyIndicator();
  }

  function clearConfigDirtyTracking() {
    const fields = document.querySelectorAll('#cfgCard .cfg-input, #cfgCard input[type="checkbox"], #cfgCard select, #cfgCard textarea');
    fields.forEach((el) => { _setDirtyState(el, false); });
    refreshConfigDirtyIndicator();
  }

  function _computeChannelNamePreview(serviceName, status, mode) {
    const dot = status === 1 ? 'рЯЯҐ' : status === 0 ? 'рЯФі' : 'рЯЯ°';
    const raw = String(serviceName || '').trim() || 'Service Name';

    const toMono = (value) => {
      return Array.from(value).map((ch) => {
        const code = ch.codePointAt(0);
        if (code >= 65 && code <= 90) return String.fromCodePoint(0x1D670 + (code - 65));
        if (code >= 97 && code <= 122) return String.fromCodePoint(0x1D68A + (code - 97));
        if (code >= 48 && code <= 57) return String.fromCodePoint(0x1D7F6 + (code - 48));
        return ch;
      }).join('');
    };

    if (mode === 'mono') {
      const mono = raw
        .replace(/[\u0000-\u001F\u007F]/g, '')
        .replace(/[\n\r\t]+/g, ' ')
        .replace(/\s+/g, '-')
        .replace(/#+/g, '-')
        .replace(/:+/g, '-')
        .replace(/@+/g, '-')
        .replace(/\/+|\\+/g, '-')
        .replace(/^-+|-+$/g, '')
        .slice(0, 90);
      return `${dot}-${toMono(mono || 'service')}`;
    }

    if (mode === 'pretty') {
      const pretty = raw
        .replace(/[\u0000-\u001F\u007F]/g, '')
        .replace(/[\n\r\t]+/g, ' ')
        .replace(/\s+/g, '-')
        .replace(/#+/g, '-')
        .replace(/:+/g, '-')
        .replace(/@+/g, '-')
        .replace(/\/+|\\+/g, '-')
        .replace(/^-+|-+$/g, '')
        .slice(0, 90);
      return `${dot}-${pretty || 'service'}`;
    }

    const slug = raw
      .toLowerCase()
      .replace(/[√§√ґ√Љ√Я]/g, c => ({ √§: 'ae', √ґ: 'oe', √Љ: 'ue', √Я: 'ss' })[c] ?? c)
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 94);
    return `${dot}-${slug || 'service'}`;
  }

  function _toStyledAsciiChar(ch, style) {
    const code = ch.codePointAt(0);

    // A-Z
    if (code >= 65 && code <= 90) {
      const offset = code - 65;
      if (style === 'mono') return String.fromCodePoint(0x1D670 + offset);
      if (style === 'sansbold') return String.fromCodePoint(0x1D5D4 + offset);
      if (style === 'serifbold') return String.fromCodePoint(0x1D400 + offset);
      if (style === 'serifitalic') return String.fromCodePoint(0x1D434 + offset);
      if (style === 'serifbolditalic') return String.fromCodePoint(0x1D468 + offset);
      if (style === 'sans') return String.fromCodePoint(0x1D5A0 + offset);
      if (style === 'sansitalic') return String.fromCodePoint(0x1D608 + offset);
    }

    // a-z
    if (code >= 97 && code <= 122) {
      const offset = code - 97;
      if (style === 'mono') return String.fromCodePoint(0x1D68A + offset);
      if (style === 'sansbold') return String.fromCodePoint(0x1D5EE + offset);
      if (style === 'serifbold') return String.fromCodePoint(0x1D41A + offset);
      if (style === 'serifitalic') return String.fromCodePoint(0x1D44E + offset);
      if (style === 'serifbolditalic') return String.fromCodePoint(0x1D482 + offset);
      if (style === 'sans') return String.fromCodePoint(0x1D5BA + offset);
      if (style === 'sansitalic') return String.fromCodePoint(0x1D622 + offset);
    }

    // 0-9
    if (code >= 48 && code <= 57) {
      const offset = code - 48;
      if (style === 'mono') return String.fromCodePoint(0x1D7F6 + offset);
      if (style === 'sansbold') return String.fromCodePoint(0x1D7EC + offset);
      if (style === 'serifbold') return String.fromCodePoint(0x1D7CE + offset);
      if (style === 'sans') return String.fromCodePoint(0x1D7E2 + offset);
    }

    return ch;
  }

  function convertUnicodeStyledText() {
    const inputEl = document.getElementById('cfgUnicodeInput');
    const styleEl = document.getElementById('cfgUnicodeStyle');
    const outputEl = document.getElementById('cfgUnicodeOutput');
    if (!inputEl || !styleEl || !outputEl) return;

    const input = String(inputEl.value || '');
    const style = styleEl.value || 'mono';
    const transformed = Array.from(input).map(ch => _toStyledAsciiChar(ch, style)).join('');
    outputEl.value = transformed;
  }

  function _insertUnicodeValue(selected, emptyMsg) {
    const inputEl = document.getElementById('cfgUnicodeInput');
    if (!inputEl) return false;

    const value = String(selected || '');
    if (!value) {
      toast(emptyMsg, 'warn');
      return false;
    }

    const start = inputEl.selectionStart ?? inputEl.value.length;
    const end = inputEl.selectionEnd ?? inputEl.value.length;
    const before = inputEl.value.slice(0, start);
    const after = inputEl.value.slice(end);
    inputEl.value = before + value + after;
    const cursorPos = start + value.length;
    inputEl.setSelectionRange(cursorPos, cursorPos);
    inputEl.focus();
    convertUnicodeStyledText();
    return true;
  }

