<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bockis Bot – Dashboard</title>
  <style>
    :root {
      --bg:       #0d1117;
      --surface:  #161b22;
      --surface2: #21262d;
      --border:   #30363d;
      --text:     #e6edf3;
      --muted:    #8b949e;
      --green:    #3fb950;
      --red:      #f85149;
      --yellow:   #d29922;
      --blue:     #388bfd;
      --purple:   #8957e5;
      --radius:   8px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 24px;
    }

    /* HEADER */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border);
    }
    .header h1 { font-size: 20px; font-weight: 600; }
    .header .sub { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .header-right { display: flex; align-items: center; gap: 12px; }
    .timer { font-size: 12px; color: var(--muted); }

    /* BUTTONS */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--text);
      font-size: 13px;
      cursor: pointer;
      transition: background .15s;
    }
    .btn:hover { background: var(--border); }
    .btn-green { background: #238636; border-color: #2ea043; color: #fff; }
    .btn-green:hover { background: #2ea043; }
    .btn-green:disabled { opacity: .6; cursor: not-allowed; }

    /* GRID */
    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 16px;
    }
    @media (max-width: 680px) { .grid-2 { grid-template-columns: 1fr; } }
    .grid-monitors {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
      gap: 12px;
    }

    /* DASHBOARD GRID LAYOUT */
    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 16px;
    }
    .dashboard-grid > .card {
      grid-column: span 12;
    }
    .dashboard-grid > .card[data-span="6"]  { grid-column: span 6; }
    .dashboard-grid > .card[data-span="4"]  { grid-column: span 4; }
    .dashboard-grid > .card[data-span="3"]  { grid-column: span 3; }
    .dashboard-grid > .card[data-span="12"] { grid-column: span 12; }
    @media (max-width: 900px) { .dashboard-grid > .card { grid-column: span 12 !important; } }

    /* CARD WIDTH BUTTONS */
    .btn-width {
      background: none;
      border: 1px solid var(--border);
      color: var(--muted);
      cursor: pointer;
      font-size: 10px;
      padding: 2px 6px;
      border-radius: 4px;
      transition: color .15s, border-color .15s;
      white-space: nowrap;
    }
    .btn-width:hover { color: var(--text); border-color: var(--blue); }
    .btn-width.active { color: var(--blue); border-color: var(--blue); }

    /* CARD */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
    }
    .card.dragging { opacity: 0.5; }
    .card.drag-over { border-color: var(--blue); box-shadow: 0 0 0 2px rgba(56,139,253,.2); }
    .drop-placeholder {
      min-height: 96px;
      border: 2px dashed rgba(56,139,253,.75);
      border-radius: var(--radius);
      background: rgba(56,139,253,.08);
      box-shadow: 0 0 0 2px rgba(56,139,253,.16), 0 0 18px rgba(56,139,253,.24);
      pointer-events: none;
      animation: dropPulse .9s ease-in-out infinite alternate;
    }
    @keyframes dropPulse {
      from { box-shadow: 0 0 0 1px rgba(56,139,253,.14), 0 0 8px rgba(56,139,253,.18); }
      to   { box-shadow: 0 0 0 2px rgba(56,139,253,.28), 0 0 22px rgba(56,139,253,.34); }
    }
    
    /* CARD WRAPPER MIT COLLAPSE */
    .card-wrapper {
      display: flex;
      flex-direction: column;
    }
    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
      cursor: grab;
      user-select: none;
    }
    .card-header:active { cursor: grabbing; }
    .card-header-left { display: flex; align-items: center; gap: 8px; flex: 1; }
    .card-title {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: var(--muted);
      margin: 0;
    }
    .card-controls { display: flex; gap: 6px; }
    .btn-collapse {
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 14px;
      padding: 4px 8px;
      transition: color .15s;
      width: 28px; height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .btn-collapse:hover { color: var(--text); }
    
    .card-content {
      overflow: hidden;
      transition: max-height .25s ease, opacity .25s ease;
      max-height: 2000px;
      opacity: 1;
    }
    .card-content.collapsed {
      max-height: 0;
      opacity: 0;
      pointer-events: none;
    }

    /* INFO ROW */
    .row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 7px 0;
      border-bottom: 1px solid var(--border);
      font-size: 13px;
    }
    .row:last-child { border-bottom: none; }
    .row-label { color: var(--muted); }
    .row-value { font-weight: 500; font-family: 'SFMono-Regular', Consolas, monospace; }

    /* BADGE */
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .04em;
    }
    .b-green  { background: rgba(63,185,80,.15);  color: var(--green); }
    .b-red    { background: rgba(248,81,73,.15);   color: var(--red); }
    .b-yellow { background: rgba(210,153,34,.15);  color: var(--yellow); }
    .b-gray   { background: rgba(139,148,158,.15); color: var(--muted); }
    .b-purple { background: rgba(137,87,229,.15);  color: var(--purple); }

    /* DOT */
    .dot {
      display: inline-block;
      width: 8px; height: 8px;
      border-radius: 50%;
      margin-right: 5px;
    }
    .dot-g { background: var(--green); box-shadow: 0 0 5px var(--green); }
    .dot-r { background: var(--red);   box-shadow: 0 0 5px var(--red); }

    /* MONITOR CARD */
    .mc {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      position: relative;
      overflow: hidden;
    }
    .mc::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .mc.online::before  { background: var(--green); }
    .mc.offline::before { background: var(--red); }
    .mc.pending::before { background: var(--yellow); }
    .mc.inactive::before{ background: var(--muted); }
    .mc-name {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 4px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .mc-group { font-size: 11px; color: var(--muted); margin-bottom: 10px; }
    .uptime-bar {
      height: 4px;
      background: var(--surface2);
      border-radius: 2px;
      margin: 8px 0;
      overflow: hidden;
    }
    .uptime-fill { height: 100%; border-radius: 2px; transition: width .5s ease; }
    .uf-g { background: var(--green); }
    .uf-y { background: var(--yellow); }
    .uf-r { background: var(--red); }
    .mc-meta {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: var(--muted);
      margin-top: 6px;
    }

    /* SERVICE CONTROL */
    .svc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 12px;
    }
    .svc-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .svc-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .svc-name { font-size: 13px; font-weight: 600; }
    .svc-actions { display: flex; gap: 6px; }
    .btn-svc {
      padding: 4px 10px;
      font-size: 11px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--text);
      cursor: pointer;
      transition: background .15s;
    }
    .btn-svc:hover { background: var(--border); }
    .btn-svc.start  { color: var(--green); border-color: rgba(63,185,80,.4); }
    .btn-svc.stop   { color: var(--red);   border-color: rgba(248,81,73,.4); }
    .btn-svc.restart{ color: var(--yellow);border-color: rgba(210,153,34,.4); }
    .btn-svc:disabled { opacity: .45; cursor: not-allowed; }

    /* SECTION */
    .section-hdr {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin: 24px 0 12px;
    }
    .section-hdr .title { font-size: 14px; font-weight: 600; }
    .section-hdr .count {
      font-size: 12px;
      color: var(--muted);
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2px 10px;
    }

    /* LOG VIEWER */
    .log-viewer {
      background: #010409;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      height: 260px;
      overflow-y: auto;
      font-family: 'SFMono-Regular', Consolas, monospace;
      font-size: 12px;
      line-height: 1.65;
    }
    .ll { color: var(--muted); padding: 1px 0; white-space: pre-wrap; word-break: break-all; }
    .ll.e { color: var(--red); }
    .ll.w { color: var(--yellow); }
    .ll.i { color: var(--text); }

    /* SKELETON */
    .sk {
      background: linear-gradient(90deg, var(--surface2) 25%, var(--border) 50%, var(--surface2) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      border-radius: 4px;
      height: 13px;
      margin-bottom: 14px;
    }
    @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

    /* TOAST */
    #toast {
      position: fixed;
      bottom: 24px; right: 24px;
      padding: 12px 18px;
      border-radius: var(--radius);
      font-size: 13px;
      background: var(--surface2);
      border: 1px solid var(--border);
      display: none;
      z-index: 999;
      box-shadow: 0 4px 20px rgba(0,0,0,.5);
    }
    #toast.show  { display: block; animation: fiu .25s ease; }
    #toast.ok    { border-color: var(--green); color: var(--green); }
    #toast.err   { border-color: var(--red);   color: var(--red); }
    @keyframes fiu { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }

    .muted { color: var(--muted); font-size: 12px; }
    .mb12  { margin-bottom: 12px; }

    /* UPDATE BANNER */
    #updateBanner {
      display: none;
      background: rgba(210,153,34,.08);
      border: 1px solid rgba(210,153,34,.4);
      border-radius: var(--radius);
      padding: 14px 18px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }
    #updateBanner.hidden { display: none !important; }
    .ub-left { display: flex; align-items: center; gap: 10px; }
    .ub-icon { font-size: 20px; }
    .ub-title { font-size: 14px; font-weight: 600; color: var(--yellow); }
    .ub-sub   { font-size: 12px; color: var(--muted); margin-top: 2px; }

    /* UPDATE SECTION */
    #updateSection { display: none; margin-bottom: 24px; }
    #updateSection.visible { display: block; }
    .commit-list { margin-top: 10px; }
    .commit {
      display: flex; gap: 12px; align-items: baseline;
      padding: 6px 0; border-bottom: 1px solid var(--border);
      font-size: 13px;
    }
    .commit:last-child { border-bottom: none; }
    .commit-hash {
      font-family: 'SFMono-Regular', Consolas, monospace;
      font-size: 11px; color: var(--blue);
      min-width: 52px;
    }
    .commit-msg  { flex: 1; color: var(--text); }
    .commit-when { font-size: 11px; color: var(--muted); white-space: nowrap; }

    /* TERMINAL OUTPUT */
    #updateLog {
      background: #010409;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px;
      height: 200px;
      overflow-y: auto;
      font-family: 'SFMono-Regular', Consolas, monospace;
      font-size: 12px;
      line-height: 1.6;
      display: none;
      margin-top: 12px;
    }
    #updateLog.visible { display: block; }
    .ul-line { white-space: pre-wrap; word-break: break-all; color: var(--muted); }
    .ul-ok   { color: var(--green); }
    .ul-err  { color: var(--red); }
    .ul-warn { color: var(--yellow); }

    /* CONFIG FORM */
    .cfg-form { margin-top: 4px; }
    .cfg-field { margin-bottom: 14px; }
    .cfg-label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .cfg-input {
      width: 100%;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      font-family: 'SFMono-Regular', Consolas, monospace;
      font-size: 12px;
      padding: 8px 10px;
      box-sizing: border-box;
      outline: none;
      transition: border-color .15s;
    }
    .cfg-input:focus { border-color: var(--blue); }
    .cfg-hint { font-size: 11px; color: var(--muted); margin-top: 4px; }
    .cfg-actions { display: flex; gap: 10px; align-items: center; margin-top: 6px; }
    #cfgStatus { font-size: 12px; }
    #cfgStatus.ok  { color: var(--green); }
    #cfgStatus.err { color: var(--red); }
  </style>
</head>
<body>

<!-- ── UPDATE BANNER (wird per JS eingeblendet) ─────── -->
<div id="updateBanner" class="hidden">
  <div class="ub-left">
    <span class="ub-icon">⚠️</span>
    <div>
      <div class="ub-title">Update verfügbar</div>
      <div class="ub-sub" id="ubSub">Neue Version auf GitHub gefunden</div>
    </div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <button class="btn" onclick="toggleUpdateSection()">Details anzeigen ↓</button>
    <button class="btn btn-green" id="btnUpdateRun" onclick="runUpdate()">▶ Update jetzt starten</button>
  </div>
</div>

<!-- ── UPDATE DETAIL SECTION ──────────────────────────── -->
<div id="updateSection">
  <div class="card" style="margin-bottom:16px">
    <div class="card-title">Neue Commits auf GitHub</div>
    <div id="commitList" class="commit-list"></div>
    <div id="updateLog"></div>
  </div>
</div>

<!-- ── HEADER ─────────────────────────────────────────── -->
<div class="header">
  <div>
    <h1>🤖 Bockis Bot · Dashboard</h1>
    <div class="sub">Service Monitor · Live-Ansicht</div>
  </div>
  <div class="header-right">
    <span class="timer" id="timer">Auto-Refresh in 30s</span>
    <button class="btn btn-green" id="btnRefresh" onclick="manualRefresh()">
      ↺ Discord Refresh
    </button>
  </div>
</div>

<!-- ── DASHBOARD GRID ───────────────────────────────── -->
<div class="dashboard-grid" id="dashboardGrid">

<!-- ── BOT STATUS ─────────────────────────────────────── -->
<div class="card" id="botCard" data-span="6">
  <div class="card-title">Bot Status</div>
  <div id="botInfo">
    <div class="sk"></div>
    <div class="sk" style="width:70%"></div>
    <div class="sk" style="width:50%"></div>
  </div>
</div>

<!-- ── SYSTEM ─────────────────────────────────────────── -->
<div class="card" id="sysCard" data-span="6">
  <div class="card-title">System</div>
  <div id="sysInfo">
    <div class="sk"></div>
    <div class="sk" style="width:70%"></div>
    <div class="sk" style="width:50%"></div>
  </div>
</div>

<!-- ── ROW 1b: CLOUDFLARE TUNNEL ─────────────────────── -->
<div class="card" id="tunnelCard" data-span="12">
  <div class="card-title">🌐 Cloudflare Tunnel</div>
  <div id="tunnelInfo">
    <div class="sk"></div>
    <div class="sk" style="width:55%"></div>
  </div>
</div>

<!-- ── ROW 1c: DISCORD KONFIGURATION ───────────────────── -->
<div class="card" id="cfgCard" data-span="12">
  <div class="card-title">⚙️ Discord-Konfiguration</div>
  <div class="cfg-form">
    <div class="cfg-field">
      <label class="cfg-label" for="cfgToken">Discord Bot Token</label>
      <input class="cfg-input" id="cfgToken" type="password" autocomplete="off"
             placeholder="Neuen Token eingeben (leer lassen = unverändert)">
      <div class="cfg-hint">Leer lassen, um den bestehenden Token zu behalten.</div>
    </div>
    <div class="cfg-field">
      <label class="cfg-label" for="cfgStatusCh">Status-Channel ID</label>
      <input class="cfg-input" id="cfgStatusCh" type="text" autocomplete="off"
             placeholder="z. B. 123456789012345678">
    </div>
    <div class="cfg-field">
      <label class="cfg-label" for="cfgNotifCh">Benachrichtigungs-Channel ID</label>
      <input class="cfg-input" id="cfgNotifCh" type="text" autocomplete="off"
             placeholder="z. B. 123456789012345678">
    </div>
    <div class="cfg-field">
      <label class="cfg-label" for="cfgKumaUrl">Uptime Kuma URL</label>
      <input class="cfg-input" id="cfgKumaUrl" type="text" autocomplete="off"
             placeholder="http://192.168.x.x:3001">
    </div>
    <div class="cfg-field">
      <label class="cfg-label" for="cfgRenderMode">Discord Status Renderer</label>
      <select class="cfg-input" id="cfgRenderMode">
        <option value="link_preview">Link-Preview (bevorzugt)</option>
        <option value="embed">Custom-Embed (fallback-fest)</option>
        <option value="auto">Auto (entscheidet automatisch)</option>
      </select>
      <div class="cfg-hint">Hier kannst du direkt zwischen Discord Link-Preview und Custom-Embed umschalten.</div>
    </div>
    <div class="cfg-field">
      <label class="cfg-label">Channel-Status-Indikator</label>
      <div style="display:flex;align-items:center;gap:12px;margin-top:2px">
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px">
          <input type="checkbox" id="cfgChannelIndicator" style="width:16px;height:16px;cursor:pointer;accent-color:var(--green)">
          <span>Channel-Name und Topic automatisch mit 🟢 / 🟡 / 🔴 aktualisieren</span>
        </label>
      </div>
      <div class="cfg-hint">Bei Statuswechsel wird z.B. aus <code>dienste-status</code> → <code>🟢dienste-status</code> (max. 2× / 10 min)</div>
    </div>
    <div class="cfg-actions">
      <button class="btn btn-green" id="btnCfgSave" onclick="saveConfig()">💾 Speichern &amp; Neu starten</button>
      <button class="btn" onclick="loadConfig()">↺ Zurücksetzen</button>
      <span id="cfgStatus"></span>
    </div>
  </div>
</div>

<!-- ── ROW 2: MONITORS ────────────────────────────────── -->
<div class="card" id="monitorsCard" data-span="12">
  <div class="card-title">📡 Services <span class="count" id="monCount" style="margin-left:8px">–</span></div>
  <div class="grid-monitors" id="monGrid"></div>
</div>

<!-- ── ROW 2b: SERVICE CONTROL ────────────────── -->
<div class="card" id="svcCard" data-span="12">
  <div class="card-title">⚙️ Dienste verwalten <span class="muted" style="font-size:11px;font-weight:400;text-transform:none;letter-spacing:0;margin-left:8px">start / stop / restart via systemctl</span></div>
<div class="svc-grid" id="svcGrid">
  <div class="svc-card" id="svc-bockis-bot">
    <div class="svc-header">
      <span class="svc-name">🤖 Bockis Bot</span>
      <span class="badge b-gray" id="svcBadge-bockis-bot">...</span>
    </div>
    <div class="svc-actions">
      <button class="btn-svc start"  onclick="svcAction('bockis-bot','start')">&#9654; Start</button>
      <button class="btn-svc stop"   onclick="svcAction('bockis-bot','stop')">&#9632; Stop</button>
      <button class="btn-svc restart" onclick="svcAction('bockis-bot','restart')">&#8635; Restart</button>
    </div>
    <div class="muted" style="font-size:11px">Stop beendet auch das Dashboard kurzzeitig</div>
  </div>
  <div class="svc-card" id="svc-uptime-kuma">
    <div class="svc-header">
      <span class="svc-name">📊 Uptime Kuma</span>
      <span class="badge b-gray" id="svcBadge-uptime-kuma">...</span>
    </div>
    <div class="svc-actions">
      <button class="btn-svc start"  onclick="svcAction('uptime-kuma','start')">&#9654; Start</button>
      <button class="btn-svc stop"   onclick="svcAction('uptime-kuma','stop')">&#9632; Stop</button>
      <button class="btn-svc restart" onclick="svcAction('uptime-kuma','restart')">&#8635; Restart</button>
    </div>
  </div>
  <div class="svc-card" id="svc-cloudflared">
    <div class="svc-header">
      <span class="svc-name">🌐 Cloudflare Tunnel</span>
      <span class="badge b-gray" id="svcBadge-cloudflared">...</span>
    </div>
    <div class="svc-actions">
      <button class="btn-svc start"  onclick="svcAction('cloudflared','start')">&#9654; Start</button>
      <button class="btn-svc stop"   onclick="svcAction('cloudflared','stop')">&#9632; Stop</button>
      <button class="btn-svc restart" onclick="svcAction('cloudflared','restart')">&#8635; Restart</button>
    </div>
  </div>
</div>
</div>

<!-- ── ROW 3: LOGS ────────────────────────────────────── -->
<div class="card" id="logsCard" data-span="12">
  <div class="card-title">📄 Bot-Logs <span class="muted" id="logFile" style="font-size:11px;font-weight:400;text-transform:none;letter-spacing:0;margin-left:8px">–</span></div>
  <div class="log-viewer" id="logViewer">
    <span class="muted">Lade Logs…</span>
  </div>
</div>

</div><!-- /.dashboard-grid -->

<!-- ── TOAST ──────────────────────────────────────────── -->
<div id="toast"></div>

<script>
  // ── Countdown ────────────────────────────────────────
  let cd = 30, cdTimer = null;

  function resetCd() {
    cd = 30;
    clearInterval(cdTimer);
    cdTimer = setInterval(() => {
      cd--;
      document.getElementById('timer').textContent = `Auto-Refresh in ${cd}s`;
      if (cd <= 0) { fetchAll(); resetCd(); }
    }, 1000);
  }

  // ── Toast ────────────────────────────────────────────
  function toast(msg, type = 'ok') {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.className = 'show ' + type;
    clearTimeout(el._t);
    el._t = setTimeout(() => el.className = '', 3500);
  }

  // ── Helpers ──────────────────────────────────────────
  function fmtUptime(sec) {
    const d = Math.floor(sec / 86400);
    const h = Math.floor((sec % 86400) / 3600);
    const m = Math.floor((sec % 3600) / 60);
    const s = Math.floor(sec % 60);
    if (d > 0) return `${d}d ${h}h ${m}m`;
    if (h > 0) return `${h}h ${m}m ${s}s`;
    return `${m}m ${s}s`;
  }

  function row(label, value) {
    return `<div class="row"><span class="row-label">${label}</span><span class="row-value">${value}</span></div>`;
  }

  function tempBadge(tempC) {
    if (tempC == null || Number.isNaN(tempC)) return '<span class="badge b-gray">N/V</span>';
    if (tempC >= 75) return `<span class="badge b-red">${tempC.toFixed(1)} °C</span>`;
    if (tempC >= 65) return `<span class="badge b-yellow">${tempC.toFixed(1)} °C</span>`;
    return `<span class="badge b-green">${tempC.toFixed(1)} °C</span>`;
  }

  // ── Render: Bot Info ─────────────────────────────────
  function renderBot(d) {
    const dot   = d.discordReady ? '<span class="dot dot-g"></span>' : '<span class="dot dot-r"></span>';
    const badge = d.discordReady ? '<span class="badge b-green">ONLINE</span>' : '<span class="badge b-red">OFFLINE</span>';
    const pingColor = d.ping < 0 ? 'var(--muted)' : d.ping < 100 ? 'var(--green)' : d.ping < 250 ? 'var(--yellow)' : 'var(--red)';
    const pingStr   = d.ping >= 0 ? `<span style="color:${pingColor}">${d.ping} ms</span>` : '–';

    document.getElementById('botInfo').innerHTML =
      row('Discord', dot + badge) +
      row('Bot-Tag', d.tag) +
      row('WS-Ping', pingStr) +
      row('Laufzeit', fmtUptime(d.uptime));
  }

  // ── Render: System ───────────────────────────────────
  function renderSys(bot, raspi = null) {
    const systemRam = raspi
      ? `${raspi.memUsedMb} / ${raspi.memTotalMb} MB (${raspi.memUsedPercent}%)`
      : '–';
    const load = raspi
      ? `${raspi.load1} / ${raspi.load5} / ${raspi.load15}`
      : '–';
    const platform = raspi?.platform || navigator.platform || '–';

    document.getElementById('sysInfo').innerHTML =
      row('CPU-Temperatur', tempBadge(raspi?.cpuTempC ?? null)) +
      row('RAM (Raspberry)', systemRam) +
      row('Load (1/5/15)', load) +
      row('Node.js', bot.nodeVersion) +
      row('RAM (Prozess)', bot.memUsedMb + ' MB') +
      row('Heap (genutzt)', bot.memHeapMb + ' MB') +
      row('Plattform', platform);
  }

  // ── Render: Monitors ─────────────────────────────────
  function monClass(m) {
    if (!m.active)    return 'inactive';
    if (m.status === 1) return 'online';
    if (m.status === 0) return 'offline';
    if (m.status === 2) return 'pending';
    return 'inactive';
  }
  function monBadge(m) {
    if (!m.active)    return '<span class="badge b-gray">DEAKTIVIERT</span>';
    if (m.status === 1) return '<span class="badge b-green">ONLINE</span>';
    if (m.status === 0) return '<span class="badge b-red">OFFLINE</span>';
    if (m.status === 2) return '<span class="badge b-yellow">PENDING</span>';
    return '<span class="badge b-gray">UNBEKANNT</span>';
  }
  function fillCls(u) {
    const v = parseFloat(u);
    return v >= 95 ? 'uf-g' : v >= 80 ? 'uf-y' : 'uf-r';
  }

  function renderMonitors(monitors) {
    const grid  = document.getElementById('monGrid');
    const count = document.getElementById('monCount');

    if (!monitors.length) {
      grid.innerHTML = '<p class="muted">Keine Daten von Uptime Kuma empfangen.</p>';
      count.textContent = '0';
      return;
    }

    const online  = monitors.filter(m => m.status === 1 && m.active).length;
    const offline = monitors.filter(m => m.status === 0 && m.active).length;
    count.textContent = `${online} / ${monitors.length} online` + (offline ? ` · ${offline} offline` : '');

    grid.innerHTML = monitors.map(m => {
      const lastCheck = m.time ? new Date(m.time).toLocaleTimeString('de-DE') : '–';
      const ping      = m.ping ? m.ping + ' ms' : '–';
      return `
        <div class="mc ${monClass(m)}">
          <div class="mc-name" title="${m.name}">${m.name}</div>
          <div class="mc-group">${m.group}</div>
          ${monBadge(m)}
          <div class="uptime-bar">
            <div class="uptime-fill ${fillCls(m.uptime)}" style="width:${m.uptime}%"></div>
          </div>
          <div class="mc-meta">
            <span>${m.uptime}% Uptime</span>
            <span>${ping}</span>
          </div>
          <div class="muted" style="margin-top:6px">⏱ ${lastCheck}</div>
        </div>`;
    }).join('');
  }

  // ── Render: Logs ─────────────────────────────────────
  function renderLogs(d) {
    document.getElementById('logFile').textContent = d.file || '–';
    const viewer = document.getElementById('logViewer');

    if (!d.lines.length) {
      viewer.innerHTML = '<span class="muted">Keine Log-Einträge gefunden.</span>';
      return;
    }

    viewer.innerHTML = d.lines.map(line => {
      let cls = 'll';
      if (/ERROR/i.test(line)) cls += ' e';
      else if (/WARN/i.test(line))  cls += ' w';
      else if (/INFO/i.test(line))  cls += ' i';
      const safe = line.replace(/</g, '&lt;').replace(/>/g, '&gt;');
      return `<div class="${cls}">${safe}</div>`;
    }).join('');
  }

  // ── Fetch All ────────────────────────────────────────
  async function fetchAll() {
    try {
      const [bot, status, logs, raspi] = await Promise.all([
        fetch('/api/bot-info').then(r => r.json()),
        fetch('/api/status').then(r => r.json()),
        fetch('/api/logs').then(r => r.json()),
        fetch('/api/raspi-status').then(r => r.json()).catch(() => ({ ok: false }))
      ]);
      if (bot.ok)    { renderBot(bot); renderSys(bot, raspi?.ok ? raspi : null); }
      if (status.ok) renderMonitors(status.monitors);
      if (logs.ok)   renderLogs(logs);
    } catch (e) {
      toast('Verbindungsfehler – ' + e.message, 'err');
    }
    // Tunnel-Status separat (non-blocking, cloudflared optional)
    try {
      const t = await fetch('/api/tunnel-status').then(r => r.json());
      renderTunnel(t);
    } catch { /* cloudflared nicht zwingend installiert */ }    // Service-Status laden
    fetchServiceStatus();
  }

  // ── Service Control ────────────────────────────────
  const SVC_LABELS = {
    'active':   ['b-green',  'AKTIV'],
    'inactive': ['b-gray',   'GESTOPPT'],
    'failed':   ['b-red',    'FEHLER'],
    'unknown':  ['b-yellow', 'UNBEKANNT']
  };

  async function fetchServiceStatus() {
    try {
      const d = await fetch('/api/service-status').then(r => r.json());
      if (!d.ok) return;
      for (const [svc, state] of Object.entries(d.services)) {
        const badge = document.getElementById('svcBadge-' + svc);
        if (!badge) continue;
        const [cls, label] = SVC_LABELS[state] || ['b-gray', state];
        badge.className = 'badge ' + cls;
        badge.textContent = label;
      }
    } catch { /* service-status ist optional */ }
  }

  async function svcAction(service, action) {
    const btns = document.querySelectorAll(`#svc-${service} .btn-svc`);
    btns.forEach(b => b.disabled = true);
    toast(`⏳ ${action} ${service}…`);
    try {
      const r = await fetch('/api/service-control', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ service, action })
      }).then(r => r.json());
      if (r.ok) {
        toast(`✓ ${service}: ${action} ausgeführt`);
      } else {
        toast(`Fehler: ${r.error}`, 'err');
      }
    } catch (e) {
      toast('Netzwerkfehler: ' + e.message, 'err');
    } finally {
      setTimeout(() => {
        btns.forEach(b => b.disabled = false);
        fetchServiceStatus();
      }, 2500);
    }  }

  // ── Tunnel Status ────────────────────────────────────
  function renderTunnel(d) {
    const el = document.getElementById('tunnelInfo');
    const card = document.getElementById('tunnelCard');
    if (!d.installed) {
      el.innerHTML = row('Status', '<span class="badge" style="background:var(--surface2);color:var(--muted)">nicht installiert</span>') +
                     row('Hinweis', '<span class="muted">cloudflared nicht gefunden – im Raspi-Menü unter "Netzwerk &amp; Cloudflare" einrichten</span>');
      card.style.borderTop = '3px solid var(--border)';
      return;
    }
    const stBadge = d.active
      ? '<span class="badge b-green">AKTIV</span>'
      : '<span class="badge b-red">GESTOPPT</span>';
    card.style.borderTop = d.active ? '3px solid var(--green)' : '3px solid var(--red)';
    let html = row('Service', stBadge) + row('Version', d.version || '–');
    if (d.tunnels && d.tunnels.length) {
      html += row('Tunnel', d.tunnels.map(t =>
        `<span class="commit-hash">${t.id.slice(0,8)}</span> ${t.name.replace(/</g,'&lt;').replace(/>/g,'&gt;')}`
      ).join('<br>'));
    } else if (d.zeroTrust) {
      html += row('Tunnel', '<span class="badge b-green">Zero Trust (Token-Methode)</span>');
      if (d.publicUrl) {
        html += row('Public URL', `<a href="${d.publicUrl.replace(/</g,'&lt;')}" target="_blank" style="color:var(--blue)">${d.publicUrl.replace(/</g,'&lt;')}</a>`);
      }
    } else {
      html += row('Tunnel', '<span class="muted">kein Tunnel konfiguriert</span>');
    }
    el.innerHTML = html;
  }

  // ── Manual Refresh ───────────────────────────────────
  async function manualRefresh() {
    const btn = document.getElementById('btnRefresh');
    btn.disabled = true;
    btn.textContent = '⏳ Wird aktualisiert…';
    try {
      const res = await fetch('/api/refresh', { method: 'POST' });
      const d   = await res.json();
      if (d.ok) toast('✓ Discord Status-Nachricht aktualisiert');
      else      toast('Fehler: ' + d.error, 'err');
      await fetchAll();
      resetCd();
    } catch (e) {
      toast('Netzwerkfehler: ' + e.message, 'err');
    } finally {
      btn.disabled = false;
      btn.textContent = '↺ Discord Refresh';
    }
  }

  // ── Init ─────────────────────────────────────────────
  fetchAll();
  resetCd();
  checkUpdate();

  // ── Update Check ─────────────────────────────────────
  let _updateData = null;

  async function checkUpdate() {
    try {
      const d = await fetch('/api/update-check').then(r => r.json());
      if (!d.ok || !d.hasGit || d.fetchFailed) return;
      _updateData = d;

      const banner = document.getElementById('updateBanner');
      const sub    = document.getElementById('ubSub');

      if (d.updateAvailable) {
        sub.textContent = `${d.behind} neuer Commit${d.behind > 1 ? 's' : ''} verfügbar · lokal: ${d.local} · remote: ${d.remote}`;
        banner.classList.remove('hidden');
        renderCommits(d.commits);
      } else {
        // Kein Update — trotzdem Versioninfo im Bot-Card ergänzen
        const bi = document.getElementById('botInfo');
        if (bi) bi.innerHTML += row('Git-Commit', d.local + ' ✓ aktuell');
      }
    } catch { /* update check ist nicht kritisch */ }
  }

  function renderCommits(commits) {
    const cl = document.getElementById('commitList');
    if (!commits.length) { cl.innerHTML = '<span class="muted">Keine Details verfügbar.</span>'; return; }
    cl.innerHTML = commits.map(c =>
      `<div class="commit">
        <span class="commit-hash">${c.hash}</span>
        <span class="commit-msg">${c.subject.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</span>
        <span class="commit-when">${c.when}</span>
      </div>`
    ).join('');
  }

  function toggleUpdateSection() {
    const s = document.getElementById('updateSection');
    s.classList.toggle('visible');
  }

  async function runUpdate() {
    const btn = document.getElementById('btnUpdateRun');
    btn.disabled = true;
    btn.textContent = '⏳ Update läuft…';

    const log  = document.getElementById('updateLog');
    const sect = document.getElementById('updateSection');
    log.innerHTML = '';
    log.classList.add('visible');
    sect.classList.add('visible');
    log.scrollTop = 0;

    const addLine = (text, cls = '') => {
      const el = document.createElement('div');
      el.className = 'ul-line ' + cls;
      // ANSI-Escape-Codes entfernen
      el.textContent = text.replace(/\x1b\[[0-9;]*m/g, '');
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
    };

    try {
      const res  = await fetch('/api/update-run', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode: 'auto' })
      });

      const reader = res.body.getReader();
      const dec    = new TextDecoder();
      let buf = '';

      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        const parts = buf.split('\n\n');
        buf = parts.pop();
        for (const part of parts) {
          if (!part.startsWith('data:')) continue;
          const line = part.slice(5).trim();
          if (line.startsWith('__EXIT__:')) {
            const code = line.split(':')[1];
            if (code === '0') {
              addLine('✓ Update erfolgreich abgeschlossen!', 'ul-ok');
              toast('✓ Bot erfolgreich aktualisiert!', 'ok');
              document.getElementById('updateBanner').classList.add('hidden');
            } else {
              addLine(`✗ Update fehlgeschlagen (Exit-Code ${code})`, 'ul-err');
              toast('Update fehlgeschlagen', 'err');
            }
          } else {
            let cls = 'ul-line';
            if (/error|fehler|fail/i.test(line))   cls = 'ul-err';
            else if (/warn|⚠/i.test(line))         cls = 'ul-warn';
            else if (/✓|success|erfolgreich/i.test(line)) cls = 'ul-ok';
            addLine(line, cls);
          }
        }
      }
    } catch (e) {
      addLine('Verbindungsfehler: ' + e.message, 'ul-err');
      toast('Fehler: ' + e.message, 'err');
    } finally {
      btn.disabled = false;
      btn.textContent = '▶ Update jetzt starten';
    }
  }

  // ── Config laden ─────────────────────────────────────
  async function loadConfig() {
    try {
      const d = await fetch('/api/config').then(r => r.json());
      if (!d.ok) { document.getElementById('cfgStatus').textContent = d.error; return; }
      // Token-Feld leer lassen (Platzhalter zeigt Hinweis)
      document.getElementById('cfgToken').value    = '';
      document.getElementById('cfgStatusCh').value = d.STATUS_CHANNEL_ID || '';
      document.getElementById('cfgNotifCh').value  = d.DISCORD_NOTIFICATION_CHANNEL || '';
      document.getElementById('cfgKumaUrl').value  = d.UPTIME_KUMA_URL || '';
      document.getElementById('cfgRenderMode').value = d.DISCORD_STATUS_RENDER_MODE || 'auto';
      document.getElementById('cfgStatus').textContent = '';
      document.getElementById('cfgToken').placeholder = d.DISCORD_TOKEN
        ? `Aktuell: ${d.DISCORD_TOKEN} — leer lassen = unverändert`
        : 'Neuen Token eingeben';
      document.getElementById('cfgChannelIndicator').checked =
        (d.CHANNEL_STATUS_INDICATOR || 'true') !== 'false';
    } catch (e) {
      document.getElementById('cfgStatus').textContent = 'Ladefehler: ' + e.message;
      document.getElementById('cfgStatus').className = 'err';
    }
  }

  // ── Config speichern ──────────────────────────────────
  async function saveConfig() {
    const btn = document.getElementById('btnCfgSave');
    const st  = document.getElementById('cfgStatus');
    btn.disabled = true;
    btn.textContent = '⏳ Speichern…';
    st.textContent = '';
    st.className = '';

    const body = {};
    const token   = document.getElementById('cfgToken').value.trim();
    const statusCh= document.getElementById('cfgStatusCh').value.trim();
    const notifCh = document.getElementById('cfgNotifCh').value.trim();
    const kumaUrl = document.getElementById('cfgKumaUrl').value.trim();
    const renderMode = document.getElementById('cfgRenderMode').value;

    if (token)    body.DISCORD_TOKEN                = token;
    if (statusCh) body.STATUS_CHANNEL_ID            = statusCh;
    if (notifCh)  body.DISCORD_NOTIFICATION_CHANNEL = notifCh;
    if (kumaUrl)  body.UPTIME_KUMA_URL              = kumaUrl;
    if (renderMode) body.DISCORD_STATUS_RENDER_MODE = renderMode;
    body.CHANNEL_STATUS_INDICATOR = document.getElementById('cfgChannelIndicator').checked ? 'true' : 'false';

    // immer mindestens CHANNEL_STATUS_INDICATOR → body nie leer
    try {
      const res = await fetch('/api/config', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(body),
      }).then(r => r.json());

      if (res.ok) {
        st.textContent = `✓ Gespeichert: ${res.updated.join(', ')}${res.restarted ? ' · Bot wird neu gestartet…' : ''}`;
        st.className = 'ok';
        toast('✓ Konfiguration gespeichert', 'ok');
        // Nach 4s neu laden (Bot braucht Zeit zum Neustart)
        if (res.restarted) setTimeout(() => { loadConfig(); fetchAll(); }, 4000);
        else loadConfig();
      } else {
        st.textContent = '✗ ' + res.error;
        st.className = 'err';
        toast('Fehler: ' + res.error, 'err');
      }
    } catch (e) {
      st.textContent = 'Verbindungsfehler: ' + e.message;
      st.className = 'err';
      toast('Verbindungsfehler', 'err');
    } finally {
      btn.disabled = false;
      btn.textContent = '💾 Speichern & Neu starten';
    }
  }

  // Config beim Start laden
  loadConfig();

  // ────────────────────────────────────────────────────────────────────────
  // DRAGGABLE + COLLAPSIBLE CARDS SYSTEM
  // ────────────────────────────────────────────────────────────────────────

  const STORAGE_KEY_COLLAPSE = 'dashboard-collapsed';
  const STORAGE_KEY_ORDER    = 'dashboard-card-order';
  const STORAGE_KEY_SPAN     = 'dashboard-card-span';

  let dragSrc = null;
  let dropPlaceholder = null;

  function getStableCardId(card, idx) {
    if (card.id) return `card:${card.id}`;
    const title = card.querySelector('.card-title')?.textContent?.trim().toLowerCase() || 'unknown';
    const slug = title.replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'unknown';
    return `card:${slug}:${idx}`;
  }

  function initCardSystem() {
    const grid = document.getElementById('dashboardGrid');
    if (!grid) return;

    if (!grid.dataset.dragBound) {
      grid.dataset.dragBound = '1';
      grid.addEventListener('dragover', (e) => {
        e.preventDefault();
        if (!dragSrc || !dropPlaceholder) return;
        if (e.target === grid) {
          dropPlaceholder.dataset.span = dragSrc.dataset.span || '12';
          grid.appendChild(dropPlaceholder);
        }
      });
      grid.addEventListener('drop', (e) => {
        e.preventDefault();
        if (!dragSrc || !dropPlaceholder) return;
        if (dropPlaceholder.parentNode === grid) {
          grid.insertBefore(dragSrc, dropPlaceholder);
          saveCardOrder();
        }
      });
    }

    Array.from(grid.querySelectorAll(':scope > .card')).forEach((card, idx) => {
      if (!card.dataset.cardId) {
        card.dataset.cardId = getStableCardId(card, idx);
      }
      if (!card.dataset.initialized) {
        card.dataset.initialized = '1';
        setupDrag(card);
        addCardControls(card);
      }
    });

    restoreCollapseStates();
    restoreSpanStates();
    restoreCardOrder();
  }

  function setupDrag(card) {
    card.draggable = true;

    card.addEventListener('dragstart', (e) => {
      dragSrc = card;
      ensureDropPlaceholder(card);
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', card.dataset.cardId);
      setTimeout(() => card.classList.add('dragging'), 0);
    });

    card.addEventListener('dragend', () => {
      card.classList.remove('dragging');
      document.querySelectorAll('.card.drag-over').forEach(c => c.classList.remove('drag-over'));
      removeDropPlaceholder();
      dragSrc = null;
    });

    card.addEventListener('dragover', (e) => {
      e.preventDefault();
      if (!dragSrc || dragSrc === card) return;
      card.classList.add('drag-over');

      const rect = card.getBoundingClientRect();
      const placeBefore = e.clientY < rect.top + rect.height / 2;
      const grid = document.getElementById('dashboardGrid');
      if (!grid || !dropPlaceholder) return;

      dropPlaceholder.dataset.span = dragSrc.dataset.span || '12';
      if (placeBefore) {
        if (card !== dropPlaceholder.nextElementSibling) {
          grid.insertBefore(dropPlaceholder, card);
        }
      } else {
        if (card.nextSibling !== dropPlaceholder) {
          grid.insertBefore(dropPlaceholder, card.nextSibling);
        }
      }
    });

    card.addEventListener('dragleave', (e) => {
      if (!card.contains(e.relatedTarget)) card.classList.remove('drag-over');
    });

    card.addEventListener('drop', (e) => {
      e.preventDefault();
      card.classList.remove('drag-over');
      if (!dragSrc || dragSrc === card) return;
      const grid = document.getElementById('dashboardGrid');
      if (grid && dropPlaceholder && dropPlaceholder.parentNode === grid) {
        grid.insertBefore(dragSrc, dropPlaceholder);
      }
      saveCardOrder();
    });
  }

  function ensureDropPlaceholder(card) {
    if (!dropPlaceholder) {
      dropPlaceholder = document.createElement('div');
      dropPlaceholder.className = 'drop-placeholder';
      dropPlaceholder.setAttribute('aria-hidden', 'true');
    }
    dropPlaceholder.dataset.span = card.dataset.span || '12';
    const grid = document.getElementById('dashboardGrid');
    if (grid && dropPlaceholder.parentNode !== grid) {
      grid.appendChild(dropPlaceholder);
    }
  }

  function removeDropPlaceholder() {
    if (dropPlaceholder && dropPlaceholder.parentNode) {
      dropPlaceholder.parentNode.removeChild(dropPlaceholder);
    }
  }

  function addCardControls(card) {
    const title = card.querySelector('.card-title');
    const titleClone = title ? title.cloneNode(true) : null;
    title?.remove();

    const header = document.createElement('div');
    header.className = 'card-header';

    const left = document.createElement('div');
    left.className = 'card-header-left';
    if (titleClone) left.appendChild(titleClone);
    header.appendChild(left);

    const SPANS = [
      { label: '½', span: '6',  title: 'Halbe Breite' },
      { label: '¾', span: '9',  title: 'Dreiviertel Breite' },
      { label: '↔', span: '12', title: 'Volle Breite' },
    ];
    const widthBtns = document.createElement('div');
    widthBtns.style.cssText = 'display:flex;gap:3px;margin-right:6px';
    const currentSpan = card.dataset.span || '12';
    SPANS.forEach(({ label, span, title }) => {
      const wb = document.createElement('button');
      wb.className = 'btn-width' + (span === currentSpan ? ' active' : '');
      wb.textContent = label;
      wb.title = title;
      wb.addEventListener('click', (e) => {
        e.stopPropagation();
        card.dataset.span = span;
        const s = JSON.parse(localStorage.getItem(STORAGE_KEY_SPAN) || '{}');
        s[card.dataset.cardId] = span;
        localStorage.setItem(STORAGE_KEY_SPAN, JSON.stringify(s));
        widthBtns.querySelectorAll('.btn-width').forEach(b => b.classList.remove('active'));
        wb.classList.add('active');
      });
      widthBtns.appendChild(wb);
    });

    const collapseBtn = document.createElement('button');
    collapseBtn.className = 'btn-collapse';
    collapseBtn.innerHTML = '−';
    collapseBtn.title = 'Ein-/Ausklappen';
    collapseBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const content = card.querySelector('.card-content');
      if (!content) return;
      const collapsed = content.classList.toggle('collapsed');
      collapseBtn.innerHTML = collapsed ? '+' : '−';
      const s = JSON.parse(localStorage.getItem(STORAGE_KEY_COLLAPSE) || '{}');
      s[card.dataset.cardId] = collapsed;
      localStorage.setItem(STORAGE_KEY_COLLAPSE, JSON.stringify(s));
    });

    const controls = document.createElement('div');
    controls.className = 'card-controls';
    controls.appendChild(widthBtns);
    controls.appendChild(collapseBtn);
    header.appendChild(controls);
    card.insertBefore(header, card.firstChild);

    const content = document.createElement('div');
    content.className = 'card-content';
    while (card.children.length > 1) content.appendChild(card.children[1]);
    card.appendChild(content);
  }

  function restoreCollapseStates() {
    const s = JSON.parse(localStorage.getItem(STORAGE_KEY_COLLAPSE) || '{}');
    document.querySelectorAll('#dashboardGrid > .card').forEach(card => {
      if (s[card.dataset.cardId]) {
        card.querySelector('.card-content')?.classList.add('collapsed');
        const btn = card.querySelector('.btn-collapse');
        if (btn) btn.innerHTML = '+';
      }
    });
  }

  function restoreSpanStates() {
    const s = JSON.parse(localStorage.getItem(STORAGE_KEY_SPAN) || '{}');
    document.querySelectorAll('#dashboardGrid > .card').forEach(card => {
      const span = s[card.dataset.cardId];
      if (!span) return;
      card.dataset.span = span;
      card.querySelectorAll('.btn-width').forEach(wb => {
        wb.classList.toggle('active', wb.title.startsWith(
          span === '6' ? 'Halbe' : span === '9' ? 'Dreiviertel' : 'Volle'
        ));
      });
    });
  }

  function restoreCardOrder() {
    const grid = document.getElementById('dashboardGrid');
    const saved = JSON.parse(localStorage.getItem(STORAGE_KEY_ORDER) || 'null');
    if (!saved?.length) return;
    saved.forEach(cid => {
      const el = grid.querySelector(`[data-card-id="${cid}"]`);
      if (el?.parentNode === grid) grid.appendChild(el);
    });
  }

  function saveCardOrder() {
    const grid = document.getElementById('dashboardGrid');
    const order = Array.from(grid.querySelectorAll(':scope > .card')).map(c => c.dataset.cardId);
    localStorage.setItem(STORAGE_KEY_ORDER, JSON.stringify(order));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCardSystem);
  } else {
    initCardSystem();
  }

  const _origFetchAll = window.fetchAll;
  window.fetchAll = function() { _origFetchAll?.call(this); setTimeout(initCardSystem, 150); };
</script>
</body>
</html>
