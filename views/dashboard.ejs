  async function loadExistingGuildChannels() {
    const btn = document.getElementById('btnLoadExistingChannels');
    const state = document.getElementById('cfgExistingChannelState');
    const categoryEl = document.getElementById('cfgExistingCategorySelect');

    const serviceGuild = (document.getElementById('cfgServiceGuildId')?.value || '').trim();
    const defaultGuild = (document.getElementById('cfgGuildId')?.value || '').trim();
    const guildId = serviceGuild || defaultGuild;

    if (!guildId) {
      if (state) state.textContent = 'Bitte zuerst SERVICE_GUILD_ID oder GUILD_ID setzen.';
      toast('Guild-ID fehlt', 'warn');
      return;
    }

    if (btn) { btn.disabled = true; btn.textContent = 'вП≥ LadeвА¶'; }
    if (state) state.textContent = 'Lade Kategorien und Kan√§le aus DiscordвА¶';

    try {
      const d = await fetch(`/api/discord-channel-browser?guildId=${encodeURIComponent(guildId)}`).then(r => r.json());
      if (!d.ok) {
        if (state) state.textContent = 'Fehler: ' + (d.error || 'Unbekannt');
        toast('Discord-Kan√§le laden fehlgeschlagen', 'err');
        return;
      }

      _existingCategoryData = d.categories || [];
      _existingUncategorized = d.uncategorized || [];

      categoryEl.innerHTML = '<option value="">Kategorie ausw√§hlenвА¶</option>';
      _existingCategoryData.forEach((cat) => {
        const opt = document.createElement('option');
        opt.value = cat.id;
        opt.textContent = `${cat.name} (${cat.channels?.length || 0})`;
        categoryEl.appendChild(opt);
      });
      if (_existingUncategorized.length) {
        const opt = document.createElement('option');
        opt.value = '__uncategorized__';
        opt.textContent = `Ohne Kategorie (${_existingUncategorized.length})`;
        categoryEl.appendChild(opt);
      }

      categoryEl.onchange = _renderExistingChannelSelect;
      _renderExistingChannelSelect();

      if (state) state.textContent = `Geladen: ${d.guild?.name || guildId} ¬Ј ${_existingCategoryData.length} Kategorien`;
      toast('Kategorien/Kan√§le geladen', 'ok');
    } catch (e) {
      if (state) state.textContent = 'Verbindungsfehler: ' + e.message;
      toast('Verbindungsfehler beim Laden', 'err');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'рЯФО Aus Discord laden'; }
    }
  }

  function addSelectedChannelToMap() {
    const monitorEl = document.getElementById('cfgExistingMonitorName');
    const channelEl = document.getElementById('cfgExistingChannelSelect');
    const mapEl = document.getElementById('cfgServiceChannelMap');
    const state = document.getElementById('cfgExistingChannelState');

    const monitorName = String(monitorEl?.value || '').trim();
    const channelId = String(channelEl?.value || '').trim();
    if (!monitorName) {
      toast('Monitorname fehlt', 'warn');
      return;
    }
    if (!channelId) {
      toast('Kanal fehlt', 'warn');
      return;
    }

    const current = String(mapEl?.value || '').trim();
    const entries = current ? current.split(';').map(s => s.trim()).filter(Boolean) : [];
    const normalizedMonitor = monitorName.toLowerCase();

    const filtered = entries.filter((entry) => {
      const idx = entry.lastIndexOf('=');
      if (idx <= 0) return true;
      const left = entry.slice(0, idx).trim().toLowerCase();
      return left !== normalizedMonitor;
    });

    filtered.push(`${monitorName}=${channelId}`);
    mapEl.value = filtered.join(';');

    if (state) state.textContent = `Mapping aktualisiert: ${monitorName} вЖТ ${channelId}`;
    toast('Kanal ins Mapping √Љbernommen', 'ok');
  }

  function applyEnabledCommandsToCheckboxes(value) {
    const enabled = new Set(_parseEnabledCommands(value));
    const boxes = document.querySelectorAll('[data-cmd]');
    boxes.forEach((box) => {
      box.checked = enabled.has(box.dataset.cmd);
    });
  }

  function syncEnabledCommandsFromCheckboxes(changedBox = null) {
    const boxes = Array.from(document.querySelectorAll('[data-cmd]'));
    if (!boxes.length) return;

    let selected = boxes.filter(b => b.checked);
    if (!selected.length) {
      if (changedBox) changedBox.checked = true;
      selected = boxes.filter(b => b.checked);
      toast('Mindestens ein Bot-Kommando muss aktiv bleiben', 'warn');
    }

    const value = selected.map(b => b.dataset.cmd).join(',');
    const hidden = document.getElementById('cfgEnabledCommands');
    if (hidden) hidden.value = value;
  }

