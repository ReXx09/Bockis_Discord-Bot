  function _parseEnabledCommands(value) {
    const allowed = ['status', 'uptime', 'refresh', 'help', 'coinflip', 'dice', 'eightball', 'cleanup', 'translate', 'ping', 'botinfo', 'serverstatus', 'ki', 'wetter', 'subscribe', 'remind', 'quote', 'poll', 'avatar', 'userinfo', 'testreply'];
    const entries = String(value || '')
      .split(',')
      .map(s => s.trim().toLowerCase())
      .filter(Boolean);
    const unique = Array.from(new Set(entries)).filter(cmd => allowed.includes(cmd));
    return unique.length ? unique : ['status', 'uptime', 'refresh', 'help', 'coinflip', 'dice', 'eightball', 'cleanup', 'translate'];
  }

  // вФАвФА Discord-Kanal-Browser f√Љr Mapping-√Ьbernahme вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
  let _existingCategoryData = [];
  let _existingUncategorized = [];

  function _renderExistingChannelSelect() {
    const categoryEl = document.getElementById('cfgExistingCategorySelect');
    const channelEl = document.getElementById('cfgExistingChannelSelect');
    if (!categoryEl || !channelEl) return;

    const selectedCategoryId = categoryEl.value || '__uncategorized__';
    let channels = [];

    if (selectedCategoryId === '__uncategorized__') {
      channels = _existingUncategorized;
    } else {
      channels = (_existingCategoryData.find(c => c.id === selectedCategoryId)?.channels) || [];
    }

    channelEl.innerHTML = '<option value="">Kanal ausw√§hlenвА¶</option>';
    channels.forEach((ch) => {
      const opt = document.createElement('option');
      opt.value = ch.id;
      opt.textContent = `# ${ch.name}`;
      channelEl.appendChild(opt);
    });
