<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bockis Bot – Dashboard</title>
  <style>
    :root {
      --bg:       #0d1117;
      --surface:  #161b22;
      --surface2: #21262d;
      --border:   #30363d;
      --text:     #e6edf3;
      --muted:    #8b949e;
      --green:    #3fb950;
      --red:      #f85149;
      --yellow:   #d29922;
      --blue:     #388bfd;
      --purple:   #8957e5;
      --radius:   8px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 24px;
    }

    /* HEADER */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border);
    }
    .header h1 { font-size: 20px; font-weight: 600; }
    .header .sub { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .header-right { display: flex; align-items: center; gap: 12px; }
    .timer { font-size: 12px; color: var(--muted); }

    /* SUBNAV */
    .subnav {
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
      margin: 0;
      padding: 0;
      border: none;
      border-radius: 0;
      background: transparent;
    }
    .subnav-btn {
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--muted);
      padding: 7px 12px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: .03em;
    }
    .subnav-btn:hover { color: var(--text); border-color: var(--blue); }
    .subnav-btn.active {
      background: rgba(56,139,253,.18);
      color: #c8e1ff;
      border-color: rgba(56,139,253,.75);
      box-shadow: inset 0 0 0 1px rgba(56,139,253,.2);
    }
    .pane-hidden { display: none !important; }

    /* BUTTONS */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--text);
      font-size: 13px;
      cursor: pointer;
      transition: background .15s;
    }
    .btn:hover { background: var(--border); }
    .btn-green { background: #238636; border-color: #2ea043; color: #fff; }
    .btn-green:hover { background: #2ea043; }
    .btn-green:disabled { opacity: .6; cursor: not-allowed; }
    .btn-small { padding: 4px 8px; font-size: 11px; }

    /* GRID */
    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 16px;
    }
    @media (max-width: 680px) { .grid-2 { grid-template-columns: 1fr; } }
    .grid-monitors {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
      gap: 12px;
    }

    /* DASHBOARD GRID LAYOUT */
    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 16px;
    }
    .dashboard-grid > .card {
      grid-column: span 12;
    }
    .dashboard-grid > .card[data-span="6"]  { grid-column: span 6; }
    .dashboard-grid > .card[data-span="4"]  { grid-column: span 4; }
    .dashboard-grid > .card[data-span="3"]  { grid-column: span 3; }
    .dashboard-grid > .card[data-span="12"] { grid-column: span 12; }
    @media (max-width: 900px) { .dashboard-grid > .card { grid-column: span 12 !important; } }

    /* CARD WIDTH BUTTONS */
    .btn-width {
      background: none;
      border: 1px solid var(--border);
      color: var(--muted);
      cursor: pointer;
      font-size: 10px;
      padding: 2px 6px;
      border-radius: 4px;
      transition: color .15s, border-color .15s;
      white-space: nowrap;
    }
    .btn-width:hover { color: var(--text); border-color: var(--blue); }
    .btn-width.active { color: var(--blue); border-color: var(--blue); }

    /* CARD */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
    }
    .card.dragging { opacity: 0.5; }
    .card.drag-over { border-color: var(--blue); box-shadow: 0 0 0 2px rgba(56,139,253,.2); }
    .drop-placeholder {
      min-height: 96px;
      border: 2px dashed rgba(56,139,253,.75);
      border-radius: var(--radius);
      background: rgba(56,139,253,.08);
      box-shadow: 0 0 0 2px rgba(56,139,253,.16), 0 0 18px rgba(56,139,253,.24);
      pointer-events: none;
      animation: dropPulse .9s ease-in-out infinite alternate;
    }
    @keyframes dropPulse {
      from { box-shadow: 0 0 0 1px rgba(56,139,253,.14), 0 0 8px rgba(56,139,253,.18); }
      to   { box-shadow: 0 0 0 2px rgba(56,139,253,.28), 0 0 22px rgba(56,139,253,.34); }
    }
    
    /* CARD WRAPPER MIT COLLAPSE */
    .card-wrapper {
      display: flex;
      flex-direction: column;
    }
    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
      cursor: grab;
      user-select: none;
    }
    .card-header:active { cursor: grabbing; }
    .card-header-left { display: flex; align-items: center; gap: 8px; flex: 1; }
    .card-title {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: var(--muted);
      margin: 0;
    }
    .card-controls { display: flex; gap: 6px; }
    .btn-collapse {
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 14px;
      padding: 4px 8px;
      transition: color .15s;
      width: 28px; height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .btn-collapse:hover { color: var(--text); }
    
    .card-content {
      overflow: hidden;
      transition: max-height .25s ease, opacity .25s ease;
      max-height: 2000px;
      opacity: 1;
    }
    .card-content.collapsed {
      max-height: 0;
      opacity: 0;
      pointer-events: none;
    }

    /* INFO ROW */
    .row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 7px 0;
      border-bottom: 1px solid var(--border);
      font-size: 13px;
    }
    .row:last-child { border-bottom: none; }
    .row-label { color: var(--muted); }
    .row-value { font-weight: 500; font-family: 'SFMono-Regular', Consolas, monospace; }

    /* BADGE */
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .04em;
    }
    .b-green  { background: rgba(63,185,80,.15);  color: var(--green); }
    .b-red    { background: rgba(248,81,73,.15);   color: var(--red); }
    .b-yellow { background: rgba(210,153,34,.15);  color: var(--yellow); }
    .b-gray   { background: rgba(139,148,158,.15); color: var(--muted); }
    .b-purple { background: rgba(137,87,229,.15);  color: var(--purple); }

    /* DOT */
    .dot {
      display: inline-block;
      width: 8px; height: 8px;
      border-radius: 50%;
      margin-right: 5px;
    }
    .dot-g { background: var(--green); box-shadow: 0 0 5px var(--green); }
    .dot-r { background: var(--red);   box-shadow: 0 0 5px var(--red); }

    /* MONITOR CARD */
    .mc {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      position: relative;
      overflow: hidden;
    }
    .mc::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .mc.online::before  { background: var(--green); }
    .mc.offline::before { background: var(--red); }
    .mc.pending::before { background: var(--yellow); }
    .mc.inactive::before{ background: var(--muted); }
    .mc-name {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 4px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .mc-group { font-size: 11px; color: var(--muted); margin-bottom: 10px; }
    .uptime-bar {
      height: 4px;
      background: var(--surface2);
      border-radius: 2px;
      margin: 8px 0;
      overflow: hidden;
    }
    .uptime-fill { height: 100%; border-radius: 2px; transition: width .5s ease; }
    .uf-g { background: var(--green); }
    .uf-y { background: var(--yellow); }
    .uf-r { background: var(--red); }
    .mc-meta {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: var(--muted);
      margin-top: 6px;
    }

    /* SERVICE CONTROL */
    .svc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 12px;
    }
    .svc-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .svc-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .svc-name { font-size: 13px; font-weight: 600; }
    .svc-actions { display: flex; gap: 6px; }
    .btn-svc {
      padding: 4px 10px;
      font-size: 11px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--text);
      cursor: pointer;
      transition: background .15s;
    }
    .btn-svc:hover { background: var(--border); }
    .btn-svc.start  { color: var(--green); border-color: rgba(63,185,80,.4); }
    .btn-svc.stop   { color: var(--red);   border-color: rgba(248,81,73,.4); }
    .btn-svc.restart{ color: var(--yellow);border-color: rgba(210,153,34,.4); }
    .btn-svc:disabled { opacity: .45; cursor: not-allowed; }

    /* SECTION */
    .section-hdr {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin: 24px 0 12px;
    }
    .section-hdr .title { font-size: 14px; font-weight: 600; }
    .section-hdr .count {
      font-size: 12px;
      color: var(--muted);
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2px 10px;
    }

    /* LOG VIEWER */
    .log-viewer {
      background: #010409;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      height: 260px;
      overflow-y: auto;
      font-family: 'SFMono-Regular', Consolas, monospace;
      font-size: 12px;
      line-height: 1.65;
    }
    .ll { color: var(--muted); padding: 1px 0; white-space: pre-wrap; word-break: break-all; }
    .ll.e { color: var(--red); }
    .ll.w { color: var(--yellow); }
    .ll.i { color: var(--text); }

    /* SKELETON */
    .sk {
      background: linear-gradient(90deg, var(--surface2) 25%, var(--border) 50%, var(--surface2) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      border-radius: 4px;
      height: 13px;
      margin-bottom: 14px;
    }
    @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

    /* TOAST */
    #toast {
      position: fixed;
      bottom: 24px; right: 24px;
      padding: 12px 18px;
      border-radius: var(--radius);
      font-size: 13px;
      background: var(--surface2);
      border: 1px solid var(--border);
      display: none;
      z-index: 999;
      box-shadow: 0 4px 20px rgba(0,0,0,.5);
    }
    #toast.show  { display: block; animation: fiu .25s ease; }
    #toast.ok    { border-color: var(--green); color: var(--green); }
    #toast.err   { border-color: var(--red);   color: var(--red); }
    @keyframes fiu { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }

    .muted { color: var(--muted); font-size: 12px; }
    .mb12  { margin-bottom: 12px; }

    /* UPDATE BANNER */
    #updateBanner {
      display: none;
      background: rgba(210,153,34,.08);
      border: 1px solid rgba(210,153,34,.4);
      border-radius: var(--radius);
      padding: 14px 18px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }
    #updateBanner.hidden { display: none !important; }
    .ub-left { display: flex; align-items: center; gap: 10px; }
    .ub-icon { font-size: 20px; }
    .ub-title { font-size: 14px; font-weight: 600; color: var(--yellow); }
    .ub-sub   { font-size: 12px; color: var(--muted); margin-top: 2px; }


    .commit-list { margin-top: 10px; }
    .commit {
      display: flex; gap: 12px; align-items: baseline;
      padding: 6px 0; border-bottom: 1px solid var(--border);
      font-size: 13px;
    }
    .commit:last-child { border-bottom: none; }
    .commit-hash {
      font-family: 'SFMono-Regular', Consolas, monospace;
      font-size: 11px; color: var(--blue);
      min-width: 52px;
    }
    .commit-msg  { flex: 1; color: var(--text); }
    .commit-when { font-size: 11px; color: var(--muted); white-space: nowrap; }

    /* TERMINAL OUTPUT */
    #updateLog {
      background: #010409;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px;
      height: 200px;
      overflow-y: auto;
      font-family: 'SFMono-Regular', Consolas, monospace;
      font-size: 12px;
      line-height: 1.6;
      display: none;
      margin-top: 12px;
    }
    #updateLog.visible { display: block; }
    .ul-line { white-space: pre-wrap; word-break: break-all; color: var(--muted); }
    .ul-ok   { color: var(--green); }
    .ul-err  { color: var(--red); }
    .ul-warn { color: var(--yellow); }

    /* DEPS TABLE */
    .deps-table { width: 100%; border-collapse: collapse; margin-top: 8px; font-size: 12px; }
    .deps-table th {
      text-align: left; font-size: 10px; font-weight: 600;
      text-transform: uppercase; letter-spacing: .06em;
      color: var(--muted); padding: 5px 10px;
      border-bottom: 1px solid var(--border);
    }
    .deps-table td { padding: 6px 10px; border-bottom: 1px solid rgba(255,255,255,.04); font-family: 'SFMono-Regular', Consolas, monospace; vertical-align: middle; }
    .deps-table tr:last-child td { border-bottom: none; }
    .deps-table tr:hover td { background: rgba(255,255,255,.03); }
    .dep-name  { font-weight: 600; color: var(--text); }
    .dep-dev   { font-size: 10px; color: var(--muted); margin-left: 4px; }
    .dep-ver   { color: var(--muted); }
    .dep-badge {
      display: inline-block; padding: 2px 7px; border-radius: 4px;
      font-size: 10px; font-weight: 700; letter-spacing: .03em;
    }
    .dep-ok-badge   { background: rgba(63,185,80,.12);  color: var(--green); }
    .dep-warn-badge { background: rgba(210,153,34,.12); color: var(--yellow); }
    .dep-crit-badge { background: rgba(248,81,73,.12);  color: var(--red); }

    /* CONFIG FORM */
    .cfg-form { margin-top: 4px; }
    .cfg-module-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 12px;
      margin-bottom: 10px;
    }
    .cfg-module {
      border: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(17,23,33,.9), rgba(17,23,33,.72));
      border-radius: 10px;
      padding: 12px;
    }
    .cfg-module-title {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--blue);
      margin-bottom: 10px;
      border-bottom: 1px solid rgba(255,255,255,.06);
      padding-bottom: 6px;
    }
    .cfg-field { margin-bottom: 14px; }
    .cfg-label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .cfg-input {
      width: 100%;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      font-family: 'SFMono-Regular', Consolas, monospace;
      font-size: 12px;
      padding: 8px 10px;
      box-sizing: border-box;
      outline: none;
      transition: border-color .15s;
    }
    .cfg-input:focus { border-color: var(--blue); }
    .cfg-hint { font-size: 11px; color: var(--muted); margin-top: 4px; }
    .cfg-actions { display: flex; gap: 10px; align-items: center; margin-top: 6px; }
    #cfgStatus { font-size: 12px; }
    #cfgStatus.ok  { color: var(--green); }
    #cfgStatus.err { color: var(--red); }
    #cfgStatus.warn { color: var(--yellow, #d4b60d); }

    .diag-hints { margin-top: 10px; }
    .diag-hints .ll { border-left: 2px solid transparent; padding-left: 8px; }
    .diag-hints .ll.e { border-left-color: var(--red); }
    .diag-hints .ll.w { border-left-color: var(--yellow); }
    .diag-hints .ll.i { border-left-color: var(--blue); }
  </style>
</head>
<body>

<!-- ── UPDATE BANNER (wird per JS eingeblendet) ─────── -->
<!-- ── HEADER ─────────────────────────────────────────── -->
<div class="header">
  <div>
    <h1>🤖 Bockis Bot · Dashboard</h1>
    <div class="sub" id="headerSub">Service Monitor · Live-Ansicht</div>
  </div>
  
  <!-- ── SUBNAV IN HEADER ─────────────────────────────── -->
  <div class="subnav" style="position:absolute;left:50%;transform:translateX(-50%);width:auto;background:transparent;border:none;gap:4px;padding:0;margin:0">
    <button class="subnav-btn active" data-pane-btn="overview" onclick="setActivePane('overview')" title="Live-Übersicht: Bot, System, Services">📊 Übersicht</button>
    <button class="subnav-btn" data-pane-btn="settings" onclick="setActivePane('settings')" title="Konfiguration & Service-Steuerung">⚙️ Einstellungen</button>
    <button class="subnav-btn" data-pane-btn="updates" onclick="setActivePane('updates')" title="Updates & Git-Commits">📦 Updates</button>
    <button class="subnav-btn" data-pane-btn="diagnostics" onclick="setActivePane('diagnostics')" title="Logs & Link-Preview-Diagnose">🧪 Diagnose</button>
  </div>
  
  <div class="header-right">
    <span class="timer" id="timer">Auto-Refresh in 30s</span>
    <button class="btn btn-green" id="btnRefresh" onclick="manualRefresh()">
      ↺ Discord Refresh
    </button>
  </div>
</div>

<!-- ── UPDATE BANNER ─────────────────────────────────── -->
<div id="updateBanner" class="hidden" data-pane="updates">
  <div class="ub-left">
    <span class="ub-icon">⚠️</span>
    <div>
      <div class="ub-title">Update verfügbar</div>
      <div class="ub-sub" id="ubSub">Neue Version auf GitHub gefunden</div>
    </div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <button class="btn" onclick="toggleUpdateSection()">Details anzeigen ↓</button>
    <button class="btn btn-green" id="btnUpdateRun" onclick="runUpdate()">▶ Update jetzt starten</button>
  </div>
</div>

<!-- ── DASHBOARD GRID ───────────────────────────────── -->
<div class="dashboard-grid" id="dashboardGrid">

<!-- ── BOT STATUS ─────────────────────────────────────── -->
<div class="card" id="botCard" data-span="6" data-pane="overview">
  <div class="card-title">Bot Status</div>
  <div id="botInfo">
    <div class="sk"></div>
    <div class="sk" style="width:70%"></div>
    <div class="sk" style="width:50%"></div>
  </div>
</div>

<!-- ── SYSTEM ─────────────────────────────────────────── -->
<div class="card" id="sysCard" data-span="6" data-pane="overview">
  <div class="card-title">System</div>
  <div id="sysInfo">
    <div class="sk"></div>
    <div class="sk" style="width:70%"></div>
    <div class="sk" style="width:50%"></div>
  </div>
</div>

<!-- ── ROW 1b: CLOUDFLARE TUNNEL ─────────────────────── -->
<div class="card" id="tunnelCard" data-span="12" data-pane="overview">
  <div class="card-title">🌐 Cloudflare Tunnel</div>
  <div id="tunnelInfo">
    <div class="sk"></div>
    <div class="sk" style="width:55%"></div>
  </div>
</div>

<!-- ── ROW 1c: DISCORD KONFIGURATION ───────────────────── -->
<div class="card" id="cfgCard" data-span="12" data-pane="settings">
  <div class="card-title">⚙️ Einstellungen</div>
  <div class="cfg-form">
    <div class="cfg-module-grid">
      <div class="cfg-module">
        <div class="cfg-module-title">🤖 Bot</div>
        <div class="cfg-field">
          <label class="cfg-label" for="cfgToken">Discord Bot Token</label>
          <input class="cfg-input" id="cfgToken" type="password" autocomplete="off"
                 placeholder="Neuen Token eingeben (leer lassen = unverändert)">
          <div class="cfg-hint">Leer lassen, um den bestehenden Token zu behalten.</div>
        </div>
        <div class="cfg-field">
          <label class="cfg-label" for="cfgStatusCh">Status-Channel ID</label>
          <input class="cfg-input" id="cfgStatusCh" type="text" autocomplete="off"
                 placeholder="z. B. 123456789012345678">
        </div>
        <div class="cfg-field">
          <label class="cfg-label" for="cfgNotifCh">Benachrichtigungs-Channel ID</label>
          <input class="cfg-input" id="cfgNotifCh" type="text" autocomplete="off"
                 placeholder="z. B. 123456789012345678">
        </div>
        <div class="cfg-field">
          <label class="cfg-label" for="cfgGuildId">Guild ID</label>
          <input class="cfg-input" id="cfgGuildId" type="text" autocomplete="off"
                 placeholder="z. B. 123456789012345678">
        </div>
        <div class="cfg-field">
          <label class="cfg-label" for="cfgMonitoredServices">Monitored Services</label>
          <input class="cfg-input" id="cfgMonitoredServices" type="text" autocomplete="off"
                 placeholder="Kommagetrennt, z. B. website,api,database">
