                   placeholder="👍;🔥;😂">
            <select class="cfg-input" id="cfgAutoReactionPreset" style="min-width:220px;flex:1">
              <option value="">Emoji-Vorlage wählen…</option>
              <option value="👍">👍 Zustimmung</option>
              <option value="🔥">🔥 Hype</option>
              <option value="😂">😂 Lustig</option>
              <option value="🎉">🎉 Feiern</option>
              <option value="👀">👀 Beobachten</option>
              <option value="🤖">🤖 Bot</option>
              <option value="❤️">❤️ Herz</option>
              <option value="✅">✅ Erledigt</option>
              <option value="🚀">🚀 Rocket</option>
              <option value="<a:partyblob:ID>">Custom Emoji Muster</option>
